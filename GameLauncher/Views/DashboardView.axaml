<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GameLauncher.ViewModels"
             xmlns:views="using:GameLauncher.Views"
             xmlns:models="using:GameLauncher.Models"
             x:Class="GameLauncher.Views.DashboardView"
             x:DataType="vm:DashboardViewModel"
             Classes="dashboard-root">

    <Grid>
    <Border Classes="dashboard-xb360-layout">
        <Grid RowDefinitions="Auto,Auto,*">
            <!-- Top header bar with user info -->
            <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="32,16,32,0">
                <Border Width="50" Height="50" Classes="xb360-avatar-tile">
                    <TextBlock Text="🙂" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20"/>
                </Border>
                <StackPanel Grid.Column="1" Margin="14,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Greeting}" Classes="xb360-header-title"/>
                    <TextBlock Text="signed in" Classes="xb360-header-subtitle"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="20" VerticalAlignment="Center">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{Binding GamesCount}" Classes="xb360-stat-num"/>
                        <TextBlock Text="Games" Classes="xb360-stat-lbl"/>
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{Binding AchievementsCount}" Classes="xb360-stat-num"/>
                        <TextBlock Text="Achievements" Classes="xb360-stat-lbl"/>
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{Binding TotalPlaytimeLabel}" Classes="xb360-stat-num"/>
                        <TextBlock Text="Playtime" Classes="xb360-stat-lbl"/>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- Blade navigation tabs -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="0"
                        Margin="0,16,0,0" Classes="xb360-blade-tabs">
                <TextBlock Text="My Games"
                           Classes.xb360-blade-tab-active="{Binding IsXb360MyGamesBlade}"
                           Classes="xb360-blade-tab"/>
                <TextBlock Text="Social"
                           Classes.xb360-blade-tab-active="{Binding IsXb360SocialBlade}"
                           Classes="xb360-blade-tab"/>
                <TextBlock Text="Games Library"
                           Classes.xb360-blade-tab-active="{Binding IsXb360GamesBlade}"
                           Classes="xb360-blade-tab"/>
                <TextBlock Text="Media"
                           Classes.xb360-blade-tab-active="{Binding IsXb360MediaBlade}"
                           Classes="xb360-blade-tab"/>
                <TextBlock Text="Settings"
                           Classes.xb360-blade-tab-active="{Binding IsXb360SettingsBlade}"
                           Classes="xb360-blade-tab"/>
            </StackPanel>

            <!-- Blade content -->
            <Grid Grid.Row="2">

                <!-- My Games blade -->
                <Grid ColumnDefinitions="*,380" Margin="32,20,32,20" IsVisible="{Binding IsXb360MyGamesBlade}">
                    <StackPanel Grid.Column="0" Spacing="12">
                        <!-- Featured / last played game -->
                        <Border Classes="xb360-metro-tile xb360-featured-tile"
                                IsVisible="{Binding FeaturedGame, Converter={x:Static ObjectConverters.IsNotNull}}">
                            <Grid ColumnDefinitions="*,Auto" Margin="20,16">
                                <StackPanel Spacing="10" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding FeaturedBadgeText}" Classes="xb360-featured-badge"/>
                                    <TextBlock Text="{Binding FeaturedGame.Title}" Classes="xb360-featured-title"/>
                                    <TextBlock Text="{Binding FeaturedGame.Platform}" Classes="xb360-featured-subtitle"/>
                                    <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,8,0,0">
                                        <Button Classes="btn-primary xb360-featured-button"
                                                Command="{Binding ContinuePlayingCommand}">
                                            ▶  Play
                                        </Button>
                                        <Button Classes="btn-secondary xb360-featured-button"
                                                Command="{Binding OpenFeaturedDetailCommand}">
                                            ···  More
                                        </Button>
                                    </StackPanel>
                                </StackPanel>
                                <Border Grid.Column="1" Width="150" Height="150"
                                        Margin="16,0,0,0" Classes="xb360-featured-cover">
                                    <views:CoverImage
                                        ImageUrl="{Binding FeaturedGame.CoverUrl}"
                                        FallbackText="{Binding FeaturedGame.Title}"
                                        FallbackGradient="{Binding FeaturedGame.CoverGradient}"
                                        SubText="{Binding FeaturedGame.Genre}"
                                        LetterFontSize="60"
                                        ImageCornerRadius="0"
                                        Width="150" Height="150"/>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Recent games horizontal scroll -->
                        <TextBlock Text="Recently Played" Classes="xb360-strip-header" Margin="0,8,0,0"/>
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding LocalLibraryGames}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:LocalGameCardVm">
                                        <Button Classes="game-card-btn xb360-recent-card-btn"
                                                Classes.focused="{Binding IsFocused}"
                                                Command="{Binding $parent[UserControl].DataContext.OpenLocalGameDetailCommand}"
                                                CommandParameter="{Binding}">
                                            <StackPanel>
                                                <Border Height="90" ClipToBounds="True">
                                                    <views:CoverImage
                                                        ImageUrl="{Binding CoverUrl}"
                                                        FallbackText="{Binding EffectiveTitle}"
                                                        FallbackGradient="{Binding CoverGradient}"
                                                        SubText="{Binding Platform}"
                                                        LetterFontSize="32"
                                                        ImageCornerRadius="0"
                                                        Height="90"/>
                                                </Border>
                                                <Border Padding="6,6,6,8">
                                                    <StackPanel Spacing="2">
                                                        <TextBlock Text="{Binding EffectiveTitle}" Classes="xb360-recent-title"/>
                                                        <TextBlock Text="{Binding Platform}" Classes="xb360-recent-platform"/>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>

                    <!-- Right panel: achievements -->
                    <StackPanel Grid.Column="1" Margin="16,0,0,0" Spacing="10">
                        <TextBlock Text="Recent Achievements" Classes="xb360-strip-header"/>
                        <ItemsControl ItemsSource="{Binding RecentAchievements}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:Achievement">
                                    <Border Classes="xb360-metro-tile xb360-achievement-tile" Margin="0,0,0,8">
                                        <Grid ColumnDefinitions="42,*" Margin="8">
                                            <Border Grid.Column="0" Classes="xb360-achievement-icon">
                                                <TextBlock Text="🏆" FontSize="18"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" Margin="10,0,0,0" Spacing="2">
                                                <TextBlock Text="{Binding Name}" Classes="xb360-achievement-title"/>
                                                <TextBlock Text="{Binding Description}" Classes="xb360-achievement-desc"/>
                                                <TextBlock Text="{Binding GameTitle}" Classes="xb360-achievement-meta"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>

                <!-- Social blade -->
                <StackPanel Margin="32,20,32,20" Spacing="12" IsVisible="{Binding IsXb360SocialBlade}">
                    <TextBlock Text="Friends &amp; Social" Classes="xb360-strip-header"/>
                    <!-- Online friends list with Invite / Message / View actions -->
                    <ItemsControl ItemsSource="{Binding OnlineFriends}" IsVisible="{Binding HasDashboardFriends}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:FriendPresenceVm">
                                <Border Classes="xb360-metro-tile xb360-metro-stat" Height="70" Margin="0,0,0,4">
                                    <Grid Margin="16,0" ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Username}" Classes="xb360-metro-label" FontSize="14"/>
                                            <TextBlock Text="{Binding StatusLabel}" Classes="xb360-achievement-desc"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Classes="btn-secondary" Padding="10,6" VerticalAlignment="Center">
                                            <TextBlock Text="···"/>
                                            <Button.Flyout>
                                                <MenuFlyout Placement="BottomEdgeAlignedRight">
                                                    <MenuItem Header="Invite">
                                                        <MenuItem Header="Crossplay"
                                                                  Command="{Binding $parent[UserControl].DataContext.InviteFriendViaConnectionCommand}"
                                                                  CommandParameter="{Binding Username, StringFormat='{}{0}|Crossplay'}"/>
                                                        <MenuItem Header="Radmin"
                                                                  Command="{Binding $parent[UserControl].DataContext.InviteFriendViaConnectionCommand}"
                                                                  CommandParameter="{Binding Username, StringFormat='{}{0}|Radmin'}"/>
                                                        <MenuItem Header="OnlineFix"
                                                                  Command="{Binding $parent[UserControl].DataContext.InviteFriendViaConnectionCommand}"
                                                                  CommandParameter="{Binding Username, StringFormat='{}{0}|OnlineFix'}"/>
                                                        <MenuItem Header="Steam"
                                                                  Command="{Binding $parent[UserControl].DataContext.InviteFriendViaConnectionCommand}"
                                                                  CommandParameter="{Binding Username, StringFormat='{}{0}|Steam'}"/>
                                                    </MenuItem>
                                                    <MenuItem Header="Message"
                                                              Command="{Binding $parent[UserControl].DataContext.MessageFriendCommand}"
                                                              CommandParameter="{Binding Username}"/>
                                                    <MenuItem Header="View"
                                                              Command="{Binding $parent[UserControl].DataContext.ViewFriendCommand}"
                                                              CommandParameter="{Binding Username}"/>
                                                </MenuFlyout>
                                            </Button.Flyout>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="{Binding DashboardInviteStatus}" Foreground="#888888" FontSize="12"
                               IsVisible="{Binding DashboardInviteStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                    <Border Classes="xb360-metro-tile xb360-metro-stat" Height="68">
                        <Grid Margin="16,0" ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Friends" Classes="xb360-metro-label" FontSize="14"/>
                            <TextBlock Text="{Binding OnlineFriendsCount, StringFormat='{}{0} online'}" Classes="xb360-achievement-desc"
                                       IsVisible="{Binding HasDashboardFriends}"/>
                            <TextBlock Text="No friends online right now." Classes="xb360-achievement-desc"
                                       IsVisible="{Binding !HasDashboardFriends}"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Classes="btn-secondary"
                                    Padding="12,6"
                                    VerticalAlignment="Center"
                                    Command="{Binding NavigateToFriendsCommand}">
                                All Friends
                            </Button>
                        </Grid>
                    </Border>
                    <Border Classes="xb360-metro-tile xb360-metro-stat" Height="80">
                        <Grid Margin="16,0" ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Inbox" Classes="xb360-metro-label" FontSize="14"/>
                            <TextBlock Text="Check your messages and invites." Classes="xb360-achievement-desc"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Classes="btn-secondary"
                                    Padding="12,6"
                                    VerticalAlignment="Center"
                                    Command="{Binding NavigateToInboxCommand}">
                                Open
                            </Button>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- Games Library blade (list view) -->
                <Grid ColumnDefinitions="*,340" Margin="32,20,32,20" IsVisible="{Binding IsXb360GamesBlade}">
                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Text="Games Library" Classes="xb360-strip-header"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="540">
                            <ItemsControl ItemsSource="{Binding LocalLibraryGames}"
                                          IsVisible="{Binding HasLocalLibraryGames}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:LocalGameCardVm">
                                        <Button Classes="xb360-list-game-btn"
                                                Classes.focused="{Binding IsFocused}"
                                                Command="{Binding $parent[UserControl].DataContext.OpenLocalGameDetailCommand}"
                                                CommandParameter="{Binding}">
                                            <Grid ColumnDefinitions="80,*,Auto" Margin="4,2">
                                                <Border Grid.Column="0" Width="80" Height="50" ClipToBounds="True">
                                                    <views:CoverImage
                                                        ImageUrl="{Binding CoverUrl}"
                                                        FallbackText="{Binding EffectiveTitle}"
                                                        FallbackGradient="{Binding CoverGradient}"
                                                        SubText="{Binding Platform}"
                                                        LetterFontSize="24"
                                                        ImageCornerRadius="0"
                                                        Width="80" Height="50"/>
                                                </Border>
                                                <StackPanel Grid.Column="1" Margin="12,0" VerticalAlignment="Center" Spacing="3">
                                                    <TextBlock Text="{Binding EffectiveTitle}" Classes="xb360-listgame-title"/>
                                                    <TextBlock Text="{Binding Platform}" Classes="xb360-listgame-platform"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="2" Text="{Binding PlaytimeLabel}"
                                                           Classes="xb360-listgame-playtime" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                        <Border Classes="xb360-metro-tile xb360-achievement-tile"
                                IsVisible="{Binding !HasLocalLibraryGames}">
                            <TextBlock Text="No local games found." Classes="xb360-achievement-desc" Margin="12,8"/>
                        </Border>
                    </StackPanel>

                    <!-- Right panel: focused game details -->
                    <StackPanel Grid.Column="1" Margin="16,0,0,0" Spacing="12"
                                IsVisible="{Binding Xb360HasFocusedGame}">
                        <Border Width="200" Height="200" Classes="xb360-featured-cover" Margin="0,0,0,8">
                            <views:CoverImage
                                ImageUrl="{Binding Xb360FocusedGame.CoverUrl}"
                                FallbackText="{Binding Xb360FocusedGame.EffectiveTitle}"
                                FallbackGradient="{Binding Xb360FocusedGame.CoverGradient}"
                                SubText="{Binding Xb360FocusedGame.Platform}"
                                LetterFontSize="64"
                                ImageCornerRadius="0"
                                Width="200" Height="200"/>
                        </Border>
                        <TextBlock Text="{Binding Xb360FocusedGame.EffectiveTitle}" Classes="xb360-featured-title" FontSize="22" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding Xb360FocusedGame.Platform}" Classes="xb360-featured-subtitle"/>
                        <TextBlock Text="{Binding Xb360FocusedGame.PlaytimeLabel}" Classes="xb360-achievement-desc"/>
                        <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,8,0,0">
                            <Button Classes="btn-primary" Width="120"
                                    Command="{Binding PlayXb360FocusedGameCommand}">
                                ▶  Play
                            </Button>
                            <Button Classes="btn-secondary" Width="120"
                                    Command="{Binding OpenXb360FocusedGameDetailCommand}">
                                ···  Details
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <!-- Media blade -->
                <StackPanel Margin="32,20,32,20" Spacing="12" IsVisible="{Binding IsXb360MediaBlade}">
                    <TextBlock Text="Media" Classes="xb360-strip-header"/>
                    <!-- Movies tile -->
                    <Border Classes="xb360-metro-tile xb360-metro-stat" Height="80">
                        <Grid Margin="16,0" ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="🎬  Movies" Classes="xb360-metro-label" FontSize="14"/>
                                <TextBlock Text="Browse your movie collection." Classes="xb360-achievement-desc"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Classes="btn-secondary"
                                    Padding="12,6"
                                    VerticalAlignment="Center"
                                    Command="{Binding OpenMoviesFolderCommand}">
                                Open
                            </Button>
                        </Grid>
                    </Border>
                    <!-- Music tile -->
                    <Border Classes="xb360-metro-tile xb360-metro-stat" Height="80">
                        <Grid Margin="16,0" ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="🎵  Music" Classes="xb360-metro-label" FontSize="14"/>
                                <TextBlock Text="Play your music library." Classes="xb360-achievement-desc"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Classes="btn-secondary"
                                    Padding="12,6"
                                    VerticalAlignment="Center"
                                    Command="{Binding OpenMusicFolderCommand}">
                                Open
                            </Button>
                        </Grid>
                    </Border>
                    <!-- TV Shows tile -->
                    <Border Classes="xb360-metro-tile xb360-metro-stat" Height="80">
                        <Grid Margin="16,0" ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="📺  TV Shows" Classes="xb360-metro-label" FontSize="14"/>
                                <TextBlock Text="Browse your TV show collection." Classes="xb360-achievement-desc"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Classes="btn-secondary"
                                    Padding="12,6"
                                    VerticalAlignment="Center"
                                    Command="{Binding OpenTvShowsFolderCommand}">
                                Open
                            </Button>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- Settings blade -->
                <StackPanel Margin="32,20,32,20" Spacing="12" IsVisible="{Binding IsXb360SettingsBlade}">
                    <TextBlock Text="Settings" Classes="xb360-strip-header"/>
                    <Border Classes="xb360-metro-tile xb360-metro-stat" Height="80">
                        <StackPanel Margin="16,0" VerticalAlignment="Center">
                            <TextBlock Text="App Settings" Classes="xb360-metro-label" FontSize="14"/>
                            <TextBlock Text="Open Settings to configure the launcher." Classes="xb360-achievement-desc"/>
                        </StackPanel>
                    </Border>
                    <Border Classes="xb360-metro-tile xb360-metro-stat" Height="80">
                        <StackPanel Margin="16,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding GamesCount, StringFormat='{}{0} Games'}" Classes="xb360-metro-value" FontSize="32"/>
                            <TextBlock Text="in your library" Classes="xb360-metro-label"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

            </Grid>
        </Grid>
    </Border>

    <!-- ══ PS5 Dashboard Layout (ported from Ref.PS5.OS/Dashboard.xaml) ══ -->
    <Border Classes="dashboard-ps5-layout">
        <Grid RowDefinitions="Auto,180,Auto,Auto,*,Auto">

            <!-- Header -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="28,18,28,12">
                <TextBlock Text="Games" Classes="ps5-header-title"/>
                <TextBlock Text="  Media" Classes="ps5-header-media"/>
            </StackPanel>

            <!-- Horizontal card row -->
            <ScrollViewer Grid.Row="1"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled"
                          Padding="20,0">
                <StackPanel Orientation="Horizontal">
                    <!-- Store card -->
                    <Button Classes="game-card-btn ps5-game-card-btn"
                            Command="{Binding OpenFeaturedDetailCommand}">
                        <StackPanel>
                            <Border Height="120" ClipToBounds="True" CornerRadius="10" Background="#1F1F1F">
                                <TextBlock Text="Store" Foreground="#ECECEC" FontSize="18"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Store" Classes="ps5-card-title" Margin="8,6,8,0"/>
                        </StackPanel>
                    </Button>

                    <!-- Games -->
                    <ItemsControl ItemsSource="{Binding Ps5RecentGames}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:LocalGameCardVm">
                                <Button Classes="game-card-btn ps5-game-card-btn"
                                        Classes.focused="{Binding IsFocused}"
                                        Command="{Binding $parent[UserControl].DataContext.OpenLocalGameDetailCommand}"
                                        CommandParameter="{Binding}">
                                    <StackPanel>
                                        <Border Height="120" ClipToBounds="True" CornerRadius="10">
                                            <views:CoverImage
                                                ImageUrl="{Binding CoverUrl}"
                                                FallbackText="{Binding EffectiveTitle}"
                                                FallbackGradient="{Binding CoverGradient}"
                                                SubText="{Binding Platform}"
                                                LetterFontSize="38"
                                                ImageCornerRadius="10"
                                                Height="120"/>
                                        </Border>
                                        <TextBlock Text="{Binding EffectiveTitle}"
                                                   Classes="ps5-card-title"
                                                   Margin="8,6,8,0"/>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- All games card -->
                    <Button Classes="game-card-btn ps5-game-card-btn"
                            Command="{Binding NavigateToAllGamesCommand}">
                        <StackPanel>
                            <Border Height="120" ClipToBounds="True" CornerRadius="10" Background="#1F1F1F">
                                <TextBlock Text="All Games" Foreground="#ECECEC" FontSize="16"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="All Games" Classes="ps5-card-title" Margin="8,6,8,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </ScrollViewer>

            <!-- Action buttons - for focused card (keyboard nav) -->
            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Margin="0,18,0,8"
                        IsVisible="{Binding HasFocusedCard}">
                <Button Classes="btn-primary ps5-action-primary"
                        Width="260" Height="46"
                        HorizontalContentAlignment="Center"
                        Command="{Binding PlayFocusedCardCommand}"
                        Margin="0,0,14,0">
                    Play Game
                </Button>
                <Button Classes="btn-secondary ps5-action-more"
                        Width="46" Height="46"
                        HorizontalContentAlignment="Center"
                        Command="{Binding OpenFocusedCardDetailCommand}"
                        ToolTip.Tip="More options">
                    ...
                </Button>
            </StackPanel>
            <!-- Action buttons - for featured game (when no focused card) -->
            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Margin="0,18,0,8"
                        IsVisible="{Binding !HasFocusedCard}">
                <Button Classes="btn-primary ps5-action-primary"
                        Width="260" Height="46"
                        HorizontalContentAlignment="Center"
                        Command="{Binding ContinuePlayingCommand}"
                        IsVisible="{Binding IsFeaturedLastPlayed}"
                        Margin="0,0,14,0">
                    Play Game
                </Button>
                <Button Classes="btn-primary ps5-action-primary"
                        Width="260" Height="46"
                        HorizontalContentAlignment="Center"
                        Command="{Binding OpenFeaturedDetailCommand}"
                        IsVisible="{Binding !IsFeaturedLastPlayed}"
                        Margin="0,0,14,0">
                    Play Game
                </Button>
                <Button Classes="btn-secondary ps5-action-more"
                        Width="46" Height="46"
                        HorizontalContentAlignment="Center"
                        ToolTip.Tip="More options">
                    ...
                </Button>
            </StackPanel>

            <!-- Store welcome block -->
            <StackPanel Grid.Row="3"
                        HorizontalAlignment="Center"
                        Margin="0,16,0,0"
                        IsVisible="{Binding !IsFeaturedLastPlayed}">
                <TextBlock Text="Welcome to the next generation"
                           Foreground="White"
                           FontSize="32"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="From the freshest releases to curated collections, there's something for everyone."
                           Foreground="#B3B3B3"
                           FontSize="18"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0"/>
                <TextBlock Text="Must see"
                           Foreground="#00AEEF"
                           FontSize="18"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Left"
                           Margin="40,28,0,0"/>
            </StackPanel>

            <!-- Achievements panel -->
            <Border Grid.Row="4"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="28,24,0,18"
                    Padding="16,12"
                    Classes="ps5-achievements-panel"
                    IsVisible="{Binding RecentAchievements.Count}">
                <StackPanel Width="380">
                    <DockPanel Margin="0,0,0,8" LastChildFill="True">
                        <TextBlock DockPanel.Dock="Left"
                                   Text="{Binding AchievementsCount, StringFormat='{}{0} Trophies'}"
                                   Foreground="#E6E6E6"
                                   FontSize="12"
                                   FontWeight="SemiBold"/>
                        <TextBlock DockPanel.Dock="Right"
                                   Text="Achievements"
                                   Foreground="#9E9E9E"
                                   FontSize="11"
                                   Margin="8,0,0,0"/>
                    </DockPanel>
                    <Rectangle Height="1" Fill="#2B2B2B" Margin="0,0,0,8"/>
                    <ItemsControl ItemsSource="{Binding RecentAchievements}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:Achievement">
                                <Grid Margin="0,4,0,4" ColumnDefinitions="28,*">
                                    <Border Grid.Column="0"
                                            Width="20" Height="20"
                                            CornerRadius="10"
                                            Background="#FFD400"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Center">
                                        <TextBlock Text="T"
                                                   Foreground="Black"
                                                   FontWeight="Bold"
                                                   FontSize="12"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" Orientation="Vertical" Margin="8,0,0,0">
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="#F2F2F2"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxWidth="280"/>
                                        <TextBlock Text="{Binding GameTitle}"
                                                   Foreground="#9E9E9E"
                                                   FontSize="11"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Bottom status tiles -->
            <StackPanel Grid.Row="5"
                        Orientation="Horizontal"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Bottom"
                        Margin="20,0,0,20">
                <Border Classes="ps5-status-tile" Width="120" Height="52" Padding="10">
                    <StackPanel>
                        <TextBlock Text="{Binding AchievementsCount}" Classes="ps5-status-value"/>
                        <TextBlock Text="Trophies" Classes="ps5-status-label"/>
                    </StackPanel>
                </Border>
                <Border Classes="ps5-status-tile" Width="160" Height="52" Padding="10" Margin="12,0,0,0">
                    <StackPanel>
                        <TextBlock Text="{Binding OnlineFriendsCount}" Classes="ps5-status-value"/>
                        <TextBlock Text="Friends Online" Classes="ps5-status-label"/>
                    </StackPanel>
                </Border>
                <Border Classes="ps5-status-tile" Width="140" Height="52" Padding="10" Margin="12,0,0,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding TotalPlaytimeLabel}" Classes="ps5-status-value"/>
                    </StackPanel>
                </Border>
            </StackPanel>

        </Grid>
    </Border>

    <!-- ══ Wii Dashboard Layout ═══════════════════════════════════════════ -->
    <Border Classes="dashboard-wii-layout">
        <Grid RowDefinitions="Auto,*,Auto" Margin="18,16,18,14">
            <TextBlock Grid.Row="0" Text="Wii Menu" Classes="wii-menu-title" HorizontalAlignment="Center"/>

            <UniformGrid Grid.Row="1" Rows="3" Columns="4" Margin="0,16,0,18">
                <Button Classes="wii-channel-tile" Command="{Binding NavigateToAllGamesCommand}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Disc Channel" Classes="wii-channel-title"/>
                        <TextBlock Text="Play installed games" Classes="wii-channel-subtitle"/>
                    </StackPanel>
                </Button>
                <Button Classes="wii-channel-tile">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Forecast Channel" Classes="wii-channel-title"/>
                        <TextBlock Text="Weather" Classes="wii-channel-subtitle"/>
                    </StackPanel>
                </Button>
                <Button Classes="wii-channel-tile" Command="{Binding OpenFeaturedDetailCommand}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Photo Channel" Classes="wii-channel-title"/>
                        <TextBlock Text="Featured game" Classes="wii-channel-subtitle"/>
                    </StackPanel>
                </Button>
                <Button Classes="wii-channel-tile" Command="{Binding NavigateToAllGamesCommand}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Game Channel" Classes="wii-channel-title"/>
                        <TextBlock Text="{Binding GamesCount, StringFormat='{}{0} games'}" Classes="wii-channel-subtitle"/>
                    </StackPanel>
                </Button>

                <Button Classes="wii-channel-tile" Command="{Binding ContinuePlayingCommand}" IsVisible="{Binding IsFeaturedLastPlayed}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Recent Game" Classes="wii-channel-title"/>
                        <TextBlock Text="{Binding FeaturedGame.Title}" Classes="wii-channel-subtitle"
                                   IsVisible="{Binding FeaturedGame, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                    </StackPanel>
                </Button>
                <Button Classes="wii-channel-tile" Command="{Binding NavigateToAllGamesCommand}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="News Channel" Classes="wii-channel-title"/>
                        <TextBlock Text="Library updates" Classes="wii-channel-subtitle"/>
                    </StackPanel>
                </Button>
                <Button Classes="wii-channel-tile" Command="{Binding OpenFeaturedDetailCommand}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Internet Channel" Classes="wii-channel-title"/>
                        <TextBlock Text="Store + web" Classes="wii-channel-subtitle"/>
                    </StackPanel>
                </Button>
                <Button Classes="wii-channel-tile" Command="{Binding NavigateToAllGamesCommand}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Mii Channel" Classes="wii-channel-title"/>
                        <TextBlock Text="{Binding Greeting}" Classes="wii-channel-subtitle"/>
                    </StackPanel>
                </Button>

                <Button Classes="wii-channel-tile" Command="{Binding NavigateToAllGamesCommand}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Photo 2" Classes="wii-channel-title"/>
                        <TextBlock Text="Achievements" Classes="wii-channel-subtitle"/>
                    </StackPanel>
                </Button>
                <Button Classes="wii-channel-tile" Command="{Binding NavigateToAllGamesCommand}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Virtual Console" Classes="wii-channel-title"/>
                        <TextBlock Text="{Binding PlatformsCount, StringFormat='{}{0} platforms'}" Classes="wii-channel-subtitle"/>
                    </StackPanel>
                </Button>
                <Button Classes="wii-channel-tile" Command="{Binding NavigateToAllGamesCommand}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Messages" Classes="wii-channel-title"/>
                        <TextBlock Text="{Binding AchievementsCount, StringFormat='{}{0} achievements'}" Classes="wii-channel-subtitle"/>
                    </StackPanel>
                </Button>
                <Button Classes="wii-channel-tile" Command="{Binding OpenFeaturedDetailCommand}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Shop Channel" Classes="wii-channel-title"/>
                        <TextBlock Text="Open store" Classes="wii-channel-subtitle"/>
                    </StackPanel>
                </Button>
            </UniformGrid>

            <Border Grid.Row="2" Classes="wii-bottom-bar">
                <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
                    <Border Grid.Column="0" Classes="wii-bottom-orb">
                        <TextBlock Text="Wii" Classes="wii-bottom-orb-text"/>
                    </Border>
                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding WiiClockTime}" Classes="wii-clock-time" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding WiiClockDate}" Classes="wii-clock-date" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <Border Grid.Column="2" Classes="wii-bottom-orb">
                        <TextBlock Text="✉" Classes="wii-bottom-orb-text"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Border>

    <!-- ══ Default Dashboard Layout ═══════════════════════════════════════ -->
    <StackPanel Margin="32,28,32,28" Spacing="0" Classes="dashboard-default-layout">

        <!-- Greeting -->
        <TextBlock Text="{Binding Greeting}"
                   Classes="page-title"
                   Margin="0,0,0,4"/>
        <TextBlock Text="Welcome back to Game.OS"
                   Classes="page-subtitle"
                   Margin="0,0,0,24"/>

        <!-- Stats row -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,28" Spacing="0">
            <Border Classes="stat-tile">
                <StackPanel Spacing="2">
                    <TextBlock Text="{Binding GamesCount}" Classes="stat-number"/>
                    <TextBlock Text="Games" Classes="stat-label"/>
                </StackPanel>
            </Border>
            <Border Classes="stat-tile">
                <StackPanel Spacing="2">
                    <TextBlock Text="{Binding AchievementsCount}"
                               Classes="stat-number stat-number-achievements"/>
                    <TextBlock Text="Achievements" Classes="stat-label"/>
                </StackPanel>
            </Border>
            <Border Classes="stat-tile">
                <StackPanel Spacing="2">
                    <TextBlock Text="{Binding PlatformsCount}"
                               Classes="stat-number stat-number-platforms"/>
                    <TextBlock Text="Platforms" Classes="stat-label"/>
                </StackPanel>
            </Border>
            <Border Classes="stat-tile">
                <StackPanel Spacing="2">
                    <TextBlock Text="{Binding TotalPlaytimeLabel}"
                               Classes="stat-number stat-number-playtime"/>
                    <TextBlock Text="Playtime" Classes="stat-label"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Hero Featured Game / Last Played -->
        <Border Classes="hero-banner featured-hero-banner" Margin="0,0,0,24" Cursor="Hand"
                IsVisible="{Binding FeaturedGame, Converter={x:Static ObjectConverters.IsNotNull}}">
            <Grid ColumnDefinitions="*,Auto" Margin="32,28,32,28">
                <StackPanel Grid.Column="0" Spacing="10" VerticalAlignment="Center">
                    <Border Classes="hero-feature-badge" CornerRadius="4"
                            Padding="8,3" HorizontalAlignment="Left">
                        <TextBlock Text="{Binding FeaturedBadgeText}" FontSize="11"
                                   FontWeight="Bold" Foreground="White"/>
                    </Border>
                    <TextBlock Text="{Binding FeaturedGame.Title}" Classes="hero-title"/>
                    <TextBlock Text="{Binding FeaturedGame.Description}" Classes="hero-desc"
                               IsVisible="{Binding FeaturedGame.Description,
                                   Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                    <!-- Show platform badge for last-played game (no description/price) -->
                    <Border Classes="hero-platform-badge" CornerRadius="4" Padding="8,3"
                            HorizontalAlignment="Left"
                            IsVisible="{Binding IsFeaturedLastPlayed}">
                        <TextBlock Text="{Binding FeaturedGame.Platform}"
                                   Classes="hero-platform-badge-text"
                                   FontSize="11"/>
                    </Border>
                    <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,8,0,0"
                                IsVisible="{Binding !IsFeaturedLastPlayed}">
                        <TextBlock Text="{Binding FeaturedGame.Price}" Classes="hero-price"/>
                        <TextBlock Text="{Binding FeaturedGame.RatingStars}"
                                   FontSize="16" Foreground="#f1c40f"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding FeaturedGame.Genre}"
                                   FontSize="13" Foreground="#8b949e"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <!-- "Continue Playing" for last-played, "View Details" for featured store game -->
                    <Button Classes="btn-primary" Width="160"
                            HorizontalContentAlignment="Center" Margin="0,8,0,0"
                            Command="{Binding ContinuePlayingCommand}"
                            IsVisible="{Binding IsFeaturedLastPlayed}">
                        ▶  Continue Playing
                    </Button>
                    <Button Classes="btn-primary" Width="140"
                            HorizontalContentAlignment="Center" Margin="0,8,0,0"
                            Command="{Binding OpenFeaturedDetailCommand}"
                            IsVisible="{Binding !IsFeaturedLastPlayed}">
                        View Details
                    </Button>
                </StackPanel>
                <!-- Cover image -->
                <Border Grid.Column="1" Width="160" Height="160"
                        CornerRadius="12" Margin="24,0,0,0" ClipToBounds="True">
                    <views:CoverImage
                        ImageUrl="{Binding FeaturedGame.CoverUrl}"
                        FallbackText="{Binding FeaturedGame.Title}"
                        FallbackGradient="{Binding FeaturedGame.CoverGradient}"
                        SubText="{Binding FeaturedGame.Genre}"
                        LetterFontSize="72"
                        ImageCornerRadius="12"
                        Width="160" Height="160"/>
                </Border>
            </Grid>
        </Border>

        <!-- Continue Playing (locally detected ROMs + installed games that have been played) -->
        <StackPanel Margin="0,0,0,24">
            <TextBlock Text="Continue Playing" Classes="section-header"/>
            <StackPanel IsVisible="{Binding HasRecentLocalGames}">
                <ItemsControl ItemsSource="{Binding RecentLocalGames}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:LocalGameCardVm">
                            <Button Classes="game-card-btn"
                                    Command="{Binding $parent[UserControl].DataContext.OpenLocalGameDetailCommand}"
                                    CommandParameter="{Binding}">
                                <StackPanel>
                                    <!-- Cover art -->
                                    <Border Height="110" CornerRadius="10,10,0,0" ClipToBounds="True">
                                        <views:CoverImage
                                            ImageUrl="{Binding CoverUrl}"
                                            FallbackText="{Binding EffectiveTitle}"
                                            FallbackGradient="{Binding CoverGradient}"
                                            SubText="{Binding Platform}"
                                            LetterFontSize="44"
                                            ImageCornerRadius="10,10,0,0"
                                            Height="110"/>
                                    </Border>
                                    <!-- Info -->
                                    <Border Padding="10,8,10,10">
                                        <StackPanel Spacing="3">
                                            <TextBlock Text="{Binding EffectiveTitle}"
                                                       Classes="game-card-title"/>
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <Border CornerRadius="3" Padding="5,2"
                                                        Classes="game-platform-pill" HorizontalAlignment="Left">
                                                    <TextBlock Text="{Binding Platform}"
                                                               FontSize="10" FontWeight="Bold"
                                                               Foreground="White"/>
                                                </Border>
                                                <Border CornerRadius="3" Padding="5,2"
                                                        Background="{Binding KindBackground}"
                                                        HorizontalAlignment="Left">
                                                    <TextBlock Text="{Binding KindLabel}"
                                                               FontSize="10" FontWeight="Bold"
                                                               Foreground="{Binding KindForeground}"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{Binding PlaytimeLabel}"
                                                       Classes="game-playtime-meta"
                                                       FontSize="10"
                                                       IsVisible="{Binding PlaytimeLabel,
                                                           Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
            <!-- Empty state: no games played yet -->
            <Border IsVisible="{Binding !HasRecentLocalGames}"
                    Classes="empty-state-card" CornerRadius="10"
                    Padding="24,20" Margin="0,4,0,0">
                <StackPanel HorizontalAlignment="Center" Spacing="8">
                    <TextBlock Text="🎮" FontSize="32" HorizontalAlignment="Center"/>
                    <TextBlock Text="No games played yet"
                               FontSize="14" FontWeight="SemiBold"
                               Classes="empty-state-title" HorizontalAlignment="Center"/>
                    <TextBlock Text="Launch a game to see it here"
                               FontSize="12" Classes="empty-state-subtitle"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Recent Achievements -->
        <TextBlock Text="Recent Achievements" Classes="section-header"
                   IsVisible="{Binding RecentAchievements.Count}"/>

        <ItemsControl ItemsSource="{Binding RecentAchievements}"
                      IsVisible="{Binding RecentAchievements.Count}">
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="models:Achievement">
                    <Border Classes="achievement-card">
                        <Grid ColumnDefinitions="40,*">
                            <Border Grid.Column="0" Width="36" Height="36"
                                    Classes="achievement-icon-card" CornerRadius="8">
                                <TextBlock Text="🏆" FontSize="18"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="12,0,0,0"
                                        VerticalAlignment="Center" Spacing="2">
                                <TextBlock Text="{Binding Name}"
                                           Classes="achievement-title"/>
                                <TextBlock Text="{Binding Description}"
                                           Classes="achievement-desc"/>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{Binding GameTitle}"
                                               Classes="achievement-meta"/>
                                    <TextBlock Text="|" Classes="achievement-divider"/>
                                    <TextBlock Text="{Binding Platform}"
                                               Classes="achievement-meta"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

    </StackPanel>
    </Grid>
</UserControl>
