<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GameLauncher.ViewModels"
             xmlns:models="using:GameLauncher.Models"
             xmlns:views="using:GameLauncher.Views"
             x:Class="GameLauncher.Views.QuickMenuOverlay"
             x:DataType="vm:QuickMenuViewModel"
             Classes.qm-theme-ps5="{Binding IsPs5Theme}"
             Classes.qm-theme-gameos="{Binding IsGameOsTheme}"
             Classes.qm-theme-xb360="{Binding IsXb360Theme}"
             Classes.qm-theme-wii="{Binding IsWiiTheme}"
             Classes.qm-theme-switch="{Binding IsSwitchTheme}"
             Classes.qm-theme-steambpm="{Binding IsSteamBpmTheme}">

    <UserControl.Styles>
        <Style Selector="Border.qm-overlay-backdrop">
            <Setter Property="Background" Value="#AA000000"/>
        </Style>
        <Style Selector="Border.qm-center-panel">
            <Setter Property="Background" Value="#CC222222"/>
            <Setter Property="CornerRadius" Value="18"/>
        </Style>
        <Style Selector="Border.qm-bottom-shell">
            <Setter Property="Background" Value="#CC222222"/>
            <Setter Property="CornerRadius" Value="24"/>
        </Style>

        <Style Selector="UserControl.qm-theme-gameos Border.qm-center-panel">
            <Setter Property="Background" Value="#E0161b22"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderBrush" Value="#30363d"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="UserControl.qm-theme-gameos Border.qm-bottom-shell">
            <Setter Property="Background" Value="#E0161b22"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderBrush" Value="#30363d"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style Selector="UserControl.qm-theme-xb360 Border.qm-overlay-backdrop">
            <Setter Property="Background" Value="#AA061109"/>
        </Style>
        <Style Selector="UserControl.qm-theme-xb360 Border.qm-center-panel">
            <Setter Property="Background" Value="#EE0d2316"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="BorderBrush" Value="#5fce7d"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="UserControl.qm-theme-xb360 Border.qm-bottom-shell">
            <Setter Property="Background" Value="#EE0d2316"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="BorderBrush" Value="#5fce7d"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="UserControl.qm-theme-xb360 Button.qm-hub-btn">
            <Setter Property="BorderBrush" Value="#5fce7d"/>
        </Style>
        <Style Selector="UserControl.qm-theme-xb360 Border.qm-center-panel">
            <Setter Property="MinWidth" Value="620"/>
        </Style>
        <Style Selector="UserControl.qm-theme-wii Border.qm-overlay-backdrop">
            <Setter Property="Background" Value="#88dff6ff"/>
        </Style>
        <Style Selector="UserControl.qm-theme-wii Border.qm-center-panel">
            <Setter Property="Background" Value="#E6f6fcff"/>
            <Setter Property="CornerRadius" Value="26"/>
            <Setter Property="BorderBrush" Value="#8bd3ee"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>
        <Style Selector="UserControl.qm-theme-wii Border.qm-bottom-shell">
            <Setter Property="Background" Value="#E6f6fcff"/>
            <Setter Property="CornerRadius" Value="30"/>
            <Setter Property="BorderBrush" Value="#8bd3ee"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>
        <Style Selector="UserControl.qm-theme-wii TextBlock">
            <Setter Property="Foreground" Value="#165b80"/>
        </Style>
        <Style Selector="UserControl.qm-theme-wii Button.qm-hub-btn /template/ ContentPresenter">
            <Setter Property="Background" Value="#ffffff"/>
        </Style>
        <Style Selector="Border.qm-wii-shell">
            <Setter Property="Background" Value="#E6f6fcff"/>
            <Setter Property="BorderBrush" Value="#8bd3ee"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="30"/>
            <Setter Property="Padding" Value="18,14"/>
        </Style>
        <Style Selector="Button.qm-wii-bubble">
            <Setter Property="Background" Value="#ffffff"/>
            <Setter Property="Foreground" Value="#1d6b8f"/>
            <Setter Property="BorderBrush" Value="#8bd3ee"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="28"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="UserControl.qm-theme-switch Border.qm-overlay-backdrop">
            <Setter Property="Background" Value="#AA0f1117"/>
        </Style>
        <Style Selector="UserControl.qm-theme-switch Border.qm-center-panel">
            <Setter Property="Background" Value="#EE1a1d24"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="BorderBrush" Value="#e60012"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>
        <Style Selector="UserControl.qm-theme-switch Border.qm-bottom-shell">
            <Setter Property="Background" Value="#EE1a1d24"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="BorderBrush" Value="#e60012"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>
        <Style Selector="UserControl.qm-theme-switch Button.qm-hub-btn.active /template/ ContentPresenter">
            <Setter Property="Background" Value="#e60012"/>
        </Style>
        <Style Selector="UserControl.qm-theme-steambpm Border.qm-overlay-backdrop">
            <Setter Property="Background" Value="#B0000000"/>
        </Style>
        <Style Selector="UserControl.qm-theme-steambpm Border.qm-center-panel">
            <Setter Property="Background" Value="#EE101822"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderBrush" Value="#4c8abf"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="UserControl.qm-theme-steambpm Border.qm-bottom-shell">
            <Setter Property="Background" Value="#EE101822"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderBrush" Value="#4c8abf"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- GameOS compact panel -->
        <Style Selector="Border.qm-gameos-panel">
            <Setter Property="Background" Value="#E8161b22"/>
            <Setter Property="BorderBrush" Value="#30363d"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16"/>
        </Style>

        <!-- XB360 guide -->
        <Style Selector="Border.qm-xb360-guide-root">
            <Setter Property="Background" Value="#3f3f3f"/>
            <Setter Property="BorderBrush" Value="#0f0f0f"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="Border.qm-xb360-guide-header">
            <Setter Property="Background" Value="#010101"/>
            <Setter Property="Padding" Value="14,12"/>
        </Style>
        <Style Selector="Border.qm-xb360-side-rail">
            <Setter Property="Background" Value="#474747"/>
        </Style>
        <Style Selector="Border.qm-xb360-center-sheet">
            <Setter Property="Background" Value="#f2f2f2"/>
        </Style>
        <Style Selector="Button.xb360-guide-item">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="MinHeight" Value="62"/>
        </Style>
        <Style Selector="Button.xb360-guide-item /template/ ContentPresenter">
            <Setter Property="Background" Value="#f2f2f2"/>
        </Style>
        <Style Selector="Button.xb360-guide-item:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#e8e8e8"/>
        </Style>
        <Style Selector="Button.xb360-guide-item.active /template/ ContentPresenter">
            <Setter Property="Background" Value="#118714"/>
        </Style>
        <Style Selector="Button.xb360-guide-item.active TextBlock">
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="TextBlock.xb360-guide-row-text">
            <Setter Property="Foreground" Value="#1a1a1a"/>
            <Setter Property="FontSize" Value="19"/>
        </Style>
        <Style Selector="TextBlock.xb360-guide-row-value">
            <Setter Property="Foreground" Value="#1a1a1a"/>
            <Setter Property="FontSize" Value="19"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
        </Style>
        <Style Selector="TextBlock.xb360-guide-side-text">
            <Setter Property="Foreground" Value="#f4f4f4"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.qm-xb360-side-btn">
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="MinHeight" Value="148"/>
        </Style>
        <Style Selector="Button.qm-xb360-side-btn /template/ ContentPresenter">
            <Setter Property="Background" Value="#474747"/>
        </Style>
        <Style Selector="Button.qm-xb360-side-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#555"/>
        </Style>
        <Style Selector="Button.qm-xb360-side-btn.active /template/ ContentPresenter">
            <Setter Property="Background" Value="#118714"/>
        </Style>
        <Style Selector="Button.qm-xb360-side-btn.active TextBlock">
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </UserControl.Styles>

    <Grid>
        <Border Classes="qm-overlay-backdrop"/>

        <!-- GameOS quick panel (replaces PS5 hub bar for GameOS theme) -->
        <Border Classes="qm-gameos-panel"
                IsVisible="{Binding IsGameOsTheme}"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,24,24,0"
                Width="290">
            <StackPanel Spacing="10">
                <!-- Header -->
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Spacing="2">
                        <TextBlock Text="Quick Menu" FontWeight="Bold" FontSize="15" Foreground="White"/>
                        <TextBlock Text="{Binding CurrentSessionLabel}" FontSize="11" Foreground="#8b949e"/>
                    </StackPanel>
                    <Button Grid.Column="1" Classes="btn-secondary" Command="{Binding DismissCommand}"
                            Width="32" Height="32" Padding="0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center">✕</Button>
                </Grid>
                <Rectangle Height="1" Fill="#30363d"/>
                <!-- Navigation items -->
                <ItemsControl ItemsSource="{Binding SwitcherItems}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:QuickMenuSwitcherItemVm">
                            <Button Classes="btn-secondary"
                                    Classes.active="{Binding IsActive}"
                                    Command="{Binding $parent[UserControl].DataContext.OpenPageFromSwitcherCommand}"
                                    CommandParameter="{Binding}"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Left"
                                    Margin="0,1">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" Spacing="1">
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold"
                                                   Foreground="#e6edf3" FontSize="13"/>
                                        <TextBlock Text="{Binding Subtitle}" Foreground="#8b949e" FontSize="10"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="✓"
                                               IsVisible="{Binding IsActive}"
                                               Foreground="#58a6ff" VerticalAlignment="Center"
                                               FontWeight="Bold" Margin="8,0,0,0"/>
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Rectangle Height="1" Fill="#30363d"/>
                <!-- Exit game shortcut when playing -->
                <Button Classes="btn-primary"
                        IsVisible="{Binding IsPlayingGame}"
                        Command="{Binding ExitGameCommand}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="⏹" FontSize="13"/>
                        <TextBlock Text="Exit Game" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- Wii quick menu strip -->
        <Border Classes="qm-wii-shell"
                IsVisible="{Binding IsWiiTheme}"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="24,0,24,24"
                Width="980">
            <Grid RowDefinitions="Auto,Auto" RowSpacing="12">
                <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto">
                    <TextBlock Grid.Column="0" Text="Wii Quick Menu" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding CurrentSessionLabel}" FontSize="13" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding CurrentGameTitle}" FontSize="11" HorizontalAlignment="Center"
                                   IsVisible="{Binding IsPlayingGame}"/>
                    </StackPanel>
                    <Button Grid.Column="2" Classes="qm-wii-bubble" Command="{Binding DismissCommand}" Width="86">Close</Button>
                </Grid>
                <Grid Grid.Row="1" ColumnDefinitions="*,*,*,*,*,*" ColumnSpacing="10">
                    <Button Grid.Column="0" Classes="qm-wii-bubble" Command="{Binding SelectHomeCommand}">Home</Button>
                    <Button Grid.Column="1" Classes="qm-wii-bubble" Command="{Binding SelectRecentGamesCommand}">Recent</Button>
                    <Button Grid.Column="2" Classes="qm-wii-bubble" Command="{Binding SelectFriendsCommand}">Friends</Button>
                    <Button Grid.Column="3" Classes="qm-wii-bubble" Command="{Binding SelectInboxCommand}">Inbox</Button>
                    <Button Grid.Column="4" Classes="qm-wii-bubble" Command="{Binding OpenBrowserCommand}">Browser</Button>
                    <Button Grid.Column="5" Classes="qm-wii-bubble" Command="{Binding ExitGameCommand}" IsVisible="{Binding IsPlayingGame}">Exit Game</Button>
                </Grid>
            </Grid>
        </Border>

        <!-- XB360 guide layout -->
        <Border Classes="qm-xb360-guide-root"
                IsVisible="{Binding UsesXb360GuideLayout}"
                Width="1120"
                Height="740"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <Grid RowDefinitions="Auto,*,Auto">
                <Border Grid.Row="0" Classes="qm-xb360-guide-header">
                    <Grid ColumnDefinitions="*,Auto,Auto" VerticalAlignment="Center">
                        <TextBlock Grid.Column="0"
                                   Text="Xbox Guide"
                                   Foreground="White"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <Border Grid.Column="1"
                                Width="50"
                                Height="50"
                                CornerRadius="25"
                                Background="#7d7d7d"
                                Margin="0,0,10,0">
                            <TextBlock Text="{Binding Xb360UserInitial}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="White"
                                       FontWeight="Bold"
                                       FontSize="18"/>
                        </Border>
                        <TextBlock Grid.Column="2"
                                   Text="{Binding Xb360CurrentTimeLabel}"
                                   Foreground="White"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <Grid Grid.Row="1" ColumnDefinitions="88,66,*,88">
                    <Border Grid.Column="0" Classes="qm-xb360-side-rail">
                        <TextBlock Text="Games &amp; Apps"
                                   Classes="xb360-guide-side-text"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center">
                            <TextBlock.RenderTransform>
                                <RotateTransform Angle="-90"/>
                            </TextBlock.RenderTransform>
                        </TextBlock>
                    </Border>

                    <Border Grid.Column="1" Classes="qm-xb360-side-rail" BorderBrush="#575757" BorderThickness="1,0,1,0">
                        <TextBlock Text="{Binding CurrentUsername}"
                                   Classes="xb360-guide-side-text"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center">
                            <TextBlock.RenderTransform>
                                <RotateTransform Angle="-90"/>
                            </TextBlock.RenderTransform>
                        </TextBlock>
                    </Border>

                    <Border Grid.Column="2" Classes="qm-xb360-center-sheet">
                        <StackPanel Spacing="0">
                            <Button Classes="xb360-guide-item"
                                    Classes.active="{Binding IsHomePage}"
                                    Command="{Binding GoToGameOsHomeCommand}">
                                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                                    <TextBlock Grid.Column="0" Text="Game OS Home" Classes="xb360-guide-row-text" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="⌂" Classes="xb360-guide-row-value" VerticalAlignment="Center"/>
                                </Grid>
                            </Button>
                            <Rectangle Height="1" Fill="#d7d7d7"/>

                            <Button Classes="xb360-guide-item"
                                    Classes.active="{Binding IsFriendsPage}"
                                    Command="{Binding OpenFriendsPageCommand}">
                                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                                    <TextBlock Grid.Column="0" Text="Friends" Classes="xb360-guide-row-text" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Xb360FriendsCount}" Classes="xb360-guide-row-value" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="👥" Classes="xb360-guide-row-value" VerticalAlignment="Center"/>
                                </Grid>
                            </Button>
                            <Rectangle Height="1" Fill="#d7d7d7"/>

                            <Button Classes="xb360-guide-item"
                                    Classes.active="{Binding IsInboxPage}"
                                    Command="{Binding OpenInboxPageCommand}">
                                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                                    <TextBlock Grid.Column="0" Text="Messages" Classes="xb360-guide-row-text" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Xb360MessagesCount}" Classes="xb360-guide-row-value" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="✉" Classes="xb360-guide-row-value" VerticalAlignment="Center"/>
                                </Grid>
                            </Button>
                            <Rectangle Height="1" Fill="#d7d7d7"/>

                            <Button Classes="xb360-guide-item"
                                    Classes.active="{Binding IsNotificationsPage}"
                                    Command="{Binding OpenNotificationsPageCommand}">
                                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                                    <TextBlock Grid.Column="0" Text="Activity" Classes="xb360-guide-row-text" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="⚡" Classes="xb360-guide-row-value" VerticalAlignment="Center"/>
                                </Grid>
                            </Button>
                            <Rectangle Height="1" Fill="#d7d7d7"/>

                            <Button Classes="xb360-guide-item"
                                    Classes.active="{Binding IsRecentGamesPage}"
                                    Command="{Binding SelectRecentGamesCommand}">
                                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                                    <TextBlock Grid.Column="0" Text="Recent Games" Classes="xb360-guide-row-text" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Xb360RecentGamesCount}" Classes="xb360-guide-row-value" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="🎮" Classes="xb360-guide-row-value" VerticalAlignment="Center"/>
                                </Grid>
                            </Button>
                            <Rectangle Height="1" Fill="#d7d7d7"/>

                            <Button Classes="xb360-guide-item"
                                    Classes.active="{Binding IsDownloadsPage}"
                                    Command="{Binding OpenDownloadsPageCommand}">
                                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                                    <TextBlock Grid.Column="0" Text="Downloads" Classes="xb360-guide-row-text" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Xb360DownloadsCount}" Classes="xb360-guide-row-value" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="⬇" Classes="xb360-guide-row-value" VerticalAlignment="Center"/>
                                </Grid>
                            </Button>
                            <Rectangle Height="1" Fill="#d7d7d7"/>

                            <Button Classes="xb360-guide-item"
                                    Classes.active="{Binding IsPowerPage}"
                                    Command="{Binding PowerSignOutCommand}">
                                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                                    <TextBlock Grid.Column="0" Text="Sign Out" Classes="xb360-guide-row-text" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="☰" Classes="xb360-guide-row-value" VerticalAlignment="Center"/>
                                </Grid>
                            </Button>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="3" Classes="qm-xb360-side-rail">
                        <Grid RowDefinitions="*,*">
                            <Button Grid.Row="0" Classes="qm-xb360-side-btn" Classes.active="{Binding IsMediaPage}" Command="{Binding SelectMediaCommand}">
                                <TextBlock Text="Media" Classes="xb360-guide-side-text" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock.RenderTransform>
                                        <RotateTransform Angle="-90"/>
                                    </TextBlock.RenderTransform>
                                </TextBlock>
                            </Button>
                            <Button Grid.Row="1" Classes="qm-xb360-side-btn" Classes.active="{Binding IsSettingsPage}" Command="{Binding OpenSettingsPageCommand}">
                                <TextBlock Text="Settings" Classes="xb360-guide-side-text" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock.RenderTransform>
                                        <RotateTransform Angle="-90"/>
                                    </TextBlock.RenderTransform>
                                </TextBlock>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>

                <Border Grid.Row="2" Background="#010101" Padding="18,12">
                    <StackPanel Orientation="Horizontal" Spacing="26" HorizontalAlignment="Center">
                        <TextBlock Text="🟢 A  Select" Foreground="White" FontSize="16"/>
                        <TextBlock Text="🔴 B  Back" Foreground="White" FontSize="16"/>
                        <Button Classes="btn-secondary"
                                Command="{Binding PowerSignOutCommand}"
                                Padding="8,2"
                                FontSize="16">🔵 X  Sign Out</Button>
                        <Button Classes="btn-secondary"
                                Command="{Binding GoToGameOsHomeCommand}"
                                Padding="8,2"
                                FontSize="16">🟡 Y  Game OS Home</Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- PS5/Switch/SteamBPM hub layout -->
        <Grid RowDefinitions="*,Auto" IsVisible="{Binding UsesHubLayout}">
            <!-- Center overlays -->
            <Grid Grid.Row="0" Margin="24,24,24,12">
                <Border Classes="qm-center-panel"
                        IsVisible="{Binding IsHomePage}"
                        Width="540"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Padding="18">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Current Session" FontSize="20" FontWeight="SemiBold" Foreground="White"/>
                        <TextBlock Text="{Binding CurrentGameTitle}" Foreground="#ECECEC" FontSize="15" IsVisible="{Binding IsPlayingGame}" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding CurrentSessionLabel}" Foreground="#B3B3B3" FontSize="12"/>

                        <Button Classes="btn-primary" Command="{Binding ExitGameCommand}" IsVisible="{Binding IsPlayingGame}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="⏹" FontSize="14"/>
                                <TextBlock Text="Exit Game" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>

                        <Button Classes="btn-secondary"
                                IsVisible="{Binding HasAchievementsProgress}"
                                Command="{Binding OpenAchievementsCommand}">
                            <StackPanel Spacing="4">
                                <TextBlock Text="🏆 Achievements" Foreground="#ECECEC" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding AchievementsLabel}" Foreground="#FFD400" FontSize="12"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <Border Classes="qm-center-panel"
                        IsVisible="{Binding IsSwitcherPage}"
                        Width="540"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Padding="18">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Switcher" FontSize="20" FontWeight="SemiBold" Foreground="White"/>
                        <ItemsControl ItemsSource="{Binding SwitcherItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:QuickMenuSwitcherItemVm">
                                    <Button Classes="btn-secondary"
                                            Command="{Binding $parent[UserControl].DataContext.OpenPageFromSwitcherCommand}"
                                            CommandParameter="{Binding}">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <StackPanel Grid.Column="0" Spacing="2">
                                                <TextBlock Text="{Binding Title}" Foreground="#ECECEC" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding Subtitle}" Foreground="#9E9E9E" FontSize="11"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1"
                                                       Text="✓"
                                                       IsVisible="{Binding IsActive}"
                                                       VerticalAlignment="Center"
                                                       Foreground="#00AEEF"
                                                       FontWeight="Bold"/>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Classes="qm-center-panel"
                        IsVisible="{Binding IsRecentGamesPage}"
                        Width="640"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Padding="18">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Recent Games" FontSize="20" FontWeight="SemiBold" Foreground="White"/>
                        <ItemsControl ItemsSource="{Binding RecentGames}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:LocalGameCardVm">
                                    <Button Classes="btn-secondary"
                                            Command="{Binding $parent[UserControl].DataContext.LaunchRecentGameCommand}"
                                            CommandParameter="{Binding}">
                                        <Grid ColumnDefinitions="72,*,Auto" ColumnSpacing="10">
                                            <Border Grid.Column="0" Width="72" Height="46" CornerRadius="6" ClipToBounds="True">
                                                <views:CoverImage ImageUrl="{Binding CoverUrl}"
                                                                  FallbackText="{Binding EffectiveTitle}"
                                                                  FallbackGradient="{Binding CoverGradient}"
                                                                  SubText="{Binding Platform}"
                                                                  LetterFontSize="20"
                                                                  ImageCornerRadius="6"
                                                                  Height="46"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" Spacing="2">
                                                <TextBlock Text="{Binding EffectiveTitle}" Foreground="#ECECEC" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Platform}" Foreground="#9E9E9E" FontSize="11"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" Text="▶" Foreground="#00AEEF" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="No recent games found." Foreground="#9E9E9E" FontSize="12" IsVisible="{Binding !HasRecentGames}"/>
                    </StackPanel>
                </Border>

                <Border Classes="qm-center-panel"
                        IsVisible="{Binding IsNotificationsPage}"
                        Width="480"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Padding="18">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Notifications" FontSize="20" FontWeight="SemiBold" Foreground="White"/>
                        <TextBlock Text="{Binding UnreadMessageCount, StringFormat='Unread messages: {0}'}" Foreground="#ECECEC"/>
                        <TextBlock Text="{Binding LastMessagePreview}" Foreground="#9E9E9E" TextWrapping="Wrap"/>
                        <Button Classes="btn-secondary" Command="{Binding OpenNotificationsPageCommand}">Open Inbox</Button>
                    </StackPanel>
                </Border>

                <Border Classes="qm-center-panel"
                        IsVisible="{Binding IsDownloadsPage}"
                        Width="480"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Padding="18">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Downloads" FontSize="20" FontWeight="SemiBold" Foreground="White"/>
                        <TextBlock Text="{Binding PendingDownloadCount, StringFormat='Ready installs / updates: {0}'}" Foreground="#ECECEC"/>
                        <Button Classes="btn-secondary" Command="{Binding OpenDownloadsPageCommand}">Open Library</Button>
                    </StackPanel>
                </Border>

                <Border Classes="qm-center-panel"
                        IsVisible="{Binding IsFriendsPage}"
                        Width="560"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Padding="18">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Friends" FontSize="20" FontWeight="SemiBold" Foreground="White"/>
                        <ItemsControl ItemsSource="{Binding Friends}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:FriendPresenceVm">
                                    <Border Background="#33222222" CornerRadius="8" Padding="10">
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Username}" Foreground="#ECECEC" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding StatusLabel}" Foreground="#9E9E9E" FontSize="11"/>
                                            </StackPanel>
                                            <Button Grid.Column="1" Classes="btn-secondary" Padding="8,4">
                                                <TextBlock Text="Profile"/>
                                                <Button.Flyout>
                                                    <MenuFlyout Placement="BottomEdgeAlignedRight">
                                                        <MenuItem Header="Invite"
                                                                  Command="{Binding $parent[UserControl].DataContext.InviteFriendCommand}"
                                                                  CommandParameter="{Binding Username}"/>
                                                        <MenuItem Header="Message"
                                                                  Command="{Binding $parent[UserControl].DataContext.MessageFriendCommand}"
                                                                  CommandParameter="{Binding Username}"/>
                                                        <MenuItem Header="View"
                                                                  Command="{Binding $parent[UserControl].DataContext.ViewFriendCommand}"
                                                                  CommandParameter="{Binding Username}"/>
                                                    </MenuFlyout>
                                                </Button.Flyout>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Button Classes="btn-secondary" Command="{Binding OpenFriendsPageCommand}">Open Friends Page</Button>
                    </StackPanel>
                </Border>

                <Border Classes="qm-center-panel"
                        IsVisible="{Binding IsInboxPage}"
                        Width="520"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Padding="18">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Inbox" FontSize="20" FontWeight="SemiBold" Foreground="White"/>
                        <TextBlock Text="{Binding UnreadMessageCount, StringFormat='Unread messages: {0}'}" Foreground="#ECECEC"/>
                        <TextBlock Text="{Binding LastMessagePreview}" Foreground="#9E9E9E" TextWrapping="Wrap"/>
                        <Button Classes="btn-secondary" Command="{Binding OpenInboxPageCommand}">Open Inbox Page</Button>
                    </StackPanel>
                </Border>

                <Border Classes="qm-center-panel"
                        IsVisible="{Binding IsMediaPage}"
                        Width="520"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Padding="18">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Media Controls" FontSize="20" FontWeight="SemiBold" Foreground="White"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
                            <Button Classes="btn-secondary" Command="{Binding MediaPreviousCommand}" Padding="16,10">⏮</Button>
                            <Button Classes="btn-secondary" Command="{Binding MediaPlayPauseCommand}" Padding="16,10">⏯</Button>
                            <Button Classes="btn-secondary" Command="{Binding MediaNextCommand}" Padding="16,10">⏭</Button>
                        </StackPanel>
                        <TextBlock Text="{Binding MediaStatusLabel}" Foreground="#9E9E9E" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Classes="qm-center-panel"
                        IsVisible="{Binding IsBrowserPage}"
                        Width="520"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Padding="18">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Browser" FontSize="20" FontWeight="SemiBold" Foreground="White"/>
                        <TextBlock Text="Open your default web browser." Foreground="#9E9E9E"/>
                        <Button Classes="btn-secondary" Command="{Binding OpenBrowserCommand}">Open Browser</Button>
                    </StackPanel>
                </Border>

                <Border Classes="qm-center-panel"
                        IsVisible="{Binding IsPowerPage}"
                        Width="420"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Padding="18">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Power" FontSize="20" FontWeight="SemiBold" Foreground="White"/>
                        <Button Classes="btn-secondary" Command="{Binding PowerSignOutCommand}">Sign Out</Button>
                        <Button Classes="btn-secondary" Command="{Binding PowerSwitchAccountCommand}">Switch Account</Button>
                        <Button Classes="btn-danger" Command="{Binding PowerExitApplicationCommand}">Exit App</Button>
                    </StackPanel>
                </Border>

                <Border Classes="qm-center-panel"
                        IsVisible="{Binding IsAchievementsPage}"
                        Width="560"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Padding="18">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Achievements" FontSize="20" FontWeight="SemiBold" Foreground="White"/>
                        <TextBlock Text="{Binding AchievementsLabel}" Foreground="#FFD400" IsVisible="{Binding HasAchievementsProgress}"/>
                        <ItemsControl ItemsSource="{Binding Achievements}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:QuickMenuAchievementVm">
                                    <Border Background="#33222222" CornerRadius="8" Padding="10">
                                        <StackPanel Spacing="2">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="{Binding StatusIcon}"/>
                                                <TextBlock Text="{Binding Name}" Foreground="#ECECEC" FontWeight="SemiBold"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Description}" Foreground="#9E9E9E" FontSize="11" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Bottom quick menu bar -->
            <Border Grid.Row="1"
                    Classes="qm-bottom-shell"
                    Height="260"
                    Margin="0,0,0,24"
                    Padding="18,12">
                <Grid RowDefinitions="Auto,*">
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{Binding MenuTitle}" FontSize="30" FontWeight="SemiBold" Foreground="#FFF" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding MenuSubtitle}" FontSize="16" Foreground="#AAFFFFFF" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <Button Grid.Column="1" Classes="btn-secondary" Command="{Binding DismissCommand}" Width="42" Height="42">✕</Button>
                    </Grid>

                    <StackPanel Grid.Row="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Bottom"
                                Margin="0,0,0,36"
                                Spacing="10">
                        <Button Classes="btn-secondary qm-hub-btn" Classes.active="{Binding IsHomePage}" Command="{Binding SelectHomeCommand}" Width="72" Height="56">🏠</Button>
                        <Button Classes="btn-secondary qm-hub-btn" Classes.active="{Binding IsSwitcherPage}" Command="{Binding SelectSwitcherCommand}" Width="72" Height="56">🗂</Button>
                        <Button Classes="btn-secondary qm-hub-btn" Classes.active="{Binding IsRecentGamesPage}" Command="{Binding SelectRecentGamesCommand}" Width="72" Height="56">🎮</Button>
                        <Button Classes="btn-secondary qm-hub-btn" Classes.active="{Binding IsNotificationsPage}" Command="{Binding SelectNotificationsCommand}" Width="72" Height="56">🔔</Button>
                        <Button Classes="btn-secondary qm-hub-btn" Classes.active="{Binding IsDownloadsPage}" Command="{Binding SelectDownloadsCommand}" Width="72" Height="56">⬇</Button>
                        <Button Classes="btn-secondary qm-hub-btn" Classes.active="{Binding IsFriendsPage}" Command="{Binding SelectFriendsCommand}" Width="72" Height="56">👥</Button>
                        <Button Classes="btn-secondary qm-hub-btn" Classes.active="{Binding IsInboxPage}" Command="{Binding SelectInboxCommand}" Width="72" Height="56">📬</Button>
                        <Button Classes="btn-secondary qm-hub-btn" Classes.active="{Binding IsAchievementsPage}" Command="{Binding OpenAchievementsCommand}" Width="72" Height="56">🏆</Button>
                        <Button Classes="btn-secondary qm-hub-btn" Classes.active="{Binding IsMediaPage}" Command="{Binding SelectMediaCommand}" Width="72" Height="56">🎵</Button>
                        <Button Classes="btn-secondary qm-hub-btn" Classes.active="{Binding IsBrowserPage}" Command="{Binding SelectBrowserCommand}" Width="72" Height="56">🌐</Button>
                        <Button Classes="btn-secondary qm-hub-btn" Classes.active="{Binding IsPowerPage}" Command="{Binding SelectPowerCommand}" Width="72" Height="56">⏻</Button>
                        <Button Classes="btn-danger qm-hub-btn" Command="{Binding ExitGameCommand}" IsVisible="{Binding IsPlayingGame}" Width="90" Height="56">⏹ Exit</Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Chat mini-window -->
        <Border IsVisible="{Binding ShowChatWindow}"
                Background="#CC0d1117"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
            <Border Width="320"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="#161b22"
                    BorderBrush="#30363d"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="12">
                <Grid RowDefinitions="Auto,*,Auto" RowSpacing="10">
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                        <TextBlock Text="{Binding ChatFriendUsername}"
                                   FontSize="13" FontWeight="Bold"
                                   Foreground="White"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="1"
                                Classes="btn-secondary"
                                Padding="8,4"
                                Command="{Binding CloseChatWindowCommand}">
                            <TextBlock Text="✕" FontSize="12" FontWeight="Bold"/>
                        </Button>
                    </Grid>
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  MaxHeight="220">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Loading messages..."
                                       Foreground="#8b949e"
                                       IsVisible="{Binding IsChatBusy}"/>
                            <TextBlock Text="{Binding ChatError}"
                                       Foreground="#f85149"
                                       IsVisible="{Binding ChatError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                            <ItemsControl ItemsSource="{Binding ChatMessages}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:Message">
                                        <Border Background="#21262d" CornerRadius="8" Padding="8,6">
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="{Binding From}"
                                                           FontSize="10" FontWeight="Bold"
                                                           Foreground="#0ea5e9"/>
                                                <TextBlock Text="{Binding Text}"
                                                           FontSize="12"
                                                           Foreground="#e6edf3"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                    <Grid Grid.Row="2" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <TextBox Grid.Column="0"
                                 Text="{Binding NewChatMessage}"
                                 Watermark="Type a message..."
                                 Background="#21262d"
                                 BorderBrush="#30363d"
                                 Foreground="White"
                                 CornerRadius="6"
                                 Padding="8,6"/>
                        <Button Grid.Column="1"
                                Classes="btn-primary"
                                Padding="12,6"
                                IsEnabled="{Binding !IsChatBusy}"
                                Command="{Binding SendChatMessageCommand}">
                            Send
                        </Button>
                    </Grid>
                </Grid>
            </Border>
        </Border>
    </Grid>

</UserControl>
