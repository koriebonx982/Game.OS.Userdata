<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GameLauncher.ViewModels"
             xmlns:views="using:GameLauncher.Views"
             xmlns:models="using:GameLauncher.Models"
             x:Class="GameLauncher.Views.LibraryView"
             x:DataType="vm:LibraryViewModel"
             Background="#0d1117">

    <StackPanel Margin="32,28,32,28" Spacing="0">

        <!-- Header -->
        <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,20">
            <StackPanel Grid.Column="0">
                <TextBlock Text="My Library" Classes="page-title"/>
                <TextBlock Text="{Binding TotalGames, StringFormat='{}{0} games in your collection'}"
                           Classes="page-subtitle"/>
            </StackPanel>
            <TextBox Grid.Column="1"
                     Classes="form-input"
                     Text="{Binding SearchText}"
                     Watermark="🔍  Search games…"
                     Width="240" VerticalAlignment="Center"/>
        </Grid>

        <!-- Platform filter dropdown -->
        <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,12">
            <TextBlock Text="Platform:"
                       FontSize="13" Foreground="#8b949e"
                       VerticalAlignment="Center"/>
            <ComboBox ItemsSource="{Binding Platforms}"
                      SelectedItem="{Binding FilterPlatform}"
                      MinWidth="180"
                      VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Install-status filter chips -->
        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,20">
            <Button Classes="filter-chip"
                    Classes.filter-chip-active="{Binding IsInstallFilterAll}"
                    Command="{Binding SetInstallFilterCommand}"
                    CommandParameter="All">
                <TextBlock Text="All Games" FontSize="12" FontWeight="SemiBold"/>
            </Button>
            <Button Classes="filter-chip"
                    Classes.filter-chip-active="{Binding IsInstallFilterInstalled}"
                    Command="{Binding SetInstallFilterCommand}"
                    CommandParameter="Installed">
                <TextBlock Text="✓  Installed" FontSize="12" FontWeight="SemiBold"/>
            </Button>
            <Button Classes="filter-chip"
                    Classes.filter-chip-active="{Binding IsInstallFilterNotInstalled}"
                    Command="{Binding SetInstallFilterCommand}"
                    CommandParameter="Not Installed">
                <TextBlock Text="🕒  Not Installed" FontSize="12" FontWeight="SemiBold"/>
            </Button>
        </StackPanel>

        <!-- Game card grid -->
        <ItemsControl ItemsSource="{Binding FilteredGames}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="models:Game">
                    <Button Classes="game-card-btn"
                            Command="{Binding $parent[UserControl].DataContext.OpenGameDetailCommand}"
                            CommandParameter="{Binding}">
                        <StackPanel>
                            <!-- Cover art -->
                            <Border Height="130" CornerRadius="10,10,0,0" ClipToBounds="True">
                                <views:CoverImage
                                    ImageUrl="{Binding CoverUrl}"
                                    FallbackText="{Binding Title}"
                                    FallbackGradient="{Binding CoverGradient}"
                                    SubText="{Binding Platform}"
                                    LetterFontSize="52"
                                    ImageCornerRadius="10,10,0,0"
                                    Height="130"/>
                            </Border>
                            <!-- Info -->
                            <Border Padding="10,10,10,12">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{Binding Title}"
                                               Classes="game-card-title"/>
                                    <Border CornerRadius="3" Padding="5,2"
                                            Background="#1f6feb"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding Platform}"
                                                   FontSize="10" FontWeight="Bold"
                                                   Foreground="White"/>
                                    </Border>
                                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,2,0,0">
                                        <TextBlock Text="{Binding RatingStars}"
                                                   FontSize="11" Foreground="#f1c40f"/>
                                        <TextBlock Text="{Binding Genre}"
                                                   Classes="game-card-meta"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- ══ My Games (LocalGames + Repacks + ROMs unified) ══ -->
        <Border IsVisible="{Binding HasMyGames}"
                Margin="0,32,0,0" Padding="0,0,0,12">
            <StackPanel Spacing="14">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="🎮" FontSize="18" VerticalAlignment="Center"/>
                    <TextBlock Text="My Games"
                               FontSize="18" FontWeight="Bold"
                               Foreground="#e6edf3" VerticalAlignment="Center"/>
                    <Border CornerRadius="10" Padding="8,3" Background="#238636"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding FilteredMyGames.Count}"
                                   FontSize="12" FontWeight="Bold" Foreground="White"/>
                    </Border>
                </StackPanel>

                <ItemsControl ItemsSource="{Binding FilteredMyGames}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:LocalGameCardVm">
                            <Button Classes="game-card-btn"
                                    Width="170" Margin="0,0,10,10"
                                    Command="{Binding $parent[UserControl].DataContext.OpenMyGameDetailCommand}"
                                    CommandParameter="{Binding}">
                                <StackPanel>
                                    <!-- Cover art (real image if available, gradient placeholder otherwise) -->
                                    <Border Height="130" CornerRadius="10,10,0,0" ClipToBounds="True">
                                        <views:CoverImage
                                            ImageUrl="{Binding CoverUrl}"
                                            FallbackText="{Binding EffectiveTitle}"
                                            FallbackGradient="{Binding CoverGradient}"
                                            SubText="{Binding Platform}"
                                            LetterFontSize="48"
                                            ImageCornerRadius="10,10,0,0"
                                            Height="130"/>
                                    </Border>
                                    <!-- Info -->
                                    <Border Padding="10,8,10,10">
                                        <StackPanel Spacing="3">
                                            <TextBlock Text="{Binding EffectiveTitle}"
                                                       Classes="game-card-title"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <!-- Platform badge -->
                                                <Border CornerRadius="3" Padding="5,2"
                                                        Background="#1f6feb" HorizontalAlignment="Left">
                                                    <TextBlock Text="{Binding Platform}"
                                                               FontSize="10" FontWeight="Bold"
                                                               Foreground="White"/>
                                                </Border>
                                                <!-- Kind badge (Installed / Repack / ROM) -->
                                                <Border CornerRadius="3" Padding="5,2"
                                                        Background="{Binding KindBackground}"
                                                        HorizontalAlignment="Left">
                                                    <TextBlock Text="{Binding KindLabel}"
                                                               FontSize="10" FontWeight="Bold"
                                                               Foreground="{Binding KindForeground}"/>
                                                </Border>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

    </StackPanel>
</UserControl>
