<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GameLauncher.ViewModels"
             xmlns:models="using:GameLauncher.Models"
             x:Class="GameLauncher.Views.FriendsView"
             x:DataType="vm:FriendsViewModel"
             Background="#0d1117">

    <Grid RowDefinitions="*,Auto">

    <!-- ── Friends list (scrollable) ── -->
    <ScrollViewer Grid.Row="0"
                  HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="32,28,32,28" Spacing="0">

        <!-- Header -->
        <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,20">
            <StackPanel Grid.Column="0">
                <TextBlock Text="Friends" Classes="page-title"/>
                <TextBlock Classes="page-subtitle">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="{}{0} online · {1} total">
                            <Binding Path="OnlineCount"/>
                            <Binding Path="TotalCount"/>
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
            </StackPanel>
            <Button Grid.Column="1" Classes="btn-primary"
                    VerticalAlignment="Center" Padding="16,10">
                + Add Friend
            </Button>
        </Grid>

        <!-- Loading indicator -->
        <TextBlock Text="Loading friends…"
                   Foreground="#8b949e" FontSize="13" Margin="0,0,0,16"
                   IsVisible="{Binding IsLoading}"/>

        <!-- Error message -->
        <Border Background="#3d1a1a" CornerRadius="6" Padding="14,10"
                Margin="0,0,0,16"
                IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="#f85149" FontSize="13"/>
        </Border>

        <!-- ── Recent Activity Feed ── -->
        <StackPanel IsVisible="False" Margin="0,0,0,24">
            <TextBlock Text="Recent Activity" Classes="section-header" Margin="0,0,0,10"/>
            <Border Background="#161b22" CornerRadius="12" Padding="4">
                <ItemsControl ItemsSource="{Binding RecentActivity}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:FriendActivityItem">
                            <Border Padding="14,10" CornerRadius="8">
                                <Grid ColumnDefinitions="36,*,Auto">
                                    <!-- Mini avatar -->
                                    <Border Grid.Column="0" Width="30" Height="30"
                                            CornerRadius="15" Background="#1f6feb">
                                        <TextBlock Text="{Binding AvatarInitial}"
                                                   FontSize="13" FontWeight="Bold"
                                                   Foreground="White"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <!-- Activity description -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center"
                                                Margin="10,0,0,0" Spacing="1">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <TextBlock Text="{Binding Icon}" FontSize="12"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Username}"
                                                       FontSize="13" FontWeight="Bold"
                                                       Foreground="White"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding ActivityText}"
                                                       FontSize="12" Foreground="#8b949e"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="{Binding GameTitle}"
                                                       FontSize="12" Foreground="#0ea5e9"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="·" FontSize="11" Foreground="#30363d"
                                                       VerticalAlignment="Center"
                                                       IsVisible="{Binding Platform, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                            <Border Background="#21262d" CornerRadius="4"
                                                    Padding="5,2"
                                                    IsVisible="{Binding Platform, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                                <TextBlock Text="{Binding Platform}"
                                                           FontSize="10" FontWeight="Bold"
                                                           Foreground="#8b949e"/>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                    <!-- Time ago -->
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding TimeAgo}"
                                               FontSize="11" Foreground="#484f58"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>
        </StackPanel>

        <!-- Pending Requests -->
        <StackPanel IsVisible="False" Margin="0,0,0,24">
            <TextBlock Text="Friend Requests" Classes="section-header"/>
            <ItemsControl ItemsSource="{Binding PendingRequests}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:FriendRequestDisplay">
                        <Border Background="#161b22" CornerRadius="10"
                                Padding="16,12" Margin="0,0,0,8">
                            <Grid ColumnDefinitions="52,*,Auto,Auto">
                                <!-- Avatar -->
                                <Border Grid.Column="0" Width="42" Height="42"
                                        CornerRadius="21" Background="#1f6feb">
                                    <TextBlock Text="{Binding AvatarInitial}"
                                               FontSize="18" FontWeight="Bold"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <!-- Info -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center"
                                            Margin="12,0,0,0" Spacing="2">
                                    <TextBlock Text="{Binding FromUsername}"
                                               FontSize="14" FontWeight="SemiBold"
                                               Foreground="White"/>
                                    <TextBlock FontSize="11" Foreground="#8b949e">
                                        <Run Text="Sent "/>
                                        <Run Text="{Binding SentAgo}"/>
                                    </TextBlock>
                                </StackPanel>
                                <!-- Accept -->
                                <Button Grid.Column="2" Classes="btn-success"
                                        Padding="14,7" Margin="0,0,8,0">
                                    ✓ Accept
                                </Button>
                                <!-- Decline -->
                                <Button Grid.Column="3" Classes="btn-secondary"
                                        Padding="14,7">
                                    ✕ Decline
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <!-- Online Friends -->
        <StackPanel IsVisible="{Binding OnlineFriends.Count}" Margin="0,0,0,24">
            <TextBlock Classes="section-header" Margin="0,0,0,8">
                <Run Text="🟢  Online — "/>
                <Run Text="{Binding OnlineCount}"/>
            </TextBlock>
            <ItemsControl ItemsSource="{Binding OnlineFriends}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:FriendEntry">
                        <Border Background="#161b22" CornerRadius="12"
                                Padding="16,14" Margin="0,0,0,8">
                            <Grid ColumnDefinitions="56,*,Auto,Auto">
                                <!-- Avatar with status dot -->
                                <Panel Grid.Column="0" Width="46" Height="46">
                                    <Border Width="46" Height="46" CornerRadius="23"
                                            Background="#1f6feb">
                                        <TextBlock Text="{Binding AvatarInitial}"
                                                   FontSize="20" FontWeight="Bold"
                                                   Foreground="White"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <!-- Online dot -->
                                    <Border Width="14" Height="14" CornerRadius="7"
                                            Background="#3fb950"
                                            BorderBrush="#161b22" BorderThickness="2"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Bottom"
                                            IsVisible="{Binding IsOnline}"/>
                                    <!-- Away dot -->
                                    <Border Width="14" Height="14" CornerRadius="7"
                                            Background="#e8960c"
                                            BorderBrush="#161b22" BorderThickness="2"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Bottom"
                                            IsVisible="{Binding IsAway}"/>
                                </Panel>

                                <!-- Friend info + current game -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center"
                                            Margin="14,0,0,0" Spacing="3">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{Binding Username}"
                                                   FontSize="15" FontWeight="Bold"
                                                   Foreground="White"/>
                                        <!-- GamerScore badge -->
                                        <Border CornerRadius="4" Padding="6,2"
                                                Background="#21262d"
                                                VerticalAlignment="Center"
                                                IsVisible="{Binding GamerScoreLabel, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                            <TextBlock Text="{Binding GamerScoreLabel}"
                                                       FontSize="10" FontWeight="Bold"
                                                       Foreground="#f1c40f"/>
                                        </Border>
                                    </StackPanel>
                                    <!-- Status line -->
                                    <StackPanel Orientation="Horizontal" Spacing="5"
                                                IsVisible="{Binding IsOnline}">
                                        <TextBlock Text="●" FontSize="9"
                                                   Foreground="#3fb950"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="Online" FontSize="12"
                                                   Foreground="#3fb950"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="5"
                                                IsVisible="{Binding IsAway}">
                                        <TextBlock Text="●" FontSize="9"
                                                   Foreground="#e8960c"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="Away" FontSize="12"
                                                   Foreground="#e8960c"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <!-- Currently playing -->
                                    <StackPanel Orientation="Horizontal" Spacing="6"
                                                IsVisible="{Binding CurrentGame, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                        <TextBlock Text="🎮" FontSize="11"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="Playing " FontSize="12"
                                                   Foreground="#8b949e"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding CurrentGame}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="#e6edf3"
                                                   VerticalAlignment="Center"
                                                   MaxWidth="200"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <Border Background="#21262d" CornerRadius="4"
                                                Padding="5,2" VerticalAlignment="Center"
                                                IsVisible="{Binding RecentGamePlatform, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                            <TextBlock Text="{Binding RecentGamePlatform}"
                                                       FontSize="10" FontWeight="Bold"
                                                       Foreground="#8b949e"/>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>

                                <!-- View Profile button -->
                                <Button Grid.Column="2" Classes="btn-secondary"
                                        Padding="10,7" VerticalAlignment="Center"
                                        Margin="0,0,8,0"
                                        Command="{Binding $parent[UserControl].DataContext.ViewFriendProfileCommand}"
                                        CommandParameter="{Binding Username}">
                                    👤 Profile
                                </Button>
                                <!-- Message button -->
                                <Button Grid.Column="3" Classes="btn-secondary"
                                        Padding="12,7" VerticalAlignment="Center"
                                        Command="{Binding $parent[UserControl].DataContext.OpenConversationCommand}"
                                        CommandParameter="{Binding Username}">
                                    💬
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <!-- Offline Friends -->
        <StackPanel IsVisible="{Binding OfflineFriends.Count}">
            <TextBlock Text="⚫  Offline" Classes="section-header" Margin="0,0,0,8"/>
            <ItemsControl ItemsSource="{Binding OfflineFriends}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:FriendEntry">
                        <Border Background="#161b22" CornerRadius="12"
                                Padding="16,14" Margin="0,0,0,8"
                                Opacity="0.8">
                            <Grid ColumnDefinitions="56,*,Auto,Auto">
                                <!-- Avatar (dimmed) -->
                                <Border Grid.Column="0" Width="46" Height="46"
                                        CornerRadius="23" Background="#21262d">
                                    <TextBlock Text="{Binding AvatarInitial}"
                                               FontSize="20" FontWeight="Bold"
                                               Foreground="#484f58"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>

                                <!-- Friend info + last played -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center"
                                            Margin="14,0,0,0" Spacing="3">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{Binding Username}"
                                                   FontSize="15" FontWeight="Bold"
                                                   Foreground="#c9d1d9"/>
                                        <!-- GamerScore badge -->
                                        <Border CornerRadius="4" Padding="6,2"
                                                Background="#1c2128"
                                                VerticalAlignment="Center"
                                                IsVisible="{Binding GamerScoreLabel, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                            <TextBlock Text="{Binding GamerScoreLabel}"
                                                       FontSize="10" FontWeight="Bold"
                                                       Foreground="#8b949e"/>
                                        </Border>
                                    </StackPanel>
                                    <!-- Last seen -->
                                    <TextBlock FontSize="12" Foreground="#484f58">
                                        <Run Text="Last seen "/>
                                        <Run Text="{Binding LastSeen}"/>
                                    </TextBlock>
                                    <!-- Last played game -->
                                    <StackPanel Orientation="Horizontal" Spacing="6"
                                                IsVisible="{Binding RecentGameTitle, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                        <TextBlock Text="🎮" FontSize="11"
                                                   VerticalAlignment="Center"
                                                   Opacity="0.6"/>
                                        <TextBlock Text="Last played " FontSize="12"
                                                   Foreground="#484f58"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding RecentGameTitle}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="#8b949e"
                                                   VerticalAlignment="Center"
                                                   MaxWidth="200"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <Border Background="#1c2128" CornerRadius="4"
                                                Padding="5,2" VerticalAlignment="Center"
                                                IsVisible="{Binding RecentGamePlatform, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                            <TextBlock Text="{Binding RecentGamePlatform}"
                                                       FontSize="10" FontWeight="Bold"
                                                       Foreground="#484f58"/>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>

                                <!-- View Profile button -->
                                <Button Grid.Column="2" Classes="btn-secondary"
                                        Padding="10,7" VerticalAlignment="Center"
                                        Margin="0,0,8,0"
                                        Opacity="0.7"
                                        Command="{Binding $parent[UserControl].DataContext.ViewFriendProfileCommand}"
                                        CommandParameter="{Binding Username}">
                                    👤 Profile
                                </Button>
                                <!-- Message button -->
                                <Button Grid.Column="3" Classes="btn-secondary"
                                        Padding="12,7" VerticalAlignment="Center"
                                        Opacity="0.7"
                                        Command="{Binding $parent[UserControl].DataContext.OpenConversationCommand}"
                                        CommandParameter="{Binding Username}">
                                    💬
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <!-- Empty state — shown when not loading and no friends found -->
        <TextBlock Text="No friends yet. Add friends to see them here."
                   Foreground="#8b949e" FontSize="13" HorizontalAlignment="Center"
                   Margin="0,32,0,0"
                   IsVisible="{Binding HasNoFriends}"/>

    </StackPanel>
    </ScrollViewer>

    <!-- ── Inline conversation panel ── -->
    <Border Grid.Row="1"
            Background="#161b22"
            BorderBrush="#30363d"
            BorderThickness="0,1,0,0"
            IsVisible="{Binding ShowConversation}">
        <Grid RowDefinitions="Auto,*,Auto" MaxHeight="340">

            <!-- Conversation header -->
            <Border Grid.Row="0" Padding="16,10" Background="#1c2128">
                <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8"
                            VerticalAlignment="Center">
                    <TextBlock Text="💬" FontSize="16"/>
                    <TextBlock Text="{Binding ConversationFriend}"
                               FontSize="14" FontWeight="Bold" Foreground="White"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <Button Grid.Column="1" Classes="btn-secondary" Padding="10,6"
                        Command="{Binding CloseConversationCommand}">
                    ✕
                </Button>
                </Grid>
            </Border>

            <!-- Message list -->
            <ScrollViewer Grid.Row="1"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto"
                          Padding="16,8">
                <StackPanel Spacing="8">
                    <!-- Message error -->
                    <TextBlock Text="{Binding MessageError}"
                               Foreground="#f85149" FontSize="12"
                               IsVisible="{Binding MessageError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                    <!-- No messages yet -->
                    <TextBlock Text="No messages yet. Say hello!"
                               Foreground="#8b949e" FontSize="12"
                               HorizontalAlignment="Center" Margin="0,16,0,0"
                               IsVisible="{Binding !ConversationMessages.Count}"/>
                    <!-- Message bubbles -->
                    <ItemsControl ItemsSource="{Binding ConversationMessages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:Message">
                                <Border CornerRadius="10" Padding="10,7"
                                        Margin="0,2">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="{Binding From}"
                                                   FontSize="11" FontWeight="Bold"
                                                   Foreground="#1f6feb"/>
                                        <TextBlock Text="{Binding Text}"
                                                   FontSize="13" Foreground="#c9d1d9"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <!-- Send message input -->
            <Border Grid.Row="2" Padding="12,10" Background="#1c2128">
                <Grid ColumnDefinitions="*,Auto">
                <TextBox Grid.Column="0"
                         Text="{Binding NewMessageText}"
                         Watermark="Type a message…"
                         Background="#21262d"
                         Foreground="White"
                         BorderBrush="#30363d"
                         CornerRadius="8"
                         Padding="10,8"
                         Margin="0,0,8,0"/>
                <Button Grid.Column="1"
                        Classes="btn-primary"
                        Padding="16,8"
                        IsEnabled="{Binding !IsSendingMessage}"
                        Command="{Binding SendMessageCommand}">
                    Send ➤
                </Button>
                </Grid>
            </Border>

        </Grid>
    </Border>

    </Grid>
</UserControl>
