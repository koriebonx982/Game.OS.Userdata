<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GameLauncher.ViewModels"
             xmlns:models="using:GameLauncher.Models"
             x:Class="GameLauncher.Views.LoginView"
             x:DataType="vm:LoginViewModel"
             Background="#0d1117">

    <Grid>
        <!-- Subtle background gradient -->
        <Border Background="#0d1117">
            <Border.Background>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                    <GradientStop Color="#0d1117" Offset="0"/>
                    <GradientStop Color="#0f2027" Offset="0.5"/>
                    <GradientStop Color="#0d1117" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <!-- Centered content -->
        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="24"
                        MaxWidth="440"
                        Margin="0,40,0,40">

                <!-- Logo / Title -->
                <StackPanel HorizontalAlignment="Center" Spacing="8">
                    <Border Width="72" Height="72" CornerRadius="16"
                            HorizontalAlignment="Center">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                                <GradientStop Color="#0ea5e9" Offset="0"/>
                                <GradientStop Color="#1d4ed8" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="G" FontSize="38" FontWeight="Black"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Game.OS" FontSize="32" FontWeight="Black"
                               Foreground="White" HorizontalAlignment="Center"/>
                    <TextBlock Text="Your games. Your world. Your OS."
                               FontSize="14" Foreground="#8b949e"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- ══ SAVED ACCOUNTS (Quick Login) ══ -->
                <Border Background="#161b22" CornerRadius="12" Padding="20,16"
                        IsVisible="{Binding SavedAccounts.Count}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Saved Accounts" FontSize="13" FontWeight="SemiBold"
                                   Foreground="#8b949e"/>
                        <ItemsControl ItemsSource="{Binding SavedAccounts}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:SavedSession">
                                    <Button Background="Transparent" BorderThickness="0"
                                            HorizontalAlignment="Stretch"
                                            Padding="0"
                                            Command="{Binding $parent[UserControl].DataContext.QuickLoginCommand}"
                                            CommandParameter="{Binding}">
                                        <Border Background="#0d1117" CornerRadius="10"
                                                Padding="14,10">
                                            <Grid ColumnDefinitions="48,*,Auto">
                                                <!-- Avatar -->
                                                <Border Grid.Column="0"
                                                        Width="40" Height="40"
                                                        CornerRadius="20"
                                                        Background="{Binding AvatarColor}">
                                                    <TextBlock Text="{Binding DisplayName[0]}"
                                                               FontSize="18" FontWeight="Bold"
                                                               Foreground="White"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                                <!-- Name -->
                                                <StackPanel Grid.Column="1"
                                                            VerticalAlignment="Center"
                                                            Spacing="2" Margin="0">
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               FontSize="15" FontWeight="SemiBold"
                                                               Foreground="White"/>
                                                    <TextBlock Text="Saved account  ·  Click to sign in"
                                                               FontSize="11" Foreground="#8b949e"/>
                                                </StackPanel>
                                                <!-- Arrow -->
                                                <TextBlock Grid.Column="2"
                                                           Text="→" FontSize="18"
                                                           Foreground="#1f6feb"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,4,0"/>
                                            </Grid>
                                        </Border>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- ══ OFFLINE PROFILES (profiles with local cache but no active session) ══ -->
                <Border Background="#161b22" CornerRadius="12" Padding="20,16"
                        IsVisible="{Binding HasOfflineCachedProfiles}">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="⚡" FontSize="13" Foreground="#f0883e"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="Offline Profiles" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#8b949e"/>
                        </StackPanel>
                        <TextBlock Text="These profiles have local cached data and can be loaded without an internet connection."
                                   FontSize="11" Foreground="#484f58" TextWrapping="Wrap"/>
                        <ItemsControl ItemsSource="{Binding OfflineCachedProfiles}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <Button Background="Transparent" BorderThickness="0"
                                            HorizontalAlignment="Stretch"
                                            Padding="0"
                                            Command="{Binding $parent[UserControl].DataContext.QuickLoginOfflineCommand}"
                                            CommandParameter="{Binding}">
                                        <Border Background="#0d1117" CornerRadius="10"
                                                Padding="14,10">
                                            <Grid ColumnDefinitions="48,*,Auto">
                                                <!-- Avatar placeholder -->
                                                <Border Grid.Column="0"
                                                        Width="40" Height="40"
                                                        CornerRadius="20"
                                                        Background="#2d1b00">
                                                    <TextBlock Text="{Binding [0]}"
                                                               FontSize="18" FontWeight="Bold"
                                                               Foreground="#f0883e"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                                <!-- Name -->
                                                <StackPanel Grid.Column="1"
                                                            VerticalAlignment="Center"
                                                            Spacing="2" Margin="0">
                                                    <TextBlock Text="{Binding}"
                                                               FontSize="15" FontWeight="SemiBold"
                                                               Foreground="White"/>
                                                    <TextBlock Text="Offline profile  ·  Load without internet"
                                                               FontSize="11" Foreground="#8b949e"/>
                                                </StackPanel>
                                                <!-- Offline icon -->
                                                <TextBlock Grid.Column="2"
                                                           Text="⚡" FontSize="18"
                                                           Foreground="#f0883e"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,4,0"/>
                                            </Grid>
                                        </Border>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Login Card -->
                <Border Classes="login-card">
                    <StackPanel Spacing="16">

                        <!-- ── SIGN IN FORM ── -->
                        <StackPanel IsVisible="{Binding !ShowRegister}" Spacing="16">

                            <TextBlock Text="Sign In" FontSize="22" FontWeight="Bold"
                                       Foreground="White" HorizontalAlignment="Center"/>

                            <!-- Username -->
                            <StackPanel Spacing="0">
                                <TextBlock Text="Username or Email" Classes="form-label"/>
                                <TextBox Classes="form-input"
                                         Text="{Binding Username}"
                                         Watermark="Enter username or email"/>
                            </StackPanel>

                            <!-- Password -->
                            <StackPanel Spacing="0">
                                <TextBlock Text="Password" Classes="form-label"/>
                                <TextBox Classes="form-input"
                                         Text="{Binding Password}"
                                         PasswordChar="●"
                                         Watermark="Enter password"/>
                            </StackPanel>

                            <!-- Remember me (mirrors the website's "Remember me" checkbox) -->
                            <StackPanel Orientation="Horizontal" Spacing="8"
                                        VerticalAlignment="Center">
                                <CheckBox IsChecked="{Binding RememberMe}"
                                          Foreground="#8b949e"
                                          VerticalAlignment="Center"/>
                                <TextBlock Text="Remember me"
                                           FontSize="13" Foreground="#8b949e"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="(stay signed in)"
                                           FontSize="11" Foreground="#484f58"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Error -->
                            <TextBlock Text="{Binding ErrorMessage}"
                                       Classes="error-text"
                                       IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                            <!-- Sign In button -->
                            <Button Classes="btn-primary"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    Command="{Binding SignInCommand}"
                                    IsEnabled="{Binding !IsLoading}">
                                <Panel>
                                    <TextBlock Text="Sign In"
                                               IsVisible="{Binding !IsLoading}"/>
                                    <TextBlock Text="Signing in…"
                                               IsVisible="{Binding IsLoading}"
                                               Foreground="#8b949e"/>
                                </Panel>
                            </Button>

                            <!-- Switch to register -->
                            <Button Background="Transparent" Foreground="#1f6feb"
                                    HorizontalAlignment="Center"
                                    BorderThickness="0" FontSize="13"
                                    Command="{Binding ToggleFormCommand}">
                                Don't have an account? Create one →
                            </Button>

                        </StackPanel>

                        <!-- ── REGISTER FORM ── -->
                        <StackPanel IsVisible="{Binding ShowRegister}" Spacing="14">

                            <TextBlock Text="Create Account" FontSize="22" FontWeight="Bold"
                                       Foreground="White" HorizontalAlignment="Center"/>

                            <!-- Username -->
                            <StackPanel Spacing="0">
                                <TextBlock Text="Username" Classes="form-label"/>
                                <TextBox Classes="form-input"
                                         Text="{Binding Username}"
                                         Watermark="Choose a username (3–24 chars)"/>
                            </StackPanel>

                            <!-- Email -->
                            <StackPanel Spacing="0">
                                <TextBlock Text="Email Address" Classes="form-label"/>
                                <TextBox Classes="form-input"
                                         Text="{Binding Email}"
                                         Watermark="your@email.com"/>
                            </StackPanel>

                            <!-- Password -->
                            <StackPanel Spacing="0">
                                <TextBlock Text="Password" Classes="form-label"/>
                                <TextBox Classes="form-input"
                                         Text="{Binding Password}"
                                         PasswordChar="●"
                                         Watermark="Min. 8 characters"/>
                            </StackPanel>

                            <!-- Confirm Password -->
                            <StackPanel Spacing="0">
                                <TextBlock Text="Confirm Password" Classes="form-label"/>
                                <TextBox Classes="form-input"
                                         Text="{Binding ConfirmPassword}"
                                         PasswordChar="●"
                                         Watermark="Repeat password"/>
                            </StackPanel>

                            <!-- Error -->
                            <TextBlock Text="{Binding ErrorMessage}"
                                       Classes="error-text"
                                       IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                            <!-- Register button -->
                            <Button Classes="btn-primary"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    Command="{Binding RegisterCommand}"
                                    IsEnabled="{Binding !IsLoading}">
                                Create Account
                            </Button>

                            <!-- Back to login -->
                            <Button Background="Transparent" Foreground="#1f6feb"
                                    HorizontalAlignment="Center"
                                    BorderThickness="0" FontSize="13"
                                    Command="{Binding ToggleFormCommand}">
                                ← Already have an account? Sign in
                            </Button>

                        </StackPanel>

                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
