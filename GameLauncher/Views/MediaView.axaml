<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GameLauncher.ViewModels"
             xmlns:vlc="using:LibVLCSharp.Avalonia"
             x:Class="GameLauncher.Views.MediaView"
             x:DataType="vm:MediaViewModel">

    <Panel>
        <!-- Main scrollable content -->
        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto"
                      IsVisible="{Binding !IsVlcPlayerOpen}">
            <StackPanel Margin="32,28,32,28" Spacing="24">

                <!-- Page title -->
                <TextBlock Text="Media" Classes="page-title"/>
                <TextBlock Text="Browse media from all drives under each drive's Media folder."
                           Classes="page-subtitle" Margin="0,-20,0,0"/>

                <!-- Play File button -->
                <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,4">
                    <Button Classes="btn-primary"
                            Command="{Binding PlayLocalVideoCommand}"
                            Padding="16,8">
                        🎬  Play File…
                    </Button>
                </StackPanel>

                <Border Classes="xb360-metro-tile xb360-metro-stat" CornerRadius="10">
                    <Grid Margin="16" ColumnDefinitions="220,*" ColumnSpacing="16">
                        <StackPanel Grid.Column="0" Spacing="8">
                            <TextBlock Text="Media" Classes="section-header"/>
                            <Button Classes="btn-secondary"
                                    Classes.active="{Binding IsMoviesSelected}"
                                    HorizontalAlignment="Stretch"
                                    Command="{Binding SelectMoviesCommand}">
                                🎬  Movies
                            </Button>
                            <Button Classes="btn-secondary"
                                    Classes.active="{Binding IsTvShowsSelected}"
                                    HorizontalAlignment="Stretch"
                                    Command="{Binding SelectTvShowsCommand}">
                                📺  TV Shows
                            </Button>
                            <Button Classes="btn-secondary"
                                    Classes.active="{Binding IsMusicSelected}"
                                    HorizontalAlignment="Stretch"
                                    Command="{Binding SelectMusicCommand}">
                                🎵  Music
                            </Button>
                            <Button Classes="btn-secondary"
                                    HorizontalAlignment="Stretch"
                                    Command="{Binding RefreshMediaLibraryCommand}">
                                Refresh Scan
                            </Button>
                        </StackPanel>

                        <Grid Grid.Column="1" RowDefinitions="Auto,Auto,*,Auto" RowSpacing="8">
                            <TextBlock Text="{Binding ActiveSectionTitle}" Classes="section-header"/>
                            <TextBlock Text="{Binding ActiveSectionSummary}"
                                       Grid.Row="1"
                                       FontSize="12"
                                       Foreground="#8b949e"/>
                            <ScrollViewer Grid.Row="2" MaxHeight="300"
                                          HorizontalScrollBarVisibility="Disabled"
                                          VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding ActiveItems}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" ItemWidth="180" ItemHeight="96"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Classes="btn-secondary"
                                                    Margin="0,0,8,8"
                                                    HorizontalContentAlignment="Stretch"
                                                    VerticalContentAlignment="Stretch"
                                                    Command="{Binding $parent[UserControl].DataContext.SelectMediaItemCommand}"
                                                    CommandParameter="{Binding}">
                                                <StackPanel Margin="8,6" Spacing="3">
                                                    <TextBlock Text="{Binding Title}"
                                                               FontSize="12"
                                                               FontWeight="SemiBold"
                                                               MaxHeight="34"
                                                               TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding Extension}"
                                                               FontSize="10"
                                                               Foreground="#8b949e"/>
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                            <Border Grid.Row="3"
                                    Classes="xb360-metro-tile xb360-metro-stat"
                                    CornerRadius="8"
                                    IsVisible="{Binding HasSelectedItem}">
                                <StackPanel Margin="12,10" Spacing="6">
                                    <TextBlock Text="Info" Classes="section-header" FontSize="14"/>
                                    <TextBlock Text="{Binding SelectedItemTitle}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding SelectedItemTypeLabel}"
                                               FontSize="11"
                                               Foreground="#8b949e"/>
                                    <TextBlock Text="{Binding SelectedItemSizeLabel}"
                                               FontSize="11"
                                               Foreground="#8b949e"/>
                                    <TextBlock Text="{Binding SelectedItemPath}"
                                               FontSize="10"
                                               Foreground="#8b949e"
                                               TextWrapping="Wrap"
                                               MaxHeight="36"/>
                                    <Button Classes="btn-primary"
                                            HorizontalAlignment="Left"
                                            Command="{Binding PlaySelectedMediaCommand}">
                                        <TextBlock Text="{Binding SelectedItemActionLabel}"/>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- VLC player overlay (shown when IsVlcPlayerOpen) -->
        <Border Background="#0d1117"
                IsVisible="{Binding IsVlcPlayerOpen}"
                ZIndex="50">
            <Grid RowDefinitions="Auto,*,Auto">

                <!-- Top bar -->
                <Border Grid.Row="0" Background="#161b22" Padding="16,10">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Button Grid.Column="0"
                                Classes="btn-secondary"
                                Padding="10,6"
                                Command="{Binding CloseVlcPlayerCommand}">
                            ✕  Close
                        </Button>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding VlcMediaPath}"
                                   FontSize="13"
                                   Foreground="#c9d1d9"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Grid.Column="2"
                                   Text="🎬 VLC Player"
                                   FontSize="12"
                                   Foreground="#8b949e"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Video surface -->
                <vlc:VideoView Grid.Row="1"
                               x:Name="VlcOverlayVideoView"/>

                <!-- Bottom hint -->
                <Border Grid.Row="2" Background="#161b22" Padding="16,8">
                    <TextBlock Text="Powered by VLC · press Close to stop playback"
                               FontSize="11"
                               Foreground="#484f58"
                               HorizontalAlignment="Center"/>
                </Border>

            </Grid>
        </Border>

    </Panel>
</UserControl>
