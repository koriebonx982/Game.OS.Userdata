<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GameLauncher.ViewModels"
             xmlns:views="using:GameLauncher.Views"
             xmlns:models="using:GameLauncher.Models"
             xmlns:wv="clr-namespace:AvaloniaWebView;assembly=Avalonia.WebView"
             x:Class="GameLauncher.Views.GameDetailView"
             x:DataType="vm:GameDetailViewModel"
             Background="#0d1117">

    <!-- Root panel: the normal content + the trailer overlay stacked on top -->
    <Panel>

    <Grid RowDefinitions="Auto,*">

        <!-- ── Top bar with back button ── -->
        <Border Grid.Row="0" Background="#161b22" Padding="20,14">
            <Grid ColumnDefinitions="Auto,*">
                <Button Grid.Column="0"
                        Classes="btn-secondary"
                        Padding="14,8"
                        Command="{Binding CloseCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="←" FontSize="16" VerticalAlignment="Center"/>
                        <TextBlock Text="Back" FontSize="14" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <TextBlock Grid.Column="1"
                           Text="{Binding Title}"
                           FontSize="18" FontWeight="Bold"
                           Foreground="White"
                           VerticalAlignment="Center"
                           Margin="16,0,0,0"/>
            </Grid>
        </Border>

        <!-- ── Content area ── -->
        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32,24,32,32" Spacing="0">

                <!-- Hero: cover + info side by side -->
                <Grid ColumnDefinitions="240,*" Margin="0,0,0,28">

                    <!-- Cover image -->
                    <Border Grid.Column="0" CornerRadius="12" ClipToBounds="True"
                            Width="220" Height="300" HorizontalAlignment="Left">
                        <views:CoverImage
                            ImageUrl="{Binding CoverUrl}"
                            FallbackText="{Binding Title}"
                            FallbackGradient="{Binding CoverGradient}"
                            SubText="{Binding Genre}"
                            LetterFontSize="80"
                            ImageCornerRadius="12"
                            Width="220" Height="300"/>
                    </Border>

                    <!-- Info panel -->
                    <StackPanel Grid.Column="1" Margin="28,0,0,0" Spacing="10"
                                VerticalAlignment="Top">

                        <TextBlock Text="{Binding Title}"
                                   FontSize="32" FontWeight="Bold"
                                   Foreground="White" TextWrapping="Wrap"/>

                        <!-- Badges row -->
                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                            <Border CornerRadius="4" Padding="10,4" Background="#1f6feb">
                                <TextBlock Text="{Binding Platform}"
                                           FontSize="12" FontWeight="Bold" Foreground="White"/>
                            </Border>
                            <Border CornerRadius="4" Padding="10,4" Background="#21262d"
                                    IsVisible="{Binding Genre, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                <TextBlock Text="{Binding Genre}"
                                           FontSize="12" Foreground="#c9d1d9"/>
                            </Border>
                            <Border CornerRadius="4" Padding="10,4" Background="#21262d"
                                    IsVisible="{Binding ReleaseYear, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                <TextBlock Text="{Binding ReleaseYear}"
                                           FontSize="12" Foreground="#8b949e"/>
                            </Border>
                            <!-- Region/Language badge for ROM games -->
                            <Border CornerRadius="4" Padding="10,4" Background="#1a3a1a"
                                    IsVisible="{Binding HasRegions}">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="🌍" FontSize="10" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding RegionsLabel}"
                                               FontSize="11" Foreground="#3fb950"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Rating -->
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="{Binding RatingStars}"
                                       FontSize="20" Foreground="#c9d1d9"/>
                        </StackPanel>

                        <!-- Price — only shown when explicitly set (not for store games) -->
                        <TextBlock Text="{Binding Price}"
                                   FontSize="24" FontWeight="Bold"
                                   Foreground="#3fb950"
                                   IsVisible="False"/>

                        <!-- Description -->
                        <TextBlock Text="{Binding Description}"
                                   FontSize="14" Foreground="#c9d1d9"
                                   TextWrapping="Wrap" MaxWidth="560"
                                   IsVisible="{Binding Description, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                   Margin="0,8,0,0"/>

                        <!-- Per-game playtime -->
                        <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0"
                                    IsVisible="{Binding HasPlaytime}">
                            <TextBlock Text="⏱" FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding PlaytimeLabel}"
                                       FontSize="13" Foreground="#0ea5e9"
                                       FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- ── Action buttons: Play + ··· when installed ── -->
                        <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,16,0,0"
                                    IsVisible="{Binding IsInstalled}">
                            <!-- Play / Playing... / Resume button -->
                            <!-- "Resume" state: game is running and user returned to launcher -->
                            <Button Classes="btn-primary"
                                    Classes.btn-resume="{Binding PlayButtonIsResume}"
                                    Padding="24,12"
                                    Command="{Binding LaunchGameCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="▶" FontSize="16" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding PlayButtonLabel}" FontSize="15" FontWeight="Bold"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <!-- More options (···) button — opens settings panel -->
                            <Button Classes="btn-secondary"
                                    Padding="16,12" ToolTip.Tip="Game Settings"
                                    Command="{Binding ShowMoreOptionsCommand}">
                                <TextBlock Text="···" FontSize="18" FontWeight="Bold"
                                           VerticalAlignment="Center"/>
                            </Button>
                            <!-- Mods button — visible for Nintendo Switch games -->
                            <Button Classes="btn-secondary"
                                    Padding="16,12" ToolTip.Tip="Manage Mods"
                                    Command="{Binding OpenModsPanelCommand}"
                                    IsVisible="{Binding IsSwitch}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="🧩" FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock Text="Mods" FontSize="14" FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!-- ── Install button when repack available ── -->
                        <StackPanel Margin="0,16,0,0" Spacing="6"
                                    IsVisible="{Binding IsRepack}">
                            <Button Classes="btn-success"
                                    Padding="24,12"
                                    IsEnabled="{Binding !IsExtracting}"
                                    Command="{Binding InstallRepackCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="⬇" FontSize="16" VerticalAlignment="Center"/>
                                    <!-- Label changes to "Installing..." during extraction -->
                                    <TextBlock Text="{Binding InstallButtonLabel}" FontSize="15" FontWeight="Bold"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <TextBlock Text="{Binding RepackSizeLabel}"
                                       FontSize="11" Foreground="#8b949e"
                                       IsVisible="{Binding RepackSizeLabel, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                            <!-- Extraction progress bar -->
                            <Border IsVisible="{Binding IsExtracting}"
                                    Background="#161b22" CornerRadius="8"
                                    Padding="12,10" Margin="0,4,0,0">
                                <StackPanel Spacing="6">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="⏳" FontSize="13" VerticalAlignment="Center"/>
                                        <TextBlock Text="Extracting…"
                                                   FontSize="12" Foreground="#8b949e"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding ExtractionProgress, StringFormat='{}{0:F0}%'}"
                                                   FontSize="12" Foreground="#0ea5e9"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <ProgressBar Value="{Binding ExtractionProgress}"
                                                 Minimum="0" Maximum="100"
                                                 Height="6" CornerRadius="3"
                                                 Foreground="#0ea5e9"
                                                 Background="#21262d"/>
                                </StackPanel>
                            </Border>
                            <!-- Install status message (visible after extraction completes / fails) -->
                            <TextBlock Text="{Binding InstallStatusMessage}"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{Binding InstallStatusForeground}"
                                       IsVisible="{Binding InstallStatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                       TextWrapping="Wrap" Margin="0,4,0,0"/>
                        </StackPanel>

                        <!-- ── Repack available badge (shown when game installed AND repack exists) ── -->
                        <Border IsVisible="{Binding HasMatchingRepack}"
                                Background="#2d1b00" CornerRadius="6"
                                Padding="12,8" Margin="0,10,0,0"
                                HorizontalAlignment="Left">
                            <TextBlock Text="{Binding MatchingRepackLabel}"
                                       FontSize="12" Foreground="#f0a030"
                                       FontWeight="SemiBold"/>
                        </Border>

                        <!-- ── Store page button ── -->
                        <Button Classes="btn-secondary"
                                Padding="20,10" Margin="0,10,0,0"
                                HorizontalAlignment="Left"
                                IsVisible="{Binding HasStoreUrl}"
                                Command="{Binding OpenStorePageCommand}">
                            <TextBlock Text="{Binding StoreButtonLabel}"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="#58a6ff"/>
                        </Button>

                        <!-- ── Drive picker (shown after clicking Install on an archive) ── -->
                        <Border IsVisible="{Binding ShowDrivePicker}"
                                Background="#161b22" CornerRadius="10"
                                Padding="16,14" Margin="0,12,0,0">
                            <StackPanel Spacing="10">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="💾" FontSize="16" VerticalAlignment="Center"/>
                                    <TextBlock Text="Choose Install Location"
                                               FontSize="14" FontWeight="Bold"
                                               Foreground="White" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="Select a drive with a Games folder (or create one):"
                                           FontSize="12" Foreground="#8b949e"/>
                                <ItemsControl ItemsSource="{Binding InstallDrives}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="models:InstallDriveOption">
                                            <Button Margin="0,0,0,6"
                                                    Background="#21262d"
                                                    BorderThickness="0"
                                                    CornerRadius="8"
                                                    Padding="12,10"
                                                    HorizontalAlignment="Stretch"
                                                    HorizontalContentAlignment="Left"
                                                    Cursor="Hand"
                                                    Command="{Binding $parent[UserControl].DataContext.SelectInstallDriveCommand}"
                                                    CommandParameter="{Binding}">
                                                <Grid ColumnDefinitions="*,Auto">
                                                    <StackPanel Grid.Column="0" Spacing="2">
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <TextBlock Text="💿" FontSize="14"/>
                                                            <TextBlock Text="{Binding DriveRoot}"
                                                                       FontSize="13" FontWeight="SemiBold"
                                                                       Foreground="White"/>
                                                            <Border CornerRadius="4" Padding="6,2"
                                                                    Background="#3fb950"
                                                                    IsVisible="{Binding GamesExists}">
                                                                <TextBlock Text="Games ✓" FontSize="10"
                                                                           Foreground="White" FontWeight="Bold"/>
                                                            </Border>
                                                            <Border CornerRadius="4" Padding="6,2"
                                                                    Background="#1f6feb"
                                                                    IsVisible="{Binding !GamesExists}">
                                                                <TextBlock Text="+ Add Games" FontSize="10"
                                                                           Foreground="White" FontWeight="Bold"/>
                                                            </Border>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding GamesFolderPath}"
                                                                   FontSize="11" Foreground="#8b949e"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding FreeSpaceLabel}"
                                                               FontSize="12" Foreground="#3fb950"
                                                               VerticalAlignment="Center"
                                                               Margin="12,0,0,0"/>
                                                </Grid>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Button Classes="btn-secondary" Padding="12,8"
                                        Command="{Binding CancelInstallCommand}">
                                    Cancel
                                </Button>
                            </StackPanel>
                        </Border>

                        <!-- Local game install info -->
                        <Border IsVisible="{Binding IsInstalled}"
                                Background="#0d3d1a" CornerRadius="8"
                                Padding="14,12" Margin="0,8,0,0">
                            <StackPanel Spacing="6">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="💿" FontSize="16" VerticalAlignment="Center"/>
                                    <TextBlock Text="Installed on Drive"
                                               FontSize="13" FontWeight="Bold"
                                               Foreground="#3fb950" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="Drive:" FontSize="12" Foreground="#8b949e"/>
                                    <TextBlock Text="{Binding ActiveDriveLabel}"
                                               FontSize="12" Foreground="White" FontWeight="SemiBold"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="Type:" FontSize="12" Foreground="#8b949e"/>
                                    <TextBlock Text="{Binding ActiveExeType}"
                                               FontSize="12" Foreground="#3fb950" FontWeight="Bold"/>
                                </StackPanel>
                                <TextBlock Text="{Binding ActiveDrivePath}"
                                           FontSize="11" Foreground="#8b949e"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- ── Multi-drive switcher ── -->
                <Border IsVisible="{Binding HasMultipleDrives}"
                        Background="#161b22" CornerRadius="10"
                        Padding="20,16" Margin="0,0,0,24">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="💾" FontSize="16" VerticalAlignment="Center"/>
                            <TextBlock Text="Available on Multiple Drives"
                                       FontSize="15" FontWeight="Bold"
                                       Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="Select which drive to use:"
                                   FontSize="12" Foreground="#8b949e"/>
                        <ItemsControl ItemsSource="{Binding DriveLabels}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="8"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Padding="16,8"
                                            CornerRadius="6"
                                            FontSize="13" FontWeight="SemiBold"
                                            Foreground="White"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            Command="{Binding $parent[UserControl].DataContext.SelectDriveCommand}"
                                            CommandParameter="{Binding}">
                                        <Button.Background>
                                            <SolidColorBrush Color="#1f6feb"/>
                                        </Button.Background>
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="💿" FontSize="13"/>
                                            <TextBlock Text="{Binding}" FontSize="13"/>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- ── Settings panel (shown when ··· is clicked) ── -->
                <Border IsVisible="{Binding ShowSettings}"
                        Background="#161b22" CornerRadius="12"
                        Padding="24,20" Margin="0,0,0,24">
                    <StackPanel Spacing="16">

                        <!-- Panel header -->
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10"
                                        VerticalAlignment="Center">
                                <TextBlock Text="⚙" FontSize="18" VerticalAlignment="Center"/>
                                <TextBlock Text="Game Settings"
                                           FontSize="17" FontWeight="Bold"
                                           Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button Grid.Column="1" Classes="btn-secondary" Padding="10,6"
                                    Command="{Binding CloseSettingsCommand}">✕</Button>
                        </Grid>

                        <!-- ── Executable / ROM selection ── -->
                        <Border Background="#21262d" CornerRadius="8" Padding="16,12">
                            <StackPanel Spacing="10">
                                <TextBlock Text="🎯  Executable / Launch File  (Exe Select)"
                                           FontSize="13" FontWeight="Bold" Foreground="White"/>
                                <TextBlock Text="Path to the .exe, .bat, or PS1 script used to launch this game."
                                           FontSize="11" Foreground="#8b949e"/>
                                <!-- ComboBox: shows detected executables; also allows typing a custom path -->
                                <ComboBox ItemsSource="{Binding AvailableExePaths}"
                                          SelectedItem="{Binding SettingsExePath}"
                                          PlaceholderText="C:\Games\GameTitle\game.exe"
                                          Background="#0d1117" Foreground="White"
                                          BorderBrush="#30363d" CornerRadius="6"
                                          Padding="10,8" FontSize="12"
                                          HorizontalAlignment="Stretch"
                                          IsVisible="{Binding AvailableExePaths.Count}"/>
                                <!-- Fallback TextBox when no executables are detected -->
                                <TextBox Text="{Binding SettingsExePath}"
                                         Watermark="C:\Games\GameTitle\game.exe"
                                         Background="#0d1117" Foreground="White"
                                         BorderBrush="#30363d" CornerRadius="6"
                                         Padding="10,8" FontSize="12"
                                         IsVisible="{Binding !AvailableExePaths.Count}"/>
                                <TextBlock Text="Launch arguments (optional):"
                                           FontSize="11" Foreground="#8b949e"/>
                                <TextBox Text="{Binding SettingsExeArgs}"
                                         Watermark="-windowed -dx11"
                                         Background="#0d1117" Foreground="White"
                                         BorderBrush="#30363d" CornerRadius="6"
                                         Padding="10,8" FontSize="12"/>

                                <!-- ROM Select — only shown for non-PC platforms -->
                                <StackPanel Spacing="6" IsVisible="{Binding IsRom}">
                                    <TextBlock Text="🕹  ROM File  (Rom Select)"
                                               FontSize="13" FontWeight="Bold" Foreground="#58a6ff"/>
                                    <TextBlock Text="Path to the ROM file passed to the emulator above."
                                               FontSize="11" Foreground="#8b949e"/>
                                    <!-- ComboBox: shows known ROM paths for multi-disk / multi-region games -->
                                    <ComboBox ItemsSource="{Binding AvailableRomPaths}"
                                              SelectedItem="{Binding SettingsRomPath}"
                                              PlaceholderText="/Roms/PS3/Games/GameTitle.iso"
                                              Background="#0d1117" Foreground="White"
                                              BorderBrush="#30363d" CornerRadius="6"
                                              Padding="10,8" FontSize="12"
                                              HorizontalAlignment="Stretch"
                                              IsVisible="{Binding AvailableRomPaths.Count}"/>
                                    <!-- Fallback TextBox when no ROM paths are auto-detected -->
                                    <TextBox Text="{Binding SettingsRomPath}"
                                             Watermark="/Roms/PS3/Games/GameTitle.iso"
                                             Background="#0d1117" Foreground="White"
                                             BorderBrush="#30363d" CornerRadius="6"
                                             Padding="10,8" FontSize="12"
                                             IsVisible="{Binding !AvailableRomPaths.Count}"/>
                                </StackPanel>

                                <!-- Emulator picker — only shown when multiple emulators configured -->
                                <StackPanel Spacing="6"
                                            IsVisible="{Binding HasMultipleEmulators}">
                                    <TextBlock Text="🎮  Emulator"
                                               FontSize="13" FontWeight="Bold" Foreground="#58a6ff"/>
                                    <TextBlock Text="Choose which emulator to use for this game."
                                               FontSize="11" Foreground="#8b949e"/>
                                    <ComboBox ItemsSource="{Binding AvailableEmulators}"
                                              SelectedItem="{Binding SelectedEmulatorName}"
                                              Background="#0d1117" Foreground="White"
                                              BorderBrush="#30363d" CornerRadius="6"
                                              Padding="10,8" FontSize="12"
                                              HorizontalAlignment="Stretch"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- ── Pre-launch entries ── -->
                        <Border Background="#21262d" CornerRadius="8" Padding="16,12">
                            <StackPanel Spacing="10">
                                <TextBlock Text="▶  Pre-Launch  (runs before the game starts)"
                                           FontSize="13" FontWeight="Bold" Foreground="#3fb950"/>
                                <TextBlock Text="e.g. launch Steam with a specific account, start a VPN, open an overlay app."
                                           FontSize="11" Foreground="#8b949e"/>

                                <!-- Existing entries -->
                                <ItemsControl ItemsSource="{Binding PreLaunchEntries}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="models:LaunchEntry">
                                            <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,4">
                                                <StackPanel Grid.Column="0" Spacing="2">
                                                    <TextBlock Text="{Binding Label}"
                                                               FontSize="12" FontWeight="SemiBold"
                                                               Foreground="White"/>
                                                    <TextBlock Text="{Binding Path}"
                                                               FontSize="11" Foreground="#8b949e"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                                <Button Grid.Column="1" Padding="8,4"
                                                        Classes="btn-secondary"
                                                        Foreground="#f85149"
                                                        VerticalAlignment="Center"
                                                        Command="{Binding $parent[UserControl].DataContext.RemovePreLaunchCommand}"
                                                        CommandParameter="{Binding}">✕</Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Add new entry form -->
                                <StackPanel Spacing="6">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBox Grid.Column="0"
                                                 Text="{Binding NewPreLaunchPath}"
                                                 Watermark="Path to app/script/bat/ps1…"
                                                 Background="#0d1117" Foreground="White"
                                                 BorderBrush="#30363d" CornerRadius="6"
                                                 Padding="8,6" FontSize="12"/>
                                        <Button Grid.Column="1"
                                                Classes="btn-secondary" Content="Browse…"
                                                FontSize="11" Padding="8,6" Margin="4,0,0,0"
                                                VerticalAlignment="Center"
                                                Command="{Binding BrowsePreLaunchCommand}"/>
                                    </Grid>
                                    <Grid ColumnDefinitions="*,*">
                                        <TextBox Grid.Column="0" Text="{Binding NewPreLaunchArgs}"
                                                 Watermark="Arguments (optional)"
                                                 Background="#0d1117" Foreground="White"
                                                 BorderBrush="#30363d" CornerRadius="6"
                                                 Padding="8,6" FontSize="12"
                                                 Margin="0,0,4,0"/>
                                        <TextBox Grid.Column="1" Text="{Binding NewPreLaunchLabel}"
                                                 Watermark="Label (e.g. Steam)"
                                                 Background="#0d1117" Foreground="White"
                                                 BorderBrush="#30363d" CornerRadius="6"
                                                 Padding="8,6" FontSize="12"
                                                 Margin="4,0,0,0"/>
                                    </Grid>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <CheckBox IsChecked="{Binding NewPreLaunchWaitForReady}"
                                                  Content="Wait until ready before launching game"
                                                  FontSize="11" Foreground="#8b949e"/>
                                    </StackPanel>
                                    <Button Classes="btn-secondary" Padding="12,6"
                                            HorizontalAlignment="Left"
                                            Command="{Binding AddPreLaunchCommand}">
                                        + Add Pre-Launch Entry
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- ── During-launch entries ── -->
                        <Border Background="#21262d" CornerRadius="8" Padding="16,12">
                            <StackPanel Spacing="10">
                                <TextBlock Text="⏯  During Launch  (runs alongside the game)"
                                           FontSize="13" FontWeight="Bold" Foreground="#58a6ff"/>
                                <TextBlock Text="e.g. game server, online fix, overlay that must stay running while game is running."
                                           FontSize="11" Foreground="#8b949e"/>

                                <!-- Existing entries -->
                                <ItemsControl ItemsSource="{Binding DuringLaunchEntries}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="models:LaunchEntry">
                                            <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,4">
                                                <StackPanel Grid.Column="0" Spacing="2">
                                                    <TextBlock Text="{Binding Label}"
                                                               FontSize="12" FontWeight="SemiBold"
                                                               Foreground="White"/>
                                                    <TextBlock Text="{Binding Path}"
                                                               FontSize="11" Foreground="#8b949e"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                                <Button Grid.Column="1" Padding="8,4"
                                                        Classes="btn-secondary"
                                                        Foreground="#f85149"
                                                        VerticalAlignment="Center"
                                                        Command="{Binding $parent[UserControl].DataContext.RemoveDuringLaunchCommand}"
                                                        CommandParameter="{Binding}">✕</Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Add new entry form -->
                                <StackPanel Spacing="6">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBox Grid.Column="0"
                                                 Text="{Binding NewDuringLaunchPath}"
                                                 Watermark="Path to app/script/bat/ps1…"
                                                 Background="#0d1117" Foreground="White"
                                                 BorderBrush="#30363d" CornerRadius="6"
                                                 Padding="8,6" FontSize="12"/>
                                        <Button Grid.Column="1"
                                                Classes="btn-secondary" Content="Browse…"
                                                FontSize="11" Padding="8,6" Margin="4,0,0,0"
                                                VerticalAlignment="Center"
                                                Command="{Binding BrowseDuringLaunchCommand}"/>
                                    </Grid>
                                    <Grid ColumnDefinitions="*,*">
                                        <TextBox Grid.Column="0" Text="{Binding NewDuringLaunchArgs}"
                                                 Watermark="Arguments (optional)"
                                                 Background="#0d1117" Foreground="White"
                                                 BorderBrush="#30363d" CornerRadius="6"
                                                 Padding="8,6" FontSize="12"
                                                 Margin="0,0,4,0"/>
                                        <TextBox Grid.Column="1" Text="{Binding NewDuringLaunchLabel}"
                                                 Watermark="Label (e.g. Game Server)"
                                                 Background="#0d1117" Foreground="White"
                                                 BorderBrush="#30363d" CornerRadius="6"
                                                 Padding="8,6" FontSize="12"
                                                 Margin="4,0,0,0"/>
                                    </Grid>
                                    <Button Classes="btn-secondary" Padding="12,6"
                                            HorizontalAlignment="Left"
                                            Command="{Binding AddDuringLaunchCommand}">
                                        + Add During-Launch Entry
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- ── Post-launch entries ── -->
                        <Border Background="#21262d" CornerRadius="8" Padding="16,12">
                            <StackPanel Spacing="10">
                                <TextBlock Text="⏹  Post-Launch  (runs after the game exits)"
                                           FontSize="13" FontWeight="Bold" Foreground="#c9d1d9"/>
                                <TextBlock Text="e.g. close Steam/Epic, stop a VPN, run a backup script."
                                           FontSize="11" Foreground="#8b949e"/>

                                <!-- Existing entries -->
                                <ItemsControl ItemsSource="{Binding PostLaunchEntries}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="models:LaunchEntry">
                                            <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,4">
                                                <StackPanel Grid.Column="0" Spacing="2">
                                                    <TextBlock Text="{Binding Label}"
                                                               FontSize="12" FontWeight="SemiBold"
                                                               Foreground="White"/>
                                                    <TextBlock Text="{Binding Path}"
                                                               FontSize="11" Foreground="#8b949e"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                                <Button Grid.Column="1" Padding="8,4"
                                                        Classes="btn-secondary"
                                                        Foreground="#f85149"
                                                        VerticalAlignment="Center"
                                                        Command="{Binding $parent[UserControl].DataContext.RemovePostLaunchCommand}"
                                                        CommandParameter="{Binding}">✕</Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Add new entry form -->
                                <StackPanel Spacing="6">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBox Grid.Column="0"
                                                 Text="{Binding NewPostLaunchPath}"
                                                 Watermark="Path to app/script/bat/ps1…"
                                                 Background="#0d1117" Foreground="White"
                                                 BorderBrush="#30363d" CornerRadius="6"
                                                 Padding="8,6" FontSize="12"/>
                                        <Button Grid.Column="1"
                                                Classes="btn-secondary" Content="Browse…"
                                                FontSize="11" Padding="8,6" Margin="4,0,0,0"
                                                VerticalAlignment="Center"
                                                Command="{Binding BrowsePostLaunchCommand}"/>
                                    </Grid>
                                    <Grid ColumnDefinitions="*,*">
                                        <TextBox Grid.Column="0" Text="{Binding NewPostLaunchArgs}"
                                                 Watermark="Arguments (optional)"
                                                 Background="#0d1117" Foreground="White"
                                                 BorderBrush="#30363d" CornerRadius="6"
                                                 Padding="8,6" FontSize="12"
                                                 Margin="0,0,4,0"/>
                                        <TextBox Grid.Column="1" Text="{Binding NewPostLaunchLabel}"
                                                 Watermark="Label (e.g. Close Steam)"
                                                 Background="#0d1117" Foreground="White"
                                                 BorderBrush="#30363d" CornerRadius="6"
                                                 Padding="8,6" FontSize="12"
                                                 Margin="4,0,0,0"/>
                                    </Grid>
                                    <Button Classes="btn-secondary" Padding="12,6"
                                            HorizontalAlignment="Left"
                                            Command="{Binding AddPostLaunchCommand}">
                                        + Add Post-Launch Entry
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Background="#21262d" CornerRadius="8" Padding="16,12">
                            <StackPanel Spacing="10">
                                <TextBlock Text="📁  Manage Game Folder"
                                           FontSize="13" FontWeight="Bold" Foreground="White"/>
                                <TextBlock Text="{Binding ActiveDrivePath}"
                                           FontSize="11" Foreground="#8b949e"
                                           TextTrimming="CharacterEllipsis"
                                           IsVisible="{Binding ActiveDrivePath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Classes="btn-secondary" Padding="14,8"
                                            Command="{Binding OpenGameFolderCommand}"
                                            ToolTip.Tip="Open game folder in file manager">
                                        📂 Open Folder
                                    </Button>
                                    <!-- Copy / Move ROM buttons (only for ROM games) -->
                                    <Button Classes="btn-secondary" Padding="14,8"
                                            Command="{Binding CopyRomCommand}"
                                            ToolTip.Tip="Copy ROM to another drive"
                                            IsVisible="{Binding IsRom}">
                                        📋 Copy ROM
                                    </Button>
                                    <Button Classes="btn-secondary" Padding="14,8"
                                            Command="{Binding MoveRomCommand}"
                                            ToolTip.Tip="Move ROM to another drive"
                                            IsVisible="{Binding IsRom}">
                                        ✂ Move ROM
                                    </Button>
                                    <Button Classes="btn-secondary" Padding="14,8"
                                            Foreground="#f85149"
                                            Command="{Binding RequestDeleteGameCommand}"
                                            ToolTip.Tip="Delete game folder from disk"
                                            IsVisible="{Binding !ConfirmDelete}">
                                        🗑 Delete Game
                                    </Button>
                                    <Button Classes="btn-primary" Padding="14,8"
                                            Foreground="#f85149"
                                            Command="{Binding ConfirmDeleteGameCommand}"
                                            IsVisible="{Binding ConfirmDelete}">
                                        ⚠ Confirm Delete
                                    </Button>
                                    <Button Classes="btn-secondary" Padding="14,8"
                                            Command="{Binding CancelDeleteCommand}"
                                            IsVisible="{Binding ConfirmDelete}">
                                        Cancel
                                    </Button>
                                </StackPanel>

                                <!-- Copy / Move destination picker -->
                                <Border IsVisible="{Binding ShowCopyMovePicker}"
                                        Background="#161b22" CornerRadius="8"
                                        Padding="14,12" Margin="0,4,0,0">
                                    <StackPanel Spacing="10">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="💾" FontSize="14" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding CopyMoveMode, StringFormat='{}{0} ROM to…'}"
                                                       FontSize="13" FontWeight="Bold"
                                                       Foreground="White" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock Text="Select a drive to copy/move the ROM file to:"
                                                   FontSize="11" Foreground="#8b949e"/>
                                        <ItemsControl ItemsSource="{Binding CopyMoveDrives}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="models:InstallDriveOption">
                                                    <Button Margin="0,0,0,6"
                                                            Background="#21262d"
                                                            BorderThickness="0"
                                                            CornerRadius="8"
                                                            Padding="12,10"
                                                            HorizontalAlignment="Stretch"
                                                            HorizontalContentAlignment="Left"
                                                            Cursor="Hand"
                                                            Command="{Binding $parent[UserControl].DataContext.SelectCopyMoveDriveCommand}"
                                                            CommandParameter="{Binding}">
                                                        <Grid ColumnDefinitions="*,Auto">
                                                            <StackPanel Grid.Column="0" Spacing="2">
                                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                                    <TextBlock Text="💿" FontSize="14"/>
                                                                    <TextBlock Text="{Binding DriveRoot}"
                                                                               FontSize="13" FontWeight="SemiBold"
                                                                               Foreground="White"/>
                                                                    <Border CornerRadius="4" Padding="6,2"
                                                                            Background="#3fb950"
                                                                            IsVisible="{Binding GamesExists}">
                                                                        <TextBlock Text="Roms ✓" FontSize="10"
                                                                                   Foreground="White" FontWeight="Bold"/>
                                                                    </Border>
                                                                </StackPanel>
                                                                <TextBlock Text="{Binding GamesFolderPath}"
                                                                           FontSize="11" Foreground="#8b949e"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                            </StackPanel>
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding FreeSpaceLabel}"
                                                                       FontSize="12" Foreground="#3fb950"
                                                                       VerticalAlignment="Center"
                                                                       Margin="12,0,0,0"/>
                                                        </Grid>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <Button Classes="btn-secondary" Padding="12,8"
                                                Command="{Binding CancelCopyMoveCommand}">
                                            Cancel
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Save + status -->
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Button Classes="btn-primary" Padding="20,10"
                                    Command="{Binding SaveSettingsCommand}">
                                💾 Save Settings
                            </Button>
                        </StackPanel>

                        <!-- Status message -->
                        <TextBlock Text="{Binding SettingsStatus}"
                                   FontSize="12" Foreground="#3fb950"
                                   IsVisible="{Binding SettingsStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                    </StackPanel>
                </Border>

                <!-- ── Achievements section (above media) ── -->
                <Border IsVisible="{Binding HasAchievements}"
                        Margin="0,0,0,24">
                    <StackPanel Spacing="14">
                        <TextBlock Text="{Binding AchievementsLabel}"
                                   Classes="section-header" Margin="0"/>
                        <ItemsControl ItemsSource="{Binding VisibleAchievements}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:Achievement">
                                    <Border Background="#161b22" CornerRadius="8"
                                            Padding="12,10" Margin="0,0,8,8"
                                            Width="260"
                                            Opacity="{Binding LockedOpacity}">
                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                            <!-- Achievement icon -->
                                            <Border Width="40" Height="40" CornerRadius="6"
                                                    ClipToBounds="True" Background="#21262d">
                                                <views:CoverImage
                                                    ImageUrl="{Binding IconUrl}"
                                                    FallbackText="🏆"
                                                    LetterFontSize="18"
                                                    ImageCornerRadius="6"
                                                    Width="40" Height="40"/>
                                            </Border>
                                            <!-- Name + description -->
                                            <StackPanel Spacing="2" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="12" FontWeight="SemiBold"
                                                           Foreground="#58a6ff"
                                                           TextWrapping="Wrap" MaxWidth="180"/>
                                                <TextBlock Text="{Binding Description}"
                                                           FontSize="11" Foreground="#8b949e"
                                                           TextWrapping="Wrap" MaxWidth="180"
                                                           MaxLines="2"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <!-- More / Less button -->
                        <Button Classes="btn-secondary" Padding="14,8"
                                HorizontalAlignment="Left"
                                IsVisible="{Binding HasMoreAchievements}"
                                Command="{Binding ToggleShowAllAchievementsCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="▼  Show More Achievements"
                                           FontSize="12" FontWeight="SemiBold"
                                           IsVisible="{Binding !ShowAllAchievements}"/>
                                <TextBlock Text="▲  Show Less"
                                           FontSize="12" FontWeight="SemiBold"
                                           IsVisible="{Binding ShowAllAchievements}"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- ── Nintendo Switch Ryujinx Mods section ── -->
                <Border IsVisible="{Binding ShowModsPanel}"
                        Background="#161b22" CornerRadius="12"
                        Padding="24,20" Margin="0,0,0,24">
                    <StackPanel Spacing="14">

                        <!-- Section header -->
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="🧩" FontSize="18" VerticalAlignment="Center"/>
                                <TextBlock Text="Ryujinx Mods"
                                           FontSize="16" FontWeight="Bold"
                                           Foreground="White" VerticalAlignment="Center"/>
                                <Border CornerRadius="10" Padding="8,3" Background="#1f6feb"
                                        VerticalAlignment="Center"
                                        IsVisible="{Binding HasSwitchMods}">
                                    <TextBlock Text="{Binding SwitchMods.Count}"
                                               FontSize="12" FontWeight="Bold" Foreground="White"/>
                                </Border>
                            </StackPanel>
                            <!-- Close button -->
                            <Button Grid.Column="1"
                                    Command="{Binding CloseModsPanelCommand}"
                                    Background="Transparent" BorderThickness="0"
                                    Padding="6,4" Cursor="Hand"
                                    ToolTip.Tip="Close"
                                    VerticalAlignment="Center">
                                <TextBlock Text="✕" FontSize="14" Foreground="#8b949e"/>
                            </Button>
                        </Grid>

                        <TextBlock Text="Enable or disable mods for this game in Ryujinx."
                                   FontSize="12" Foreground="#8b949e"/>

                        <!-- mods.json file path hint -->
                        <Border IsVisible="{Binding SwitchModsJsonPath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                Background="#21262d" CornerRadius="6" Padding="10,6">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="📄" FontSize="11" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding SwitchModsJsonPath}"
                                           FontSize="10" Foreground="#6e7681"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Mod list -->
                        <ItemsControl ItemsSource="{Binding SwitchMods}"
                                      IsVisible="{Binding HasSwitchMods}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:RyujinxModVm">
                                    <Border Background="#21262d" CornerRadius="8"
                                            Padding="14,10" Margin="0,0,0,6">
                                        <Grid ColumnDefinitions="*,Auto">

                                            <!-- Mod info -->
                                            <StackPanel Grid.Column="0" Spacing="4"
                                                        VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="13" FontWeight="SemiBold"
                                                               Foreground="White"/>
                                                    <!-- Enabled/Disabled badge -->
                                                    <Border CornerRadius="4" Padding="6,2"
                                                            Background="{Binding StatusBackground}">
                                                        <TextBlock Text="{Binding StatusLabel}"
                                                                   FontSize="10" FontWeight="Bold"
                                                                   Foreground="{Binding StatusForeground}"/>
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Path}"
                                                           FontSize="10" Foreground="#6e7681"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxWidth="500"/>
                                            </StackPanel>

                                            <!-- Toggle button -->
                                            <Button Grid.Column="1"
                                                    Padding="14,7"
                                                    CornerRadius="6"
                                                    BorderThickness="0"
                                                    Cursor="Hand"
                                                    VerticalAlignment="Center"
                                                    Command="{Binding $parent[UserControl].DataContext.ToggleSwitchModCommand}"
                                                    CommandParameter="{Binding}">
                                                <Button.Background>
                                                    <SolidColorBrush Color="{Binding ToggleBackground}"/>
                                                </Button.Background>
                                                <TextBlock Text="{Binding ToggleLabel}"
                                                           FontSize="12" FontWeight="Bold"
                                                           Foreground="{Binding ToggleForeground}"/>
                                            </Button>

                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Empty state: mods.json exists but has no entries -->
                        <Border IsVisible="{Binding ModsJsonExistsButEmpty}"
                                Background="#21262d" CornerRadius="8" Padding="16,12">
                            <StackPanel Spacing="6">
                                <TextBlock Text="No mods found in mods.json."
                                           FontSize="13" Foreground="#8b949e"/>
                                <TextBlock Text="Add mods to the mods folder, then re-open this panel."
                                           FontSize="11" Foreground="#6e7681"/>
                            </StackPanel>
                        </Border>

                        <!-- Empty state: mods.json not yet created (no mods folder set up) -->
                        <Border IsVisible="{Binding ShowModsNotFoundMessage}"
                                Background="#21262d" CornerRadius="8" Padding="16,12">
                            <StackPanel Spacing="6">
                                <TextBlock Text="No mods.json found for this game."
                                           FontSize="13" Foreground="#8b949e"/>
                                <TextBlock Text="Place mods in the mods folder and re-open this panel."
                                           FontSize="11" Foreground="#6e7681"/>
                            </StackPanel>
                        </Border>

                        <!-- Status message -->
                        <TextBlock Text="{Binding SwitchModsStatus}"
                                   FontSize="12" Foreground="#3fb950"
                                   IsVisible="{Binding SwitchModsStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                        <!-- Open Mods Folder button -->
                        <Button Classes="btn-secondary"
                                Padding="14,8"
                                Command="{Binding OpenSwitchModsFolderCommand}"
                                HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="📂" FontSize="13" VerticalAlignment="Center"/>
                                <TextBlock Text="Open Mods Folder" FontSize="12"
                                           FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                    </StackPanel>
                </Border>

                <!-- ── Media row: Trailer (left) + Screenshots (right) on the same row.
                     WrapPanel collapses gracefully when only one child is visible. ── -->
                <WrapPanel Orientation="Horizontal" Margin="0,0,0,24">

                    <!-- Trailer (first in media) -->
                    <Border IsVisible="{Binding HasTrailer}"
                            Background="#161b22" CornerRadius="10"
                            Padding="20,16" Margin="0,0,16,16">
                        <StackPanel Spacing="12">
                            <TextBlock Text="🎬  Trailer"
                                       Classes="section-header" Margin="0"/>

                            <!-- YouTube embed-style player preview -->
                            <Button Background="Transparent" BorderThickness="0"
                                    Padding="0" HorizontalAlignment="Left"
                                    Command="{Binding OpenTrailerCommand}"
                                    Cursor="Hand">
                                <Border CornerRadius="10" ClipToBounds="True"
                                        Width="400" Height="225">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                                            <GradientStop Color="#0d1117" Offset="0"/>
                                            <GradientStop Color="#161b22" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <!-- Black letterbox with play icon — like an embedded player -->
                                    <Grid>
                                        <!-- Centered play button (YouTube-style) -->
                                        <StackPanel HorizontalAlignment="Center"
                                                    VerticalAlignment="Center" Spacing="12">
                                            <Border Width="80" Height="80" CornerRadius="40"
                                                    HorizontalAlignment="Center"
                                                    Opacity="0.90">
                                                <Border.Background>
                                                    <SolidColorBrush Color="#FF0000"/>
                                                </Border.Background>
                                                <TextBlock Text="▶" FontSize="34"
                                                           FontWeight="Black"
                                                           Foreground="White"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Margin="6,0,0,0"/>
                                            </Border>
                                            <TextBlock Text="▶  Watch Trailer"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="#c9d1d9"
                                                       HorizontalAlignment="Center"/>
                                        </StackPanel>
                                        <!-- YouTube URL bar at bottom -->
                                        <Border VerticalAlignment="Bottom"
                                                Background="#0000008a"
                                                Padding="12,6">
                                            <TextBlock Text="{Binding TrailerUrl}"
                                                       FontSize="10" Foreground="#8b949e"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Screenshots (same row as trailer when trailer is present) -->
                    <Border IsVisible="{Binding HasScreenshots}"
                            Background="#161b22" CornerRadius="10"
                            Padding="20,16" Margin="0,0,0,16">
                        <StackPanel Spacing="14">
                            <TextBlock Text="📸  Screenshots"
                                       Classes="section-header" Margin="0"/>
                            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding Screenshots}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="12"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="8" ClipToBounds="True"
                                                    Width="300" Height="169">
                                                <views:CoverImage
                                                    ImageUrl="{Binding}"
                                                    LetterFontSize="1"
                                                    ImageCornerRadius="8"
                                                    Width="300" Height="169"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>
                </WrapPanel>

            </StackPanel>
        </ScrollViewer>

    </Grid>

    <!-- ── In-app trailer player overlay ──────────────────────────────────── -->
    <!-- Shown when IsTrailerPlayerOpen = true; covers the entire detail view  -->
    <Grid IsVisible="{Binding IsTrailerPlayerOpen}"
          Background="#000000e8"
          ZIndex="100"
          x:Name="TrailerOverlay">

        <Grid RowDefinitions="Auto,*,Auto">

            <!-- Title bar -->
            <Border Grid.Row="0" Background="#161b22" Padding="20,12">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0"
                               Text="{Binding Title, StringFormat='▶  {0}'}"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="White" VerticalAlignment="Center"/>
                    <Button Grid.Column="1"
                            Classes="btn-secondary"
                            Content="✕  Close"
                            Command="{Binding CloseTrailerPlayerCommand}"
                            Padding="14,8"/>
                </Grid>
            </Border>

            <!-- WebView fills the remaining area and plays the YouTube embed URL -->
            <wv:WebView Grid.Row="1"
                        x:Name="TrailerWebView"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Url="{Binding TrailerEmbedUrl}"/>

            <!-- Status bar -->
            <Border Grid.Row="2" Background="#0d1117" Padding="16,8">
                <TextBlock Text="{Binding TrailerUrl}"
                           FontSize="11" Foreground="#8b949e"
                           TextTrimming="CharacterEllipsis"/>
            </Border>

        </Grid>

    </Grid>

    </Panel>
</UserControl>
