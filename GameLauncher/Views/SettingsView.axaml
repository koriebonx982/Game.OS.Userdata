<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GameLauncher.ViewModels"
             x:Class="GameLauncher.Views.SettingsView"
             x:DataType="vm:SettingsViewModel"
             Background="#0d1117">

    <!-- Steam-style two-pane settings layout -->
    <Grid ColumnDefinitions="220,*">

        <!-- ══════════ LEFT: Category navigation ══════════ -->
        <Border Grid.Column="0"
                Background="#0d1117"
                BorderBrush="#21262d"
                BorderThickness="0,0,1,0"
                Padding="0,24,0,24">
            <StackPanel Spacing="0">

                <TextBlock Text="Settings"
                           FontSize="20" FontWeight="Bold"
                           Foreground="White"
                           Margin="16,0,16,20"/>

                <Button Classes="settings-nav-item"
                        Classes.active="{Binding IsAppSection}"
                        HorizontalAlignment="Stretch"
                        Command="{Binding SelectSectionCommand}"
                        CommandParameter="app">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="⚙" FontSize="16" VerticalAlignment="Center"/>
                        <TextBlock Text="App Preferences" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Classes="settings-nav-item"
                        Classes.active="{Binding IsEmulatorSection}"
                        HorizontalAlignment="Stretch"
                        Command="{Binding SelectSectionCommand}"
                        CommandParameter="emulator">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="🎮" FontSize="16" VerticalAlignment="Center"/>
                        <TextBlock Text="Emulator Setup" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Classes="settings-nav-item"
                        Classes.active="{Binding IsPlaytimeSection}"
                        HorizontalAlignment="Stretch"
                        Command="{Binding SelectSectionCommand}"
                        CommandParameter="playtime">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="⏱" FontSize="16" VerticalAlignment="Center"/>
                        <TextBlock Text="Playtime Tracking" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Classes="settings-nav-item"
                        Classes.active="{Binding IsSyncSection}"
                        HorizontalAlignment="Stretch"
                        Command="{Binding SelectSectionCommand}"
                        CommandParameter="sync">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="🔄" FontSize="16" VerticalAlignment="Center"/>
                        <TextBlock Text="Sync &amp; Data" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Classes="settings-nav-item"
                        Classes.active="{Binding IsAccountSection}"
                        HorizontalAlignment="Stretch"
                        Command="{Binding SelectSectionCommand}"
                        CommandParameter="account">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="👤" FontSize="16" VerticalAlignment="Center"/>
                        <TextBlock Text="Account" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Classes="settings-nav-item"
                        Classes.active="{Binding IsCustomiseSection}"
                        HorizontalAlignment="Stretch"
                        Command="{Binding SelectSectionCommand}"
                        CommandParameter="customise">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="🎨" FontSize="16" VerticalAlignment="Center"/>
                        <TextBlock Text="Customise" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Classes="settings-nav-item"
                        Classes.active="{Binding IsDesignSection}"
                        HorizontalAlignment="Stretch"
                        Command="{Binding SelectSectionCommand}"
                        CommandParameter="design">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="🟢" FontSize="16" VerticalAlignment="Center"/>
                        <TextBlock Text="Design" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Classes="settings-nav-item"
                        Classes.active="{Binding IsSystemSection}"
                        HorizontalAlignment="Stretch"
                        Command="{Binding SelectSectionCommand}"
                        CommandParameter="system">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="🖥" FontSize="16" VerticalAlignment="Center"/>
                        <TextBlock Text="System" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Classes="settings-nav-item"
                        Classes.active="{Binding IsNotificationsSection}"
                        HorizontalAlignment="Stretch"
                        Command="{Binding SelectSectionCommand}"
                        CommandParameter="notifications">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="🔔" FontSize="16" VerticalAlignment="Center"/>
                        <TextBlock Text="Notifications" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Classes="settings-nav-item"
                        Classes.active="{Binding IsDeveloperSection}"
                        HorizontalAlignment="Stretch"
                        Command="{Binding SelectSectionCommand}"
                        CommandParameter="developer">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="🛠" FontSize="16" VerticalAlignment="Center"/>
                        <TextBlock Text="Developer" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

            </StackPanel>
        </Border>

        <!-- ══════════ RIGHT: Section content ══════════ -->
        <ScrollViewer Grid.Column="1"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32,28,32,28" Spacing="0">

                <!-- ── App Preferences ── -->
                <StackPanel IsVisible="{Binding IsAppSection}" Spacing="0">

                    <TextBlock Text="App Preferences" Classes="page-title" Margin="0,0,0,4"/>
                    <TextBlock Text="Configure launcher behaviour and startup options."
                               Classes="page-subtitle" Margin="0,0,0,24"/>

                    <Border Background="#13243a"
                            BorderBrush="#1f6feb"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="24,20"
                            Margin="0,0,0,24"
                            IsVisible="{Binding ShowFirstRunSetupBanner}">
                        <StackPanel Spacing="12">
                            <TextBlock Text="First-time setup"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="White"/>
                            <TextBlock Text="This looks like a new Game.OS install. Review your app preferences, emulator paths, quick-menu behavior, and startup apps, then save once to finish setup on this device."
                                       FontSize="12"
                                       Foreground="#c9d1d9"
                                       TextWrapping="Wrap"/>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Classes="btn-secondary"
                                        Content="🎮  Emulator Setup"
                                        Command="{Binding SelectSectionCommand}"
                                        CommandParameter="emulator"/>
                                <Button Classes="btn-secondary"
                                        Content="🖥  System"
                                        Command="{Binding SelectSectionCommand}"
                                        CommandParameter="system"/>
                                <Button Classes="btn-secondary"
                                        Content="🎨  Customise"
                                        Command="{Binding SelectSectionCommand}"
                                        CommandParameter="customise"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Background="#161b22" CornerRadius="10" Padding="24,20" Margin="0,0,0,24">
                        <StackPanel Spacing="16">

                            <!-- Auto-update toggle -->
                            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="Auto-update Games Database on startup"
                                               FontSize="13" Foreground="#e6edf3"/>
                                    <TextBlock Text="Checks for updated game metadata (covers, achievements) each time the launcher starts."
                                               FontSize="11" Foreground="#8b949e" TextWrapping="Wrap"/>
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1"
                                              IsChecked="{Binding AutoUpdate}"
                                              OffContent="" OnContent=""
                                              VerticalAlignment="Center"
                                              Margin="16,0,0,0"/>
                            </Grid>

                            <Rectangle Height="1" Fill="#21262d"/>

                            <!-- Intro video toggle -->
                            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="Show intro video on startup"
                                               FontSize="13" Foreground="#e6edf3"/>
                                    <TextBlock TextWrapping="Wrap"
                                               FontSize="11" Foreground="#8b949e">
                                        Plays a full-screen intro video each time the launcher opens.
                                        Place your video at  Data\Intro\Intro.mp4  inside the Game.OS folder — this matches the PS5 OS reference behaviour.
                                        Disable for a faster startup.
                                    </TextBlock>
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1"
                                              IsChecked="{Binding ShowIntroVideo}"
                                              OffContent="" OnContent=""
                                              VerticalAlignment="Center"
                                              Margin="16,0,0,0"/>
                            </Grid>

                            <!-- Custom intro video override (shown when toggle is on) -->
                            <Grid ColumnDefinitions="*,Auto,Auto" VerticalAlignment="Center"
                                  IsVisible="{Binding ShowIntroVideo}">
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="Custom intro video (optional override)"
                                               FontSize="13" Foreground="#e6edf3"/>
                                    <TextBlock TextWrapping="Wrap"
                                               FontSize="11" Foreground="#8b949e">
                                        Leave blank to use the default  Data\Intro\Intro.mp4  location.
                                        Browse to a different file only if you want to override the default path.
                                    </TextBlock>
                                    <TextBox Classes="form-input"
                                             Text="{Binding IntroVideoPath}"
                                             Watermark="Leave blank to use Data\Intro\Intro.mp4…"
                                             FontSize="11"
                                             Margin="0,4,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Classes="btn-secondary"
                                        Content="Browse…"
                                        FontSize="11"
                                        Padding="8,6"
                                        Margin="16,0,0,0"
                                        VerticalAlignment="Center"
                                        Command="{Binding BrowseIntroVideoCommand}"/>
                                <Button Grid.Column="2"
                                        Classes="btn-secondary"
                                        Content="🎬  Gallery"
                                        FontSize="11"
                                        Padding="8,6"
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Center"
                                        Command="{Binding PickIntroVideoFromGalleryCommand}"/>
                            </Grid>

                            <Rectangle Height="1" Fill="#21262d"/>

                            <!-- Switch log reading toggle -->
                            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="Read Switch game log after session"
                                               FontSize="13" Foreground="#e6edf3"/>
                                    <TextBlock Text="After a Nintendo Switch (Ryujinx) game exits, Game.OS reads the emulator log and shows relevant output in the launcher."
                                               FontSize="11" Foreground="#8b949e" TextWrapping="Wrap"/>
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1"
                                              IsChecked="{Binding ReadSwitchLog}"
                                              OffContent="" OnContent=""
                                              VerticalAlignment="Center"
                                              Margin="16,0,0,0"/>
                            </Grid>

                            <Rectangle Height="1" Fill="#21262d"/>

                            <!-- Minimize on game launch -->
                            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="Minimize on Game Launch"
                                               FontSize="13" Foreground="#e6edf3"/>
                                    <TextBlock Text="Game.OS minimizes to the background when you launch a game and automatically restores to full-screen when the game exits."
                                               FontSize="11" Foreground="#8b949e" TextWrapping="Wrap"/>
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1"
                                              IsChecked="{Binding MinimizeOnGameLaunch}"
                                              OffContent="" OnContent=""
                                              VerticalAlignment="Center"
                                              Margin="16,0,0,0"/>
                            </Grid>

                            <Rectangle Height="1" Fill="#21262d"/>

                            <!-- Track folder processes (mod clients) -->
                            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="Track Mod-Client Processes"
                                               FontSize="13" Foreground="#e6edf3"/>
                                    <TextBlock Text="Watches the game folder for child processes so mod clients (Plutonium, iw4x, Project BO4, etc.) are tracked correctly — even when they launch a separate executable."
                                               FontSize="11" Foreground="#8b949e" TextWrapping="Wrap"/>
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1"
                                              IsChecked="{Binding TrackFolderProcesses}"
                                              OffContent="" OnContent=""
                                              VerticalAlignment="Center"
                                              Margin="16,0,0,0"/>
                            </Grid>

                            <Rectangle Height="1" Fill="#21262d"/>

                            <!-- Local Transfer placeholder -->
                            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="Local Transfer"
                                               FontSize="13" Foreground="#e6edf3"/>
                                    <TextBlock Text="Coming soon — peer-to-peer game file sharing between devices on the same network. This feature is under development."
                                               FontSize="11" Foreground="#8b949e" TextWrapping="Wrap"/>
                                </StackPanel>
                                <Border Background="#21262d" CornerRadius="4" Padding="8,4"
                                        VerticalAlignment="Center" Margin="16,0,0,0">
                                    <TextBlock Text="Soon" FontSize="11" Foreground="#8b949e"/>
                                </Border>
                            </Grid>

                        </StackPanel>
                    </Border>

                    <!-- Save button -->
                    <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,0,0,24">
                        <Button Classes="btn-primary"
                                Content="💾  Save Settings"
                                Command="{Binding SaveCommand}"
                                Width="180"/>
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="#3fb950"
                                   FontSize="13"
                                   VerticalAlignment="Center"
                                   IsVisible="{Binding IsSaveSuccess}"/>
                    </StackPanel>

                </StackPanel>

                <!-- ── Emulator Setup ── -->
                <StackPanel IsVisible="{Binding IsEmulatorSection}" Spacing="0">

                    <TextBlock Text="Emulator Setup" Classes="page-title" Margin="0,0,0,4"/>
                    <TextBlock Text="Set the emulator executable for each platform."
                               Classes="page-subtitle" Margin="0,0,0,24"/>

                    <Border Background="#161b22" CornerRadius="10" Padding="24,20" Margin="0,0,0,24">
                        <StackPanel Spacing="16">

                            <TextBlock Text="Use {rom} in Arguments as the ROM path placeholder. You can add multiple emulators per platform."
                                       FontSize="12" Foreground="#8b949e" Margin="0,0,0,8"/>

                            <!-- Platform groups -->
                            <ItemsControl ItemsSource="{Binding EmulatorGroups}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:EmulatorPlatformGroupVm">
                                        <Border Background="#1c2128" CornerRadius="8"
                                                Padding="12,10" Margin="0,0,0,8">
                                            <StackPanel Spacing="6">

                                                <!-- Platform header row -->
                                                <Grid ColumnDefinitions="Auto,*,Auto">
                                                    <Border Grid.Column="0"
                                                            Background="#1f6feb"
                                                            CornerRadius="4" Padding="8,4"
                                                            HorizontalAlignment="Left"
                                                            VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Platform}"
                                                                   FontSize="11" FontWeight="Bold"
                                                                   Foreground="White"/>
                                                    </Border>
                                                    <StackPanel Grid.Column="1"
                                                                Orientation="Horizontal" Spacing="0"
                                                                Margin="12,0,0,0"/>
                                                    <Button Grid.Column="2"
                                                            Classes="btn-secondary"
                                                            Content="+ Add Emulator"
                                                            FontSize="11"
                                                            Padding="8,4"
                                                            VerticalAlignment="Center"
                                                            Command="{Binding AddEmulatorCommand}"/>
                                                </Grid>

                                                <!-- Column headers -->
                                                <Grid ColumnDefinitions="*,160,80,44,38" Margin="0,4,0,0">
                                                    <TextBlock Grid.Column="0" Text="Emulator Executable"
                                                               FontSize="10" Foreground="#484f58"/>
                                                    <TextBlock Grid.Column="1" Text="Arguments"
                                                               FontSize="10" Foreground="#484f58" Margin="8,0,0,0"/>
                                                    <TextBlock Grid.Column="2" Text="Name"
                                                               FontSize="10" Foreground="#484f58" Margin="4,0,0,0"/>
                                                    <TextBlock Grid.Column="3" Text="On"
                                                               FontSize="10" Foreground="#484f58"
                                                               HorizontalAlignment="Center"/>
                                                </Grid>

                                                <!-- Emulator rows -->
                                                <ItemsControl ItemsSource="{Binding Emulators}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:EmulatorRowVm">
                                                            <Grid ColumnDefinitions="*,160,80,44,38"
                                                                  Margin="0,2,0,2">

                                                                <Grid Grid.Column="0" ColumnDefinitions="*,Auto">
                                                                    <TextBox Grid.Column="0"
                                                                             Classes="form-input"
                                                                             Text="{Binding EmulatorPath}"
                                                                             Watermark="Path to emulator .exe…"
                                                                             FontSize="12"
                                                                             VerticalAlignment="Center"/>
                                                                    <Button Grid.Column="1"
                                                                            Classes="btn-secondary"
                                                                            Content="Browse…"
                                                                            FontSize="11"
                                                                            Padding="8,6"
                                                                            Margin="4,0,0,0"
                                                                            Command="{Binding $parent[UserControl].DataContext.BrowseEmulatorCommand}"
                                                                            CommandParameter="{Binding}"
                                                                            VerticalAlignment="Center"/>
                                                                </Grid>

                                                                <TextBox Grid.Column="1"
                                                                         Classes="form-input"
                                                                         Text="{Binding Arguments}"
                                                                         Watermark="{}{rom}"
                                                                         FontSize="12"
                                                                         Margin="8,0,4,0"
                                                                         VerticalAlignment="Center"/>

                                                                <TextBox Grid.Column="2"
                                                                         Classes="form-input"
                                                                         Text="{Binding EmulatorName}"
                                                                         Watermark="e.g. Ryujinx"
                                                                         FontSize="12"
                                                                         Margin="0,0,4,0"
                                                                         VerticalAlignment="Center"/>

                                                                <CheckBox Grid.Column="3"
                                                                          IsChecked="{Binding Enabled}"
                                                                          HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"/>

                                                                <Button Grid.Column="4"
                                                                        Classes="btn-secondary"
                                                                        Content="✕"
                                                                        FontSize="11"
                                                                        Padding="6,4"
                                                                        Foreground="#f85149"
                                                                        HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center"
                                                                        Command="{Binding $parent[ItemsControl].DataContext.RemoveEmulatorCommand}"
                                                                        CommandParameter="{Binding}"/>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>
                    </Border>

                    <!-- Save button -->
                    <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,0,0,24">
                        <Button Classes="btn-primary"
                                Content="💾  Save Settings"
                                Command="{Binding SaveCommand}"
                                Width="180"/>
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="#3fb950"
                                   FontSize="13"
                                   VerticalAlignment="Center"
                                   IsVisible="{Binding IsSaveSuccess}"/>
                    </StackPanel>

                </StackPanel>

                <!-- ── Playtime Tracking ── -->
                <StackPanel IsVisible="{Binding IsPlaytimeSection}" Spacing="0">

                    <TextBlock Text="Playtime Tracking" Classes="page-title" Margin="0,0,0,4"/>
                    <TextBlock Text="View how Game.OS records your play sessions."
                               Classes="page-subtitle" Margin="0,0,0,24"/>

                    <Border Background="#161b22" CornerRadius="10" Padding="24,20">
                        <StackPanel Spacing="8">
                            <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#8b949e">
                                Game.OS automatically tracks how long you play each game.
                                Sessions are recorded when you launch a game from this launcher and
                                the process exits. Playtime totals appear on game cards and the Home dashboard.
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#8b949e">
                                Data is stored locally at %APPDATA%\Game.OS\Playtime\sessions.json.
                            </TextBlock>
                        </StackPanel>
                    </Border>

                </StackPanel>

                <!-- ── Sync &amp; Data ── -->
                <StackPanel IsVisible="{Binding IsSyncSection}" Spacing="0">

                    <TextBlock Text="Sync &amp; Data" Classes="page-title" Margin="0,0,0,4"/>
                    <TextBlock Text="Manually synchronise your library and achievements with the server."
                               Classes="page-subtitle" Margin="0,0,0,24"/>

                    <Border Background="#161b22" CornerRadius="10" Padding="24,20" Margin="0,0,0,16">
                        <StackPanel Spacing="16">

                            <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#8b949e">
                                Game.OS automatically checks for remote changes every 5 minutes while you're
                                online. Use the button below to trigger an immediate sync at any time.
                            </TextBlock>

                            <TextBlock Text="{Binding LastSyncedLabel}"
                                       FontSize="12" Foreground="#8b949e"/>

                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Button Classes="btn-primary"
                                        Content="🔄  Resync data"
                                        Command="{Binding SyncNowCommand}"
                                        IsEnabled="{Binding !IsSyncing}"
                                        Width="160"/>
                                <TextBlock Text="Syncing…"
                                           FontSize="12" Foreground="#3fb950"
                                           VerticalAlignment="Center"
                                           IsVisible="{Binding IsSyncing}"/>
                            </StackPanel>

                        </StackPanel>
                    </Border>

                </StackPanel>

                <!-- ── Account ── -->
                <StackPanel IsVisible="{Binding IsAccountSection}" Spacing="0">

                    <TextBlock Text="Account" Classes="page-title" Margin="0,0,0,4"/>
                    <TextBlock Text="View your Game.OS account details."
                               Classes="page-subtitle" Margin="0,0,0,24"/>

                    <!-- Account info card -->
                    <Border Background="#161b22" CornerRadius="10" Padding="24,20" Margin="0,0,0,20">
                        <StackPanel Spacing="18">

                            <!-- Avatar + username -->
                            <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,0,0,6">
                                <Border Width="60" Height="60" CornerRadius="30"
                                        Background="#1f6feb">
                                    <TextBlock Text="{Binding AccountAvatarInitial}"
                                               FontSize="26" FontWeight="Bold"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center" Spacing="4">
                                    <TextBlock Text="{Binding AccountUsername}"
                                               FontSize="20" FontWeight="Bold"
                                               Foreground="White"/>
                                    <Border Background="#1f3a6e" CornerRadius="6"
                                            Padding="8,3" HorizontalAlignment="Left">
                                        <TextBlock Text="Game.OS Member"
                                                   FontSize="11" FontWeight="Bold"
                                                   Foreground="#58a6ff"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>

                            <Rectangle Height="1" Fill="#21262d"/>

                            <!-- Email -->
                            <Grid ColumnDefinitions="160,*">
                                <TextBlock Grid.Column="0" Text="Email"
                                           FontSize="13" Foreground="#8b949e"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding AccountEmail}"
                                           FontSize="13" Foreground="#e6edf3"
                                           VerticalAlignment="Center"/>
                            </Grid>

                            <Rectangle Height="1" Fill="#21262d"/>

                            <!-- Member since -->
                            <Grid ColumnDefinitions="160,*">
                                <TextBlock Grid.Column="0" Text="Member Since"
                                           FontSize="13" Foreground="#8b949e"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding AccountMemberSince}"
                                           FontSize="13" Foreground="#e6edf3"
                                           VerticalAlignment="Center"/>
                            </Grid>

                            <Rectangle Height="1" Fill="#21262d"/>

                            <!-- Games -->
                            <Grid ColumnDefinitions="160,*">
                                <TextBlock Grid.Column="0" Text="Games in Library"
                                           FontSize="13" Foreground="#8b949e"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding AccountGamesCount}"
                                           FontSize="13" Foreground="#e6edf3"
                                           VerticalAlignment="Center"/>
                            </Grid>

                        </StackPanel>
                    </Border>

                    <!-- Placeholder actions card -->
                    <Border Background="#161b22" CornerRadius="10" Padding="24,20" Margin="0,0,0,20">
                        <StackPanel Spacing="16">
                            <TextBlock Text="Account Actions"
                                       FontSize="14" FontWeight="Bold"
                                       Foreground="White"/>
                            <TextBlock Text="Account management options will be available here in a future update."
                                       FontSize="12" Foreground="#8b949e"
                                       TextWrapping="Wrap"/>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Button Classes="btn-secondary" IsEnabled="False"
                                        Padding="14,8">
                                    🔑  Change Password
                                </Button>
                                <Button Classes="btn-secondary" IsEnabled="False"
                                        Padding="14,8">
                                    ✉  Change Email
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Steam API key -->
                    <Border Background="#161b22" CornerRadius="10" Padding="24,20" Margin="0,0,0,20">
                        <StackPanel Spacing="14">
                            <TextBlock Text="🎮  Steam Integration"
                                       FontSize="14" FontWeight="Bold" Foreground="White"/>
                            <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#8b949e">
                                Link your Steam account to import your owned game library.
                                All credentials are stored locally on this device only and are never uploaded to the cloud.
                            </TextBlock>

                            <!-- Step 1: API key -->
                            <StackPanel Spacing="6">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="Steam API Key"
                                               FontSize="12" Foreground="#8b949e"
                                               VerticalAlignment="Center"/>
                                    <Button Classes="btn-secondary"
                                            Padding="8,3"
                                            FontSize="11"
                                            Command="{Binding OpenSteamApiKeyPageCommand}"
                                            ToolTip.Tip="Open steamcommunity.com/dev/apikey in your browser">
                                        <TextBlock Text="🔑  Get API Key" FontSize="11"/>
                                    </Button>
                                </StackPanel>
                                <TextBox Classes="form-input"
                                         Text="{Binding SteamApiKey}"
                                         Watermark="Enter your Steam Web API key…"
                                         PasswordChar="•"
                                         FontSize="12"/>
                            </StackPanel>

                            <!-- Step 2: Steam User ID -->
                            <StackPanel Spacing="6">
                                <TextBlock FontSize="12" Foreground="#8b949e">
                                    <Run Text="Steam User ID (SteamID64) — find it on "/>
                                    <Run Text="steamid.io" TextDecorations="Underline" Foreground="#58a6ff"/>
                                    <Run Text=" or in Steam › Profile URL"/>
                                </TextBlock>
                                <TextBox Classes="form-input"
                                         Text="{Binding SteamUserId}"
                                         Watermark="76561198000000000"
                                         FontSize="12"/>
                            </StackPanel>

                            <TextBlock Text="Stored locally only — never sent to Game.OS servers."
                                       FontSize="10" Foreground="#484f58"/>

                            <!-- Save + Import buttons -->
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Button Classes="btn-primary"
                                        Content="💾  Save Settings"
                                        Command="{Binding SaveCommand}"
                                        Width="150" HorizontalAlignment="Left"/>
                                <Button Classes="btn-success"
                                        IsEnabled="{Binding !IsSteamImporting}"
                                        Command="{Binding ImportSteamLibraryCommand}"
                                        Content="{Binding ImportSteamButtonLabel}"
                                        Padding="16,10" HorizontalAlignment="Left"/>
                            </StackPanel>

                            <!-- Import status message -->
                            <TextBlock Text="{Binding SteamImportStatus}"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="#8b949e" TextWrapping="Wrap"
                                       IsVisible="{Binding SteamImportStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                        </StackPanel>
                    </Border>

                    <!-- Exophase integration -->
                    <Border Background="#161b22" CornerRadius="10" Padding="24,20" Margin="0,0,0,20">
                        <StackPanel Spacing="14">
                            <TextBlock Text="🏆  Exophase Integration"
                                       FontSize="14" FontWeight="Bold" Foreground="White"/>
                            <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#8b949e">
                                Link your Exophase profile so Game.OS can track achievement unlocks. On game
                                launch the achievement list is scraped from Exophase and refreshed every 1 minute.
                                Your Profile ID is stored locally only and is never uploaded to the cloud.
                                Note: URL fragments (the #... part) are client-side only; sync requests use this saved profile ID explicitly.
                            </TextBlock>
                             <StackPanel Spacing="6">
                                 <TextBlock Text="Exophase Profile ID"
                                            FontSize="12" Foreground="#8b949e"/>
                                 <TextBox Classes="form-input"
                                          Text="{Binding ExophaseProfileId}"
                                          Watermark="#2896888"
                                          FontSize="12"/>
                                 <TextBlock Text="The unique ID shown in your Exophase URL fragment (e.g. #2896888). Save the numeric ID only."
                                            FontSize="10" Foreground="#484f58"
                                            TextWrapping="Wrap"/>
                             </StackPanel>
                             <Button Classes="btn-primary"
                                     Content="💾  Save Settings"
                                    Command="{Binding SaveCommand}"
                                    Width="180" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Border>

                </StackPanel>

                <!-- ── Customise ── -->
                <StackPanel IsVisible="{Binding IsCustomiseSection}" Spacing="0">

                    <TextBlock Text="Customise" Classes="page-title" Margin="0,0,0,4"/>
                    <TextBlock Text="Adjust launcher interaction and compatibility behaviour."
                               Classes="page-subtitle" Margin="0,0,0,24"/>

                    <Border Background="#161b22" CornerRadius="10" Padding="24,20" Margin="0,0,0,24">
                        <StackPanel Spacing="16">

                            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="Enable global quick menu hotkey"
                                               FontSize="13" Foreground="#e6edf3"/>
                                    <TextBlock Text="Windows only. Polls Left Ctrl + Left Shift globally so the quick menu can be opened while a game window is focused."
                                               FontSize="11" Foreground="#8b949e" TextWrapping="Wrap"/>
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1"
                                              IsChecked="{Binding EnableGlobalQuickMenuHotkey}"
                                              OffContent="" OnContent=""
                                              VerticalAlignment="Center"
                                              Margin="16,0,0,0"/>
                            </Grid>

                            <Rectangle Height="1" Fill="#21262d"/>

                            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="Compatibility overlay mode (legacy)"
                                               FontSize="13" Foreground="#e6edf3"/>
                                    <TextBlock Text="Uses the older focus-stealing quick-menu overlay. Leave this off for fullscreen games; turn it on only if the passive overlay does not appear on your system."
                                               FontSize="11" Foreground="#8b949e" TextWrapping="Wrap"/>
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1"
                                              IsChecked="{Binding CompatibilityOverlayMode}"
                                              OffContent="" OnContent=""
                                              VerticalAlignment="Center"
                                              Margin="16,0,0,0"/>
                            </Grid>

                            <Rectangle Height="1" Fill="#21262d"/>

                            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="Prefer cached metadata for local games"
                                               FontSize="13" Foreground="#e6edf3"/>
                                    <TextBlock Text="Uses cached covers, game info, and achievements first for installed games so pages stay responsive and continue to work offline."
                                               FontSize="11" Foreground="#8b949e" TextWrapping="Wrap"/>
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1"
                                              IsChecked="{Binding PreferOfflineCachedMetadata}"
                                              OffContent="" OnContent=""
                                              VerticalAlignment="Center"
                                              Margin="16,0,0,0"/>
                            </Grid>

                        </StackPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,0,0,24">
                        <Button Classes="btn-primary"
                                Content="💾  Save Settings"
                                Command="{Binding SaveCommand}"
                                Width="180"/>
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="#3fb950"
                                   FontSize="13"
                                   VerticalAlignment="Center"
                                   IsVisible="{Binding IsSaveSuccess}"/>
                    </StackPanel>

                </StackPanel>

                <!-- ── Design ── -->
                <StackPanel IsVisible="{Binding IsDesignSection}" Spacing="0">

                    <TextBlock Text="Design" Classes="page-title" Margin="0,0,0,4"/>
                    <TextBlock Text="Choose the launcher theme."
                               Classes="page-subtitle" Margin="0,0,0,24"/>

                    <Border Background="#161b22" CornerRadius="10" Padding="24,20" Margin="0,0,0,24">
                        <StackPanel Spacing="16">

                            <StackPanel Spacing="6">
                                <TextBlock Text="Theme"
                                           FontSize="13" Foreground="#e6edf3"/>
                                <ComboBox Classes="form-input"
                                          ItemsSource="{Binding AvailableDesignThemes}"
                                          SelectedItem="{Binding DesignTheme}"
                                          Width="220"/>
                                <TextBlock Text="Default uses the standard Game.OS dashboard style. XB360 applies an Xbox 360 inspired dashboard look."
                                           FontSize="11" Foreground="#8b949e" TextWrapping="Wrap"/>
                            </StackPanel>

                            <StackPanel Spacing="6">
                                <TextBlock Text="Quick Menu Style"
                                           FontSize="13" Foreground="#e6edf3"/>
                                <ComboBox Classes="form-input"
                                          ItemsSource="{Binding AvailableQuickMenuThemes}"
                                          SelectedItem="{Binding QuickMenuTheme}"
                                          Width="220"/>
                                <TextBlock Text="PS5 shows the PlayStation-style quick menu. XB360 shows Xbox 360 style. GameOS uses the default style."
                                           FontSize="11" Foreground="#8b949e" TextWrapping="Wrap"/>
                            </StackPanel>

                        </StackPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,0,0,24">
                        <Button Classes="btn-primary"
                                Content="💾  Save Settings"
                                Command="{Binding SaveCommand}"
                                Width="180"/>
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="#3fb950"
                                   FontSize="13"
                                   VerticalAlignment="Center"
                                   IsVisible="{Binding IsSaveSuccess}"/>
                    </StackPanel>

                </StackPanel>

                <!-- ── System ── -->
                <StackPanel IsVisible="{Binding IsSystemSection}" Spacing="0">

                    <TextBlock Text="System" Classes="page-title" Margin="0,0,0,4"/>
                    <TextBlock Text="Configure apps to launch automatically when Game.OS starts and you log in."
                               Classes="page-subtitle" Margin="0,0,0,24"/>

                    <!-- Startup apps list -->
                    <Border Background="#161b22" CornerRadius="10" Padding="24,20" Margin="0,0,0,16">
                        <StackPanel Spacing="16">

                            <TextBlock Text="🚀  Startup Apps"
                                       FontSize="14" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="These apps launch automatically after you log in. Enable the ones you want. You can customise the path for each preset or add your own."
                                       FontSize="12" Foreground="#8b949e" TextWrapping="Wrap"/>

                            <!-- Startup app rows -->
                            <ItemsControl ItemsSource="{Binding StartupApps}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:StartupAppRowVm">
                                        <Border Background="#1c2128" CornerRadius="8"
                                                Padding="14,10" Margin="0,0,0,6">
                                            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto">

                                                <!-- Enable toggle -->
                                                <ToggleSwitch Grid.Column="0"
                                                              IsChecked="{Binding Enabled}"
                                                              OffContent="" OnContent=""
                                                              VerticalAlignment="Center"
                                                              Margin="0,0,12,0"/>

                                                <!-- Path + label -->
                                                <StackPanel Grid.Column="1" Spacing="4"
                                                            VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Label}"
                                                               FontSize="13" FontWeight="SemiBold"
                                                               Foreground="White"/>
                                                    <Grid ColumnDefinitions="*,Auto">
                                                        <TextBox Grid.Column="0"
                                                                 Text="{Binding Path}"
                                                                 Watermark="Path to executable…"
                                                                 Background="#0d1117" Foreground="White"
                                                                 BorderBrush="#30363d" CornerRadius="6"
                                                                 Padding="8,5" FontSize="11"/>
                                                        <Button Grid.Column="1"
                                                                Classes="btn-secondary"
                                                                Content="Browse…"
                                                                FontSize="11" Padding="8,5"
                                                                Margin="4,0,0,0"
                                                                VerticalAlignment="Center"
                                                                Command="{Binding $parent[UserControl].DataContext.BrowseStartupAppCommand}"
                                                                CommandParameter="{Binding}"/>
                                                    </Grid>
                                                    <TextBox Text="{Binding Arguments}"
                                                             Watermark="Arguments (optional)"
                                                             Background="#0d1117" Foreground="White"
                                                             BorderBrush="#30363d" CornerRadius="6"
                                                             Padding="8,5" FontSize="11"/>
                                                </StackPanel>

                                                <!-- Move Up -->
                                                <Button Grid.Column="2"
                                                        Classes="btn-secondary"
                                                        Content="▲" FontSize="11"
                                                        Padding="7,5" Margin="8,0,0,0"
                                                        VerticalAlignment="Center"
                                                        Command="{Binding $parent[UserControl].DataContext.MoveStartupAppUpCommand}"
                                                        CommandParameter="{Binding}"/>

                                                <!-- Move Down -->
                                                <Button Grid.Column="3"
                                                        Classes="btn-secondary"
                                                        Content="▼" FontSize="11"
                                                        Padding="7,5" Margin="4,0,0,0"
                                                        VerticalAlignment="Center"
                                                        Command="{Binding $parent[UserControl].DataContext.MoveStartupAppDownCommand}"
                                                        CommandParameter="{Binding}"/>

                                                <!-- Preset badge / Remove button -->
                                                <Border Grid.Column="4"
                                                        Background="#1f3a6e" CornerRadius="4"
                                                        Padding="6,3" Margin="8,0,0,0"
                                                        VerticalAlignment="Center"
                                                        IsVisible="{Binding IsPreset}">
                                                    <TextBlock Text="preset" FontSize="10"
                                                               Foreground="#58a6ff" FontWeight="Bold"/>
                                                </Border>
                                                <Button Grid.Column="5"
                                                        Classes="btn-secondary"
                                                        Content="✕" FontSize="11"
                                                        Padding="7,5" Margin="4,0,0,0"
                                                        Foreground="#f85149"
                                                        VerticalAlignment="Center"
                                                        IsVisible="{Binding !IsPreset}"
                                                        Command="{Binding $parent[UserControl].DataContext.RemoveStartupAppCommand}"
                                                        CommandParameter="{Binding}"/>

                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>
                    </Border>

                    <!-- Add custom startup app -->
                    <Border Background="#161b22" CornerRadius="10" Padding="24,20" Margin="0,0,0,24">
                        <StackPanel Spacing="12">
                            <TextBlock Text="+ Add Custom App"
                                       FontSize="14" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="Add any app, script, or tool that should run at startup."
                                       FontSize="12" Foreground="#8b949e"/>

                            <Grid ColumnDefinitions="*,Auto">
                                <TextBox Grid.Column="0"
                                         Text="{Binding NewStartupAppPath}"
                                         Watermark="Path to executable or script…"
                                         Background="#0d1117" Foreground="White"
                                         BorderBrush="#30363d" CornerRadius="6"
                                         Padding="10,8" FontSize="12"/>
                                <Button Grid.Column="1"
                                        Classes="btn-secondary"
                                        Content="Browse…"
                                        FontSize="11" Padding="10,8"
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Center"
                                        Command="{Binding BrowseNewStartupAppCommand}"/>
                            </Grid>
                            <Grid ColumnDefinitions="*,*">
                                <TextBox Grid.Column="0"
                                         Text="{Binding NewStartupAppArgs}"
                                         Watermark="Arguments (optional)"
                                         Background="#0d1117" Foreground="White"
                                         BorderBrush="#30363d" CornerRadius="6"
                                         Padding="10,8" FontSize="12"
                                         Margin="0,0,4,0"/>
                                <TextBox Grid.Column="1"
                                         Text="{Binding NewStartupAppLabel}"
                                         Watermark="Label (e.g. My VPN)"
                                         Background="#0d1117" Foreground="White"
                                         BorderBrush="#30363d" CornerRadius="6"
                                         Padding="10,8" FontSize="12"
                                         Margin="4,0,0,0"/>
                            </Grid>
                            <Button Classes="btn-secondary" Padding="14,8"
                                    HorizontalAlignment="Left"
                                    Command="{Binding AddStartupAppCommand}">
                                + Add Startup App
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Save button -->
                    <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,0,0,24">
                        <Button Classes="btn-primary"
                                Content="💾  Save Settings"
                                Command="{Binding SaveCommand}"
                                Width="180"/>
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="#3fb950"
                                   FontSize="13"
                                   VerticalAlignment="Center"
                                   IsVisible="{Binding IsSaveSuccess}"/>
                    </StackPanel>

                </StackPanel>

                <!-- ── Notifications ── -->
                <StackPanel IsVisible="{Binding IsNotificationsSection}" Spacing="0">

                    <TextBlock Text="Notifications" Classes="page-title" Margin="0,0,0,4"/>
                    <TextBlock Text="Control which game and friend events trigger desktop notifications."
                               Classes="page-subtitle" Margin="0,0,0,24"/>

                    <!-- Friend notifications -->
                    <Border Background="#161b22" CornerRadius="10" Padding="24,20" Margin="0,0,0,24">
                        <StackPanel Spacing="16">
                            <TextBlock Text="👥  Friend Activity"
                                       FontSize="14" FontWeight="Bold" Foreground="White"/>

                            <!-- Notify when friend comes online -->
                            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="Notify when a friend comes online"
                                               FontSize="13" Foreground="#e6edf3"/>
                                    <TextBlock Text="Shows a toast notification when one of your friends logs in to Game.OS."
                                               FontSize="11" Foreground="#8b949e" TextWrapping="Wrap"/>
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1"
                                              IsChecked="{Binding NotifyFriendOnline}"
                                              OffContent="" OnContent=""
                                              VerticalAlignment="Center"
                                              Margin="16,0,0,0"/>
                            </Grid>

                            <Rectangle Height="1" Fill="#21262d"/>

                            <!-- Notify when friend starts a game -->
                            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="Notify when a friend starts playing a game"
                                               FontSize="13" Foreground="#e6edf3"/>
                                    <TextBlock Text="Shows a toast notification when a friend launches a game on Game.OS."
                                               FontSize="11" Foreground="#8b949e" TextWrapping="Wrap"/>
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1"
                                              IsChecked="{Binding NotifyFriendGameStart}"
                                              OffContent="" OnContent=""
                                              VerticalAlignment="Center"
                                              Margin="16,0,0,0"/>
                            </Grid>

                        </StackPanel>
                    </Border>

                    <!-- Broadcast settings -->
                    <Border Background="#161b22" CornerRadius="10" Padding="24,20" Margin="0,0,0,24">
                        <StackPanel Spacing="16">
                            <TextBlock Text="📡  Broadcast to Friends"
                                       FontSize="14" FontWeight="Bold" Foreground="White"/>

                            <!-- Broadcast when user comes online -->
                            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="Broadcast when I come online"
                                               FontSize="13" Foreground="#e6edf3"/>
                                    <TextBlock Text="Updates your presence immediately when you log in so friends see you as Online straight away."
                                               FontSize="11" Foreground="#8b949e" TextWrapping="Wrap"/>
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1"
                                              IsChecked="{Binding BroadcastUserOnline}"
                                              OffContent="" OnContent=""
                                              VerticalAlignment="Center"
                                              Margin="16,0,0,0"/>
                            </Grid>

                            <Rectangle Height="1" Fill="#21262d"/>

                            <!-- Broadcast when user starts a game -->
                            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="Broadcast when I start playing a game"
                                               FontSize="13" Foreground="#e6edf3"/>
                                    <TextBlock Text="Sends a presence update with the game title when you launch a game so friends can see what you're playing."
                                               FontSize="11" Foreground="#8b949e" TextWrapping="Wrap"/>
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1"
                                              IsChecked="{Binding BroadcastGameStart}"
                                              OffContent="" OnContent=""
                                              VerticalAlignment="Center"
                                              Margin="16,0,0,0"/>
                            </Grid>

                        </StackPanel>
                    </Border>

                    <!-- Save button -->
                    <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,0,0,24">
                        <Button Classes="btn-primary"
                                Content="💾  Save Settings"
                                Command="{Binding SaveCommand}"
                                Width="180"/>
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="#3fb950"
                                   FontSize="13"
                                   VerticalAlignment="Center"
                                   IsVisible="{Binding IsSaveSuccess}"/>
                    </StackPanel>

                </StackPanel>

                <!-- ── Developer Section ── -->
                <StackPanel IsVisible="{Binding IsDeveloperSection}" Spacing="0">

                    <TextBlock Text="Developer" Classes="page-title" Margin="0,0,0,4"/>
                    <TextBlock Text="Testing tools and feature flags for development."
                               Classes="page-subtitle" Margin="0,0,0,24"/>

                    <!-- Test Toast Notifications card -->
                    <Border Background="#161b22" CornerRadius="10" Padding="24,20" Margin="0,0,0,24">
                        <StackPanel Spacing="16">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="🔔" FontSize="18" VerticalAlignment="Center"/>
                                <TextBlock Text="Test Toast Notifications"
                                           FontSize="15" FontWeight="Bold"
                                           Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="Fires one of each notification type with dummy data so you can verify they appear correctly."
                                       FontSize="12" Foreground="#8b949e" TextWrapping="Wrap"/>
                            <Button Classes="btn-secondary" Padding="16,10"
                                    HorizontalAlignment="Left"
                                    Command="{Binding TestToastNotificationsCommand}">
                                <TextBlock Text="🔔  Fire Test Notifications" FontSize="13" FontWeight="SemiBold"/>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Dev.log toggle card -->
                    <Border Background="#161b22" CornerRadius="10" Padding="24,20" Margin="0,0,0,24">
                        <StackPanel Spacing="16">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="📋" FontSize="18" VerticalAlignment="Center"/>
                                <TextBlock Text="Dev.log"
                                           FontSize="15" FontWeight="Bold"
                                           Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="Write debug output to Dev.log"
                                               FontSize="13" Foreground="#e6edf3"/>
                                    <TextBlock Text="Logs debug messages and unhandled exceptions to a Dev.log file next to the executable."
                                               FontSize="11" Foreground="#8b949e" TextWrapping="Wrap"/>
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1"
                                              IsChecked="{Binding DevLogs}"
                                              OffContent="" OnContent=""
                                              VerticalAlignment="Center"
                                              Margin="16,0,0,0"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Scanner Logging card -->
                    <Border Background="#161b22" CornerRadius="10" Padding="24,20" Margin="0,0,0,24">
                        <StackPanel Spacing="16">

                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="🔍" FontSize="18" VerticalAlignment="Center"/>
                                <TextBlock Text="Scanner Logging"
                                           FontSize="15" FontWeight="Bold"
                                           Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="Enable per-scanner verbose output in Dev.log to diagnose missing games, ROMs, or repacks. Requires Dev.log to be on."
                                       FontSize="11" Foreground="#8b949e" TextWrapping="Wrap"/>

                            <Rectangle Height="1" Fill="#21262d"/>

                            <!-- Games Scanner -->
                            <Grid ColumnDefinitions="*,Auto,Auto" VerticalAlignment="Center">
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="Games Scanner"
                                               FontSize="13" Foreground="#e6edf3"/>
                                    <TextBlock Text="Logs per-drive Games folder summary: total folders, archives, and combined count."
                                               FontSize="11" Foreground="#8b949e" TextWrapping="Wrap"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="Advanced"
                                           FontSize="11" Foreground="#8b949e"
                                           VerticalAlignment="Center" Margin="12,0,4,0"
                                           IsVisible="{Binding LogGamesScanner}"/>
                                <ToggleSwitch Grid.Column="1"
                                             IsChecked="{Binding LogGamesScannerAdvanced}"
                                             OffContent="" OnContent=""
                                             VerticalAlignment="Center"
                                             Margin="0,0,8,0"
                                             IsVisible="{Binding LogGamesScanner}"
                                             ToolTip.Tip="Also print every game title found on each drive"/>
                                <ToggleSwitch Grid.Column="2"
                                             IsChecked="{Binding LogGamesScanner}"
                                             OffContent="" OnContent=""
                                             VerticalAlignment="Center"
                                             Margin="16,0,0,0"/>
                            </Grid>

                            <Rectangle Height="1" Fill="#21262d"/>

                            <!-- ROMs Scanner -->
                            <Grid ColumnDefinitions="*,Auto,Auto" VerticalAlignment="Center">
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="ROMs Scanner"
                                               FontSize="13" Foreground="#e6edf3"/>
                                    <TextBlock Text="Logs per-drive, per-platform ROM summary and grand total."
                                               FontSize="11" Foreground="#8b949e" TextWrapping="Wrap"/>
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1"
                                             IsChecked="{Binding LogRomsScannerAdvanced}"
                                             OffContent="" OnContent=""
                                             VerticalAlignment="Center"
                                             Margin="0,0,8,0"
                                             IsVisible="{Binding LogRomsScanner}"
                                             ToolTip.Tip="Also print every ROM title found on each drive"/>
                                <ToggleSwitch Grid.Column="2"
                                             IsChecked="{Binding LogRomsScanner}"
                                             OffContent="" OnContent=""
                                             VerticalAlignment="Center"
                                             Margin="16,0,0,0"/>
                            </Grid>

                            <Rectangle Height="1" Fill="#21262d"/>

                            <!-- Repacks Scanner -->
                            <Grid ColumnDefinitions="*,Auto,Auto" VerticalAlignment="Center">
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="Repacks Scanner"
                                               FontSize="13" Foreground="#e6edf3"/>
                                    <TextBlock Text="Logs per-drive Repacks folder summary: total folders and archive files found."
                                               FontSize="11" Foreground="#8b949e" TextWrapping="Wrap"/>
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1"
                                             IsChecked="{Binding LogRepacksScannerAdvanced}"
                                             OffContent="" OnContent=""
                                             VerticalAlignment="Center"
                                             Margin="0,0,8,0"
                                             IsVisible="{Binding LogRepacksScanner}"
                                             ToolTip.Tip="Also print every repack title found on each drive"/>
                                <ToggleSwitch Grid.Column="2"
                                             IsChecked="{Binding LogRepacksScanner}"
                                             OffContent="" OnContent=""
                                             VerticalAlignment="Center"
                                             Margin="16,0,0,0"/>
                            </Grid>

                            <Rectangle Height="1" Fill="#21262d"/>

                            <!-- Local Steam Scanner -->
                            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="Local Steam Scanner"
                                               FontSize="13" Foreground="#e6edf3"/>
                                    <TextBlock Text="Logs each Steam library path scanned (ACF manifests + common folder)."
                                               FontSize="11" Foreground="#8b949e" TextWrapping="Wrap"/>
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1"
                                             IsChecked="{Binding LogLocalSteamScanner}"
                                             OffContent="" OnContent=""
                                             VerticalAlignment="Center"
                                             Margin="16,0,0,0"/>
                            </Grid>

                            <Rectangle Height="1" Fill="#21262d"/>

                            <!-- Steam API Scanner -->
                            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="Steam API Scanner"
                                               FontSize="13" Foreground="#e6edf3"/>
                                    <TextBlock Text="Logs Steam Web API import requests and results."
                                               FontSize="11" Foreground="#8b949e" TextWrapping="Wrap"/>
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1"
                                             IsChecked="{Binding LogSteamApiScanner}"
                                             OffContent="" OnContent=""
                                             VerticalAlignment="Center"
                                             Margin="16,0,0,0"/>
                            </Grid>

                        </StackPanel>
                    </Border>

                    <!-- Feature Flags card -->
                    <Border Background="#161b22" CornerRadius="10" Padding="24,20" Margin="0,0,0,24">
                        <StackPanel Spacing="16">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="🚩" FontSize="18" VerticalAlignment="Center"/>
                                <TextBlock Text="Feature Flags"
                                           FontSize="15" FontWeight="Bold"
                                           Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>

                            <Rectangle Height="1" Fill="#21262d"/>

                            <!-- Steam Sync -->
                            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="Steam playtime sync"
                                               FontSize="13" Foreground="#e6edf3"/>
                                    <TextBlock Text="After each Steam library import, merge Steam playtime into Game.OS (takes the maximum of local and Steam values)."
                                               FontSize="11" Foreground="#8b949e" TextWrapping="Wrap"/>
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1"
                                              IsChecked="{Binding EnableSteamSync}"
                                              OffContent="" OnContent=""
                                              VerticalAlignment="Center"
                                              Margin="16,0,0,0"/>
                            </Grid>

                            <Rectangle Height="1" Fill="#21262d"/>

                            <!-- Achievement Auto-Sync -->
                            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="Achievement auto-sync"
                                               FontSize="13" Foreground="#e6edf3"/>
                                    <TextBlock Text="Automatically record and sync achievement unlocks detected from Xenia / Ryujinx log files."
                                               FontSize="11" Foreground="#8b949e" TextWrapping="Wrap"/>
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1"
                                              IsChecked="{Binding EnableAchievementAutoSync}"
                                              OffContent="" OnContent=""
                                              VerticalAlignment="Center"
                                              Margin="16,0,0,0"/>
                            </Grid>

                            <Rectangle Height="1" Fill="#21262d"/>

                            <!-- Ryujinx log status toasts -->
                            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="Ryujinx log status toasts"
                                               FontSize="13" Foreground="#e6edf3"/>
                                    <TextBlock Text="Show developer notifications such as 'Ryujinx log found' and 'Reading log' during Switch achievement polling."
                                               FontSize="11" Foreground="#8b949e" TextWrapping="Wrap"/>
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1"
                                              IsChecked="{Binding NotifyRyujinxLogStatus}"
                                              OffContent="" OnContent=""
                                              VerticalAlignment="Center"
                                              Margin="16,0,0,0"/>
                            </Grid>

                        </StackPanel>
                    </Border>

                    <!-- Save button -->
                    <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,0,0,24">
                        <Button Classes="btn-primary"
                                Content="💾  Save Settings"
                                Command="{Binding SaveCommand}"
                                Width="180"/>
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="#3fb950"
                                   FontSize="13"
                                   VerticalAlignment="Center"
                                   IsVisible="{Binding IsSaveSuccess}"/>
                    </StackPanel>

                </StackPanel>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</UserControl>
