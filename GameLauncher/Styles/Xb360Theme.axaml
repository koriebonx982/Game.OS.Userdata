<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Xbox 360 (Kinect dashboard inspired) override theme -->
    <Styles.Resources>
        <Thickness x:Key="Xb360StatTilePadding">24,22</Thickness>
        <x:Double x:Key="Xb360StatTileMinWidth">190</x:Double>
        <x:Double x:Key="Xb360StatTileMinHeight">126</x:Double>
        <x:Double x:Key="Xb360GameCardTileWidth">212</x:Double>
        <Thickness x:Key="Xb360GameCardTileMargin">0,0,14,14</Thickness>
        <Thickness x:Key="Xb360BladeTabMargin">0,0,8,0</Thickness>
    </Styles.Resources>

    <Style Selector="Window.main-window-shell">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#09130c" Offset="0"/>
                    <GradientStop Color="#040a06" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>

    <Style Selector="Border.main-content-surface">
        <Setter Property="Background" Value="#08120c"/>
    </Style>

    <Style Selector="Border.detail-overlay-surface">
        <Setter Property="Background" Value="#07110b"/>
    </Style>

    <Style Selector="Border.friend-profile-topbar">
        <Setter Property="Background" Value="#0f2417"/>
        <Setter Property="BorderBrush" Value="#3f8e54"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
    </Style>

    <Style Selector="Border.sync-overlay-panel">
        <Setter Property="Background" Value="#10291a"/>
        <Setter Property="BorderBrush" Value="#5fce7d"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style Selector="UserControl.dashboard-root">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#061109" Offset="0"/>
                    <GradientStop Color="#040b06" Offset="0.55"/>
                    <GradientStop Color="#020704" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>

    <Style Selector="Border.dashboard-xb360-layout">
        <Setter Property="IsVisible" Value="True"/>
    </Style>

    <Style Selector="StackPanel.dashboard-default-layout">
        <Setter Property="IsVisible" Value="False"/>
    </Style>

    <Style Selector="Border.xb360-avatar-tile">
        <Setter Property="Background" Value="#2a7f3a"/>
        <Setter Property="Width" Value="52"/>
        <Setter Property="Height" Value="52"/>
    </Style>

    <Style Selector="TextBlock.xb360-header-title">
        <Setter Property="FontSize" Value="28"/>
        <Setter Property="Foreground" Value="#edffe2"/>
        <Setter Property="FontWeight" Value="Light"/>
    </Style>

    <Style Selector="TextBlock.xb360-header-subtitle">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="#9cc79f"/>
    </Style>

    <Style Selector="StackPanel.xb360-blade-tabs">
        <Setter Property="Background" Value="#0d2316"/>
    </Style>

    <Style Selector="TextBlock.xb360-blade-tab">
        <Setter Property="Margin" Value="{StaticResource Xb360BladeTabMargin}"/>
        <Setter Property="Foreground" Value="#96b899"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="Padding" Value="18,9"/>
    </Style>

    <Style Selector="TextBlock.xb360-blade-tab-active">
        <Setter Property="Background" Value="#2b7f3c"/>
        <Setter Property="Foreground" Value="#f2ffea"/>
    </Style>

    <Style Selector="Border.xb360-metro-tile">
        <Setter Property="Background" Value="#135328"/>
        <Setter Property="BorderBrush" Value="#68c26f"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="0"/>
    </Style>

    <Style Selector="Border.xb360-metro-stat">
        <Setter Property="Height" Value="120"/>
        <Setter Property="Padding" Value="16"/>
    </Style>

    <Style Selector="TextBlock.xb360-metro-label">
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="Foreground" Value="#b7dfb8"/>
    </Style>

    <Style Selector="TextBlock.xb360-metro-value">
        <Setter Property="FontSize" Value="40"/>
        <Setter Property="Foreground" Value="#f2ffe8"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <Style Selector="Border.xb360-featured-tile">
        <Setter Property="Height" Value="260"/>
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#1a6633" Offset="0"/>
                    <GradientStop Color="#0f421f" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>

    <Style Selector="TextBlock.xb360-featured-badge">
        <Setter Property="Foreground" Value="#d8ffd7"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style Selector="TextBlock.xb360-featured-title">
        <Setter Property="FontSize" Value="36"/>
        <Setter Property="Foreground" Value="#f7fff0"/>
        <Setter Property="FontWeight" Value="Light"/>
    </Style>

    <Style Selector="TextBlock.xb360-featured-subtitle">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Foreground" Value="#b5d5b7"/>
    </Style>

    <Style Selector="Button.xb360-featured-button">
        <Setter Property="FontSize" Value="17"/>
        <Setter Property="Padding" Value="14,8"/>
    </Style>

    <Style Selector="Border.xb360-featured-cover">
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="#79cb77"/>
    </Style>

    <Style Selector="TextBlock.xb360-strip-header">
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="FontWeight" Value="Light"/>
        <Setter Property="Foreground" Value="#e7ffe2"/>
        <Setter Property="Margin" Value="0,4,0,8"/>
    </Style>

    <Style Selector="Button.xb360-recent-card-btn">
        <Setter Property="Width" Value="170"/>
        <Setter Property="Margin" Value="0,0,8,8"/>
    </Style>

    <Style Selector="TextBlock.xb360-recent-title">
        <Setter Property="Foreground" Value="#f0ffe8"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="MaxLines" Value="2"/>
    </Style>

    <Style Selector="TextBlock.xb360-recent-platform">
        <Setter Property="Foreground" Value="#9fd0a1"/>
        <Setter Property="FontSize" Value="11"/>
    </Style>

    <Style Selector="Border.xb360-achievement-tile">
        <Setter Property="Padding" Value="2"/>
    </Style>

    <Style Selector="Border.xb360-achievement-icon">
        <Setter Property="Background" Value="#2b7f3a"/>
        <Setter Property="Width" Value="38"/>
        <Setter Property="Height" Value="38"/>
        <Setter Property="VerticalAlignment" Value="Top"/>
    </Style>

    <Style Selector="TextBlock.xb360-achievement-title">
        <Setter Property="Foreground" Value="#efffe7"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="MaxLines" Value="1"/>
    </Style>

    <Style Selector="TextBlock.xb360-achievement-desc">
        <Setter Property="Foreground" Value="#a9cba9"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="MaxLines" Value="2"/>
    </Style>

    <Style Selector="TextBlock.xb360-achievement-meta">
        <Setter Property="Foreground" Value="#8eb28f"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="MaxLines" Value="1"/>
    </Style>

    <Style Selector="TextBlock.page-title">
        <Setter Property="FontSize" Value="34"/>
        <Setter Property="Foreground" Value="#f6ffef"/>
    </Style>

    <Style Selector="TextBlock.page-subtitle">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="Foreground" Value="#9fbd9e"/>
    </Style>

    <Style Selector="TextBlock.section-header">
        <Setter Property="Foreground" Value="#dcf9d2"/>
    </Style>

    <Style Selector="Border.featured-hero-banner">
        <Setter Property="CornerRadius" Value="0"/>
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#1e512f" Offset="0"/>
                    <GradientStop Color="#0f2e1c" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderBrush" Value="#76d747"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style Selector="Border.hero-feature-badge">
        <Setter Property="CornerRadius" Value="0"/>
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#b7f06d" Offset="0"/>
                    <GradientStop Color="#69c839" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>

    <Style Selector="Border.hero-platform-badge">
        <Setter Property="CornerRadius" Value="0"/>
        <Setter Property="Background" Value="#163d27"/>
        <Setter Property="BorderBrush" Value="#60c87c"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style Selector="TextBlock.hero-platform-badge-text">
        <Setter Property="Foreground" Value="#b6ff91"/>
    </Style>

    <Style Selector="Border.game-platform-pill">
        <Setter Property="Background" Value="#68c53d"/>
        <Setter Property="CornerRadius" Value="0"/>
    </Style>

    <Style Selector="TextBlock.stat-number-achievements">
        <Setter Property="Foreground" Value="#b6ff73"/>
    </Style>

    <Style Selector="TextBlock.stat-number-platforms">
        <Setter Property="Foreground" Value="#88e97e"/>
    </Style>

    <Style Selector="TextBlock.stat-number-playtime">
        <Setter Property="Foreground" Value="#8fe1ff"/>
    </Style>

    <Style Selector="TextBlock.achievement-meta">
        <Setter Property="Foreground" Value="#acd8aa"/>
    </Style>

    <Style Selector="TextBlock.achievement-divider">
        <Setter Property="Foreground" Value="#3b7a4c"/>
    </Style>

    <Style Selector="TextBlock.empty-state-title">
        <Setter Property="Foreground" Value="#b7d4b5"/>
    </Style>

    <Style Selector="TextBlock.empty-state-subtitle">
        <Setter Property="Foreground" Value="#7aa57e"/>
    </Style>

    <Style Selector="TextBlock.game-playtime-meta">
        <Setter Property="Foreground" Value="#9af069"/>
    </Style>

    <Style Selector="Border.empty-state-card">
        <Setter Property="Background" Value="#10291a"/>
        <Setter Property="BorderBrush" Value="#3a8d53"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="0"/>
    </Style>

    <Style Selector="Border.achievement-icon-card">
        <Setter Property="Background" Value="#2d4d15"/>
    </Style>

    <Style Selector="Border.nav-sidebar">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#0e2c17" Offset="0"/>
                    <GradientStop Color="#081d10" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>

    <Style Selector="Border.nav-logo-area">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#bdf06d" Offset="0"/>
                    <GradientStop Color="#66c935" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderBrush" Value="#d8ff9d"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
    </Style>

    <Style Selector="TextBlock.nav-logo-text">
        <Setter Property="Foreground" Value="#0d2714"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <Style Selector="Button.nav-item">
        <Setter Property="Foreground" Value="#dff8dc"/>
        <Setter Property="CornerRadius" Value="0"/>
        <Setter Property="Margin" Value="0,1"/>
        <Setter Property="Padding" Value="20,16"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="#1f5a33"/>
    </Style>

    <Style Selector="Button.nav-item /template/ ContentPresenter">
        <Setter Property="Background" Value="#123521"/>
        <Setter Property="CornerRadius" Value="0"/>
    </Style>

    <Style Selector="Button.nav-item:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#1f6a39"/>
    </Style>

    <Style Selector="Button.nav-item.active /template/ ContentPresenter">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#9eee58" Offset="0"/>
                    <GradientStop Color="#64c938" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>

    <Style Selector="Button.nav-item.active">
        <Setter Property="Foreground" Value="#0f2414"/>
        <Setter Property="BorderBrush" Value="#c7ff7d"/>
    </Style>

    <Style Selector="TextBlock.page-title">
        <Setter Property="Foreground" Value="#edffe0"/>
    </Style>

    <Style Selector="TextBlock.page-subtitle">
        <Setter Property="Foreground" Value="#9ec2a3"/>
    </Style>

    <Style Selector="Border.stat-tile">
        <Setter Property="Background" Value="#102a1b"/>
        <Setter Property="BorderBrush" Value="#2a7442"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="0"/>
        <Setter Property="Padding" Value="{StaticResource Xb360StatTilePadding}"/>
        <Setter Property="MinWidth" Value="{StaticResource Xb360StatTileMinWidth}"/>
        <Setter Property="MinHeight" Value="{StaticResource Xb360StatTileMinHeight}"/>
    </Style>

    <Style Selector="Border.game-card">
        <Setter Property="Background" Value="#112d1d"/>
        <Setter Property="BorderBrush" Value="#2a7442"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="0"/>
    </Style>

    <Style Selector="Button.game-card-btn /template/ ContentPresenter">
        <Setter Property="Background" Value="#112d1d"/>
        <Setter Property="BorderBrush" Value="#2a7442"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="0"/>
    </Style>

    <Style Selector="Button.game-card-btn">
        <Setter Property="CornerRadius" Value="0"/>
        <Setter Property="Width" Value="{StaticResource Xb360GameCardTileWidth}"/>
        <Setter Property="Margin" Value="{StaticResource Xb360GameCardTileMargin}"/>
    </Style>

    <Style Selector="Button.game-card-btn:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#184329"/>
    </Style>

    <Style Selector="Border.store-card">
        <Setter Property="Background" Value="#112d1d"/>
        <Setter Property="BorderBrush" Value="#2a7442"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="0"/>
    </Style>

    <Style Selector="Border.achievement-card">
        <Setter Property="Background" Value="#102619"/>
        <Setter Property="BorderBrush" Value="#2a7442"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="0"/>
    </Style>

    <Style Selector="Button.btn-primary">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#a0f05a" Offset="0"/>
                    <GradientStop Color="#63c63b" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="Foreground" Value="#0f2614"/>
        <Setter Property="CornerRadius" Value="0"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="#c8ff86"/>
    </Style>

    <Style Selector="Button.btn-primary:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#8de44f"/>
    </Style>

    <Style Selector="Button.btn-secondary">
        <Setter Property="Foreground" Value="#def8dc"/>
        <Setter Property="BorderBrush" Value="#4eb86b"/>
        <Setter Property="CornerRadius" Value="3"/>
    </Style>

    <Style Selector="Button.btn-secondary:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#1d5632"/>
    </Style>

    <Style Selector="TextBox.form-input">
        <Setter Property="Background" Value="#0d2417"/>
        <Setter Property="BorderBrush" Value="#45a75f"/>
        <Setter Property="Foreground" Value="#f0ffec"/>
    </Style>

    <Style Selector="Button.settings-nav-item">
        <Setter Property="Foreground" Value="#ddf8da"/>
        <Setter Property="CornerRadius" Value="0"/>
        <Setter Property="Margin" Value="0,1"/>
        <Setter Property="Padding" Value="18,12"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="#1f5a33"/>
    </Style>

    <Style Selector="Button.settings-nav-item /template/ ContentPresenter">
        <Setter Property="Background" Value="#123521"/>
        <Setter Property="CornerRadius" Value="0"/>
    </Style>

    <Style Selector="Button.settings-nav-item:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#1f6a39"/>
    </Style>

    <Style Selector="Button.settings-nav-item.active /template/ ContentPresenter">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#9eee58" Offset="0"/>
                    <GradientStop Color="#64c938" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>

    <Style Selector="Button.settings-nav-item.active">
        <Setter Property="Foreground" Value="#0f2414"/>
        <Setter Property="BorderBrush" Value="#c7ff7d"/>
    </Style>

</Styles>
