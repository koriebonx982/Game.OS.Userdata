<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Nintendo Wii inspired bright shell -->
    <Style Selector="Border.dashboard-xb360-layout">
        <Setter Property="IsVisible" Value="False"/>
    </Style>
    <Style Selector="Border.dashboard-ps5-layout">
        <Setter Property="IsVisible" Value="False"/>
    </Style>
    <Style Selector="Border.dashboard-wii-layout">
        <Setter Property="IsVisible" Value="True"/>
    </Style>
    <Style Selector="StackPanel.dashboard-default-layout">
        <Setter Property="IsVisible" Value="False"/>
    </Style>

    <Style Selector="Window.main-window-shell">
        <Setter Property="Background" Value="#dff4ff"/>
    </Style>
    <Style Selector="Border.main-content-surface">
        <Setter Property="Background" Value="#dff4ff"/>
    </Style>
    <Style Selector="Border.detail-overlay-surface">
        <Setter Property="Background" Value="#cfeefe"/>
    </Style>
    <Style Selector="UserControl.dashboard-root">
        <Setter Property="Background" Value="#dff4ff"/>
    </Style>
    <Style Selector="Border.nav-sidebar">
        <Setter Property="Background" Value="#f5fcff"/>
        <Setter Property="BorderBrush" Value="#a4d9ee"/>
        <Setter Property="BorderThickness" Value="0,0,1,0"/>
    </Style>
    <Style Selector="Border.nav-logo-area">
        <Setter Property="Background" Value="#4cb7dc"/>
    </Style>
    <Style Selector="TextBlock.nav-logo-text">
        <Setter Property="Foreground" Value="#ffffff"/>
    </Style>
    <Style Selector="Button.nav-item">
        <Setter Property="Foreground" Value="#2e6c88"/>
    </Style>
    <Style Selector="Button.nav-item.active /template/ ContentPresenter">
        <Setter Property="Background" Value="#6ec8e8"/>
    </Style>
    <Style Selector="Button.nav-item.active">
        <Setter Property="Foreground" Value="#ffffff"/>
    </Style>

    <Style Selector="TextBlock.page-title">
        <Setter Property="Foreground" Value="#1f5f7f"/>
    </Style>
    <Style Selector="TextBlock.page-subtitle">
        <Setter Property="Foreground" Value="#4b89a8"/>
    </Style>
    <Style Selector="TextBlock.section-header">
        <Setter Property="Foreground" Value="#1f5f7f"/>
    </Style>

    <Style Selector="Border.stat-tile">
        <Setter Property="Background" Value="#f6fdff"/>
        <Setter Property="BorderBrush" Value="#a4d9ee"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>
    <Style Selector="TextBlock.stat-number">
        <Setter Property="Foreground" Value="#1f5f7f"/>
    </Style>
    <Style Selector="TextBlock.stat-label">
        <Setter Property="Foreground" Value="#5a92ae"/>
    </Style>
    <Style Selector="TextBlock.stat-number-achievements">
        <Setter Property="Foreground" Value="#f5a623"/>
    </Style>
    <Style Selector="TextBlock.stat-number-platforms">
        <Setter Property="Foreground" Value="#2bb2d9"/>
    </Style>
    <Style Selector="TextBlock.stat-number-playtime">
        <Setter Property="Foreground" Value="#2a7fab"/>
    </Style>

    <Style Selector="Border.featured-hero-banner">
        <Setter Property="Background" Value="#f6fdff"/>
        <Setter Property="BorderBrush" Value="#a4d9ee"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>
    <Style Selector="TextBlock.hero-title">
        <Setter Property="Foreground" Value="#1f5f7f"/>
    </Style>
    <Style Selector="TextBlock.hero-desc">
        <Setter Property="Foreground" Value="#4b89a8"/>
    </Style>
    <Style Selector="Border.game-card">
        <Setter Property="Background" Value="#ffffff"/>
        <Setter Property="BorderBrush" Value="#a4d9ee"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>
    <Style Selector="TextBlock.game-card-title">
        <Setter Property="Foreground" Value="#1f5f7f"/>
    </Style>
    <Style Selector="TextBlock.game-card-meta">
        <Setter Property="Foreground" Value="#4b89a8"/>
    </Style>

    <Style Selector="Button.btn-primary">
        <Setter Property="Background" Value="#4cb7dc"/>
    </Style>
    <Style Selector="Button.btn-primary:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#5ec2e5"/>
    </Style>
    <Style Selector="Button.btn-secondary">
        <Setter Property="Foreground" Value="#2e6c88"/>
        <Setter Property="BorderBrush" Value="#8bcbe4"/>
    </Style>
    <Style Selector="Button.btn-secondary:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#eef9ff"/>
    </Style>

    <Style Selector="TextBlock.wii-menu-title">
        <Setter Property="FontSize" Value="36"/>
        <Setter Property="FontWeight" Value="Light"/>
        <Setter Property="Foreground" Value="#2f6f8c"/>
    </Style>
    <Style Selector="Button.wii-channel-tile">
        <Setter Property="Margin" Value="8"/>
        <Setter Property="Background" Value="#fbfeff"/>
        <Setter Property="BorderBrush" Value="#9bd2e8"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="14"/>
        <Setter Property="Padding" Value="10"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>
    <Style Selector="Button.wii-channel-tile:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#eef9ff"/>
    </Style>
    <Style Selector="TextBlock.wii-channel-title">
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#2f6f8c"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
    </Style>
    <Style Selector="TextBlock.wii-channel-subtitle">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Foreground" Value="#5d93ad"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
    </Style>
    <Style Selector="Border.wii-bottom-bar">
        <Setter Property="Background" Value="#ecf9ff"/>
        <Setter Property="BorderBrush" Value="#9bd2e8"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="28"/>
        <Setter Property="Padding" Value="12,8"/>
    </Style>
    <Style Selector="Border.wii-bottom-orb">
        <Setter Property="Width" Value="52"/>
        <Setter Property="Height" Value="52"/>
        <Setter Property="CornerRadius" Value="26"/>
        <Setter Property="Background" Value="#ffffff"/>
        <Setter Property="BorderBrush" Value="#9bd2e8"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <Style Selector="TextBlock.wii-bottom-orb-text">
        <Setter Property="Foreground" Value="#2f6f8c"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <Style Selector="TextBlock.wii-clock-time">
        <Setter Property="Foreground" Value="#2f6f8c"/>
        <Setter Property="FontSize" Value="34"/>
        <Setter Property="FontWeight" Value="Light"/>
    </Style>
    <Style Selector="TextBlock.wii-clock-date">
        <Setter Property="Foreground" Value="#5d93ad"/>
        <Setter Property="FontSize" Value="18"/>
    </Style>
</Styles>
