<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Layout visibility ──────────────────────────────────────────── -->
    <Style Selector="Border.dashboard-xb360-layout">
        <Setter Property="IsVisible" Value="False"/>
    </Style>
    <Style Selector="Border.dashboard-ps5-layout">
        <Setter Property="IsVisible" Value="False"/>
    </Style>
    <Style Selector="Border.dashboard-wii-layout">
        <Setter Property="IsVisible" Value="False"/>
    </Style>
    <Style Selector="StackPanel.dashboard-default-layout">
        <Setter Property="IsVisible" Value="False"/>
    </Style>
    <Style Selector="Border.dashboard-steambpm-layout">
        <Setter Property="IsVisible" Value="True"/>
    </Style>

    <!-- ── Window / surface ───────────────────────────────────────────── -->
    <Style Selector="Window.main-window-shell">
        <Setter Property="Background" Value="#1B2838"/>
    </Style>
    <Style Selector="Border.main-content-surface">
        <Setter Property="Background" Value="#1B2838"/>
    </Style>
    <Style Selector="Border.detail-overlay-surface">
        <Setter Property="Background" Value="#16202D"/>
    </Style>
    <Style Selector="UserControl.dashboard-root">
        <Setter Property="Background" Value="#1B2838"/>
    </Style>

    <!-- ── Top bar ────────────────────────────────────────────────────── -->
    <!-- "Recent Games" heading -->
    <Style Selector="TextBlock.steam-shell-title">
        <Setter Property="FontSize" Value="28"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
    </Style>
    <!-- Search / globe icon -->
    <Style Selector="TextBlock.steam-shell-icon">
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="Foreground" Value="#C6D4DF"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <!-- Clock -->
    <Style Selector="TextBlock.steam-shell-time">
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#C6D4DF"/>
    </Style>
    <!-- Avatar circle -->
    <Style Selector="Border.steam-shell-avatar">
        <Setter Property="Width" Value="40"/>
        <Setter Property="Height" Value="40"/>
        <Setter Property="CornerRadius" Value="20"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="BorderBrush" Value="#4F88C6"/>
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#8B4CAC" Offset="0"/>
                    <GradientStop Color="#4F88C6" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>
    <Style Selector="TextBlock.steam-shell-avatar-text">
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="Foreground" Value="White"/>
    </Style>

    <!-- ── Hero (large left card) ─────────────────────────────────────── -->
    <Style Selector="Button.steam-hero-recent-button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="VerticalContentAlignment" Value="Stretch"/>
    </Style>
    <Style Selector="Button.steam-hero-recent-button /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="CornerRadius" Value="0"/>
    </Style>
    <Style Selector="Button.steam-hero-recent-button:pointerover /template/ ContentPresenter">
        <Setter Property="Opacity" Value="0.95"/>
    </Style>
    <!-- Game title below the images -->
    <Style Selector="TextBlock.steam-hero-game-title">
        <Setter Property="FontSize" Value="22"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
    </Style>
    <!-- Playtime / meta (green to match Steam BPM) -->
    <Style Selector="TextBlock.steam-hero-game-meta">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#4BAD4E"/>
    </Style>

    <!-- ── Side recent cards (4 portrait cards right of hero) ─────────── -->
    <Style Selector="Button.steam-side-recent-button">
        <Setter Property="Width" Value="160"/>
        <Setter Property="Height" Value="264"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Background" Value="#16202D"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="VerticalContentAlignment" Value="Stretch"/>
    </Style>
    <Style Selector="Button.steam-side-recent-button /template/ ContentPresenter">
        <Setter Property="Background" Value="#16202D"/>
        <Setter Property="CornerRadius" Value="0"/>
    </Style>
    <Style Selector="Button.steam-side-recent-button:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#1E2D3D"/>
    </Style>
    <!-- "NEW TO LIBRARY" / kind chip on side cards -->
    <Style Selector="Border.steam-side-card-chip">
        <Setter Property="Margin" Value="8,8,0,0"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="CornerRadius" Value="2"/>
        <Setter Property="Background" Value="#2A6496"/>
    </Style>
    <Style Selector="TextBlock.steam-side-card-chip-text">
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="White"/>
    </Style>

    <!-- ── Tab pills ──────────────────────────────────────────────────── -->
    <Style Selector="Border.steam-tab-pill">
        <Setter Property="Padding" Value="20,9"/>
        <Setter Property="CornerRadius" Value="20"/>
        <Setter Property="Background" Value="#22303E"/>
    </Style>
    <Style Selector="Border.steam-tab-pill-active">
        <Setter Property="Background" Value="#3D4E5C"/>
    </Style>
    <Style Selector="TextBlock.steam-tab-pill-text">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#C6D4DF"/>
    </Style>
    <Style Selector="Border.steam-tab-count-pill">
        <Setter Property="Background" Value="#3A9B45"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="7,2"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <Style Selector="TextBlock.steam-tab-count-text">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="White"/>
    </Style>

    <!-- ── News cards ─────────────────────────────────────────────────── -->
    <!-- Category label above the card -->
    <Style Selector="TextBlock.steam-news-category">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="#5BB6FF"/>
    </Style>
    <!-- Card container -->
    <Style Selector="Border.steam-news-card">
        <Setter Property="Width" Value="248"/>
        <Setter Property="Background" Value="#16202D"/>
    </Style>
    <!-- Dark footer -->
    <Style Selector="Border.steam-news-footer">
        <Setter Property="Background" Value="#213040"/>
        <Setter Property="Padding" Value="12,10,12,12"/>
    </Style>
    <!-- Date / meta text -->
    <Style Selector="TextBlock.steam-news-meta">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Foreground" Value="#8BA3B8"/>
    </Style>
    <!-- News title -->
    <Style Selector="TextBlock.steam-news-title">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
    </Style>
</Styles>

