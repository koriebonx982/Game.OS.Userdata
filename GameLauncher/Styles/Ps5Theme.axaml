<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- PS5 (PlayStation 5 UI inspired) override theme
         Colour palette:
           Background     #0D0D0D  (near-black)
           Card surface   #2A2A2A
           Sidebar        #1A1A1A
           Active accent  #00AEEF  (PS5 blue)
           Focus ring     #FFD400  (PlayStation gold/yellow)
           Primary text   #FFFFFF / #ECECEC
           Secondary text #B3B3B3 / #9E9E9E
    -->

    <!-- ── Dashboard layout visibility ── -->
    <Style Selector="Border.dashboard-ps5-layout">
        <Setter Property="IsVisible" Value="True"/>
    </Style>

    <Style Selector="Border.dashboard-xb360-layout">
        <Setter Property="IsVisible" Value="False"/>
    </Style>

    <Style Selector="StackPanel.dashboard-default-layout">
        <Setter Property="IsVisible" Value="False"/>
    </Style>

    <!-- ── Shell backgrounds ── -->
    <Style Selector="Window.main-window-shell">
        <Setter Property="Background" Value="#0D0D0D"/>
    </Style>

    <Style Selector="Border.main-content-surface">
        <Setter Property="Background" Value="#0D0D0D"/>
    </Style>

    <Style Selector="Border.detail-overlay-surface">
        <Setter Property="Background" Value="#0D0D0D"/>
    </Style>

    <Style Selector="UserControl.dashboard-root">
        <Setter Property="Background" Value="#0D0D0D"/>
    </Style>

    <!-- ── Top bar / friend strip ── -->
    <Style Selector="Border.friend-profile-topbar">
        <Setter Property="Background" Value="#1A1A1A"/>
        <Setter Property="BorderBrush" Value="#2A2A2A"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
    </Style>

    <Style Selector="Border.sync-overlay-panel">
        <Setter Property="Background" Value="#1E1E1E"/>
        <Setter Property="BorderBrush" Value="#00AEEF"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <!-- ── Navigation sidebar ── -->
    <Style Selector="Border.nav-sidebar">
        <Setter Property="Background" Value="#1A1A1A"/>
    </Style>

    <Style Selector="Border.nav-logo-area">
        <Setter Property="Background" Value="#003087"/>
        <Setter Property="BorderBrush" Value="#00439C"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
    </Style>

    <Style Selector="TextBlock.nav-logo-text">
        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <Style Selector="Button.nav-item">
        <Setter Property="Foreground" Value="#B3B3B3"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Margin" Value="8,2"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <Style Selector="Button.nav-item /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="CornerRadius" Value="6"/>
    </Style>

    <Style Selector="Button.nav-item:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#2A2A2A"/>
    </Style>

    <Style Selector="Button.nav-item.active /template/ ContentPresenter">
        <Setter Property="Background" Value="#00439C"/>
    </Style>

    <Style Selector="Button.nav-item.active">
        <Setter Property="Foreground" Value="#FFFFFF"/>
    </Style>

    <!-- ── Page text ── -->
    <Style Selector="TextBlock.page-title">
        <Setter Property="FontSize" Value="28"/>
        <Setter Property="Foreground" Value="#ECECEC"/>
    </Style>

    <Style Selector="TextBlock.page-subtitle">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="#9E9E9E"/>
    </Style>

    <Style Selector="TextBlock.section-header">
        <Setter Property="Foreground" Value="#ECECEC"/>
    </Style>

    <!-- ── Stat tiles ── -->
    <Style Selector="Border.stat-tile">
        <Setter Property="Background" Value="#1E1E1E"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <Style Selector="TextBlock.stat-number-achievements">
        <Setter Property="Foreground" Value="#FFD400"/>
    </Style>

    <Style Selector="TextBlock.stat-number-platforms">
        <Setter Property="Foreground" Value="#00AEEF"/>
    </Style>

    <Style Selector="TextBlock.stat-number-playtime">
        <Setter Property="Foreground" Value="#B3B3B3"/>
    </Style>

    <!-- ── Hero / featured banner ── -->
    <Style Selector="Border.featured-hero-banner">
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#001A3D" Offset="0"/>
                    <GradientStop Color="#000D1F" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <Style Selector="Border.hero-feature-badge">
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Background" Value="#003087"/>
    </Style>

    <Style Selector="Border.hero-platform-badge">
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Background" Value="#001A3D"/>
        <Setter Property="BorderBrush" Value="#00AEEF"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style Selector="TextBlock.hero-platform-badge-text">
        <Setter Property="Foreground" Value="#00AEEF"/>
    </Style>

    <!-- ── Game platform pill ── -->
    <Style Selector="Border.game-platform-pill">
        <Setter Property="Background" Value="#003087"/>
        <Setter Property="CornerRadius" Value="4"/>
    </Style>

    <!-- ── Game cards ── -->
    <Style Selector="Border.game-card">
        <Setter Property="Background" Value="#2A2A2A"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <Style Selector="Button.game-card-btn /template/ ContentPresenter">
        <Setter Property="Background" Value="#2A2A2A"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <Style Selector="Button.game-card-btn">
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <Style Selector="Button.game-card-btn:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#333333"/>
    </Style>

    <!-- PS5-specific game-card strip buttons (wider, no info panel below) -->
    <Style Selector="Button.ps5-game-card-btn">
        <Setter Property="Width" Value="160"/>
        <Setter Property="Margin" Value="8,0"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>

    <Style Selector="Button.ps5-game-card-btn:focus /template/ ContentPresenter">
        <Setter Property="BorderBrush" Value="#FFD400"/>
    </Style>

    <Style Selector="Button.ps5-game-card-btn:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#333333"/>
    </Style>

    <!-- Store cards -->
    <Style Selector="Border.store-card">
        <Setter Property="Background" Value="#2A2A2A"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <!-- ── Achievement cards ── -->
    <Style Selector="Border.achievement-card">
        <Setter Property="Background" Value="#1E1E1E"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <Style Selector="Border.achievement-icon-card">
        <Setter Property="Background" Value="#2D2D00"/>
    </Style>

    <Style Selector="TextBlock.achievement-meta">
        <Setter Property="Foreground" Value="#9E9E9E"/>
    </Style>

    <Style Selector="TextBlock.achievement-divider">
        <Setter Property="Foreground" Value="#3A3A3A"/>
    </Style>

    <!-- ── Buttons ── -->
    <!-- Primary action — PS5 pill: dark translucent, rounded pill shape -->
    <Style Selector="Button.btn-primary">
        <Setter Property="Background" Value="#222224"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Setter Property="CornerRadius" Value="20"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style Selector="Button.btn-primary:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#2E2E32"/>
    </Style>

    <!-- PS5 primary action specific (full-width pill) -->
    <Style Selector="Button.ps5-action-primary">
        <Setter Property="CornerRadius" Value="23"/>
    </Style>

    <!-- PS5 "more" square button -->
    <Style Selector="Button.ps5-action-more">
        <Setter Property="Background" Value="#1F1F1F"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="#ECECEC"/>
    </Style>

    <!-- Secondary -->
    <Style Selector="Button.btn-secondary">
        <Setter Property="Foreground" Value="#B3B3B3"/>
        <Setter Property="BorderBrush" Value="#3A3A3A"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style Selector="Button.btn-secondary:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#2A2A2A"/>
    </Style>

    <!-- ── Form inputs ── -->
    <Style Selector="TextBox.form-input">
        <Setter Property="Background" Value="#1E1E1E"/>
        <Setter Property="BorderBrush" Value="#3A3A3A"/>
        <Setter Property="Foreground" Value="#ECECEC"/>
    </Style>

    <!-- ── Settings navigation ── -->
    <Style Selector="Button.settings-nav-item">
        <Setter Property="Foreground" Value="#B3B3B3"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Margin" Value="8,2"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <Style Selector="Button.settings-nav-item /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="CornerRadius" Value="6"/>
    </Style>

    <Style Selector="Button.settings-nav-item:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#2A2A2A"/>
    </Style>

    <Style Selector="Button.settings-nav-item.active /template/ ContentPresenter">
        <Setter Property="Background" Value="#00439C"/>
    </Style>

    <Style Selector="Button.settings-nav-item.active">
        <Setter Property="Foreground" Value="#FFFFFF"/>
    </Style>

    <!-- ── Empty state ── -->
    <Style Selector="Border.empty-state-card">
        <Setter Property="Background" Value="#1E1E1E"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <Style Selector="TextBlock.empty-state-title">
        <Setter Property="Foreground" Value="#9E9E9E"/>
    </Style>

    <Style Selector="TextBlock.empty-state-subtitle">
        <Setter Property="Foreground" Value="#5A5A5A"/>
    </Style>

    <Style Selector="TextBlock.game-playtime-meta">
        <Setter Property="Foreground" Value="#B3B3B3"/>
    </Style>

    <!-- ── PS5 Dashboard specific classes ── -->

    <!-- "Games" heading -->
    <Style Selector="TextBlock.ps5-header-title">
        <Setter Property="FontSize" Value="28"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
    </Style>

    <!-- " Media" softer heading -->
    <Style Selector="TextBlock.ps5-header-media">
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="Foreground" Value="#B3B3B3"/>
        <Setter Property="VerticalAlignment" Value="Bottom"/>
        <Setter Property="Margin" Value="8,0,0,3"/>
    </Style>

    <!-- Game-strip card title -->
    <Style Selector="TextBlock.ps5-card-title">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#ECECEC"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="MaxLines" Value="2"/>
        <Setter Property="TextAlignment" Value="Center"/>
    </Style>

    <!-- Achievements panel backdrop -->
    <Style Selector="Border.ps5-achievements-panel">
        <Setter Property="Background" Value="#1E1E1E"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="BorderBrush" Value="#2B2B2B"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <!-- Bottom status tiles -->
    <Style Selector="Border.ps5-status-tile">
        <Setter Property="Background" Value="#2A2A2A"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <Style Selector="TextBlock.ps5-status-value">
        <Setter Property="Foreground" Value="#D1D1D1"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style Selector="TextBlock.ps5-status-label">
        <Setter Property="Foreground" Value="#9E9E9E"/>
        <Setter Property="FontSize" Value="11"/>
    </Style>

</Styles>
